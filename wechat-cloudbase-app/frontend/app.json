{
  "pages": [
    "pages/discover/index",
    "pages/record/index",
    "pages/mine/index",
    "pages/material-detail/index",
    "pages/inspiration-edit/index",
    "pages/practice-feedback/index",
    "pages/rehearsal-record/index",
    "pages/rehearsal-review/index",
    "pages/team-records/index",
    "pages/practice-records/index",
    "pages/settings/index",
    "pages/help/index",
    "pages/privacy/index"
  ],
  "window": {
    "navigationStyle": "custom",
    "backgroundColor": "#FAFAF7",
    "backgroundTextStyle": "dark",
    "enablePullDownRefresh": true
  },
  "tabBar": {
    "custom": true,
    "color": "#8D9AA5",
    "selectedColor": "#2F6F93",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/discover/index",
        "text": "发现",
        "iconPath": "assets/tabbar/discover.png",
        "selectedIconPath": "assets/tabbar/discover.png"
      },
      {
        "pagePath": "pages/record/index",
        "text": "记录",
        "iconPath": "assets/tabbar/record.png",
        "selectedIconPath": "assets/tabbar/record.png"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的",
        "iconPath": "assets/tabbar/mine.png",
        "selectedIconPath": "assets/tabbar/mine.png"
      }
    ]
  },
  "style": "v2",
  "renderer": "skyline",
  "componentFramework": "glass-easel",
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "defaultContentBox": true,
      "disableABTest": true
    }
  },
  "lazyCodeLoading": "requiredComponents",
  "sitemapLocation": "sitemap.json",
  "__usePrivacyCheck__": true
}
