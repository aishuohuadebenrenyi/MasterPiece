@import "./styles/theme.wxss";

page {
  --nav-row-top: 108rpx;
  --content-safe-top: 172rpx;
  --page-side: 40rpx;
  --page-bottom: 128rpx;
  width: 100vw;
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fff5ef 0%, #f7f9ff 54%, #eef5ff 100%);
  background: linear-gradient(180deg, var(--improv-bg-top, #fff5ef) 0%, var(--improv-bg-mid, #f7f9ff) 54%, var(--improv-bg-bottom, #eef5ff) 100%);
  color: #24324a;
  color: var(--improv-text, #24324a);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  width: auto;
  min-width: 0;
  min-height: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: 1.2;
  text-align: center;
  vertical-align: middle;
  overflow: visible;
}

button::after {
  border: 0;
}

.back {
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  min-height: 64rpx;
  display: inline-flex;
  align-items: center;
  margin: 0;
  padding: 0;
  align-self: flex-start;
  justify-content: center;
  color: var(--improv-text);
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.page {
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
  overflow-x: hidden;
  padding: var(--content-safe-top) var(--page-side) var(--page-bottom);
  background: linear-gradient(180deg, var(--improv-bg-top, #fff5ef) 0%, var(--improv-bg-mid, #f7f9ff) 54%, var(--improv-bg-bottom, #eef5ff) 100%);
  color: var(--improv-text, #24324a);
}

.subpage-page {
  height: 100vh;
  min-height: 0;
  padding: var(--nav-row-top) var(--page-side) calc(48rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  background: linear-gradient(180deg, var(--improv-bg-top, #fff5ef) 0%, var(--improv-bg-mid, #f7f9ff) 54%, var(--improv-bg-bottom, #eef5ff) 100%);
  color: var(--improv-text, #24324a);
}

.page.modal-open {
  height: 100vh;
  overflow: hidden;
}

.safe-right {
  padding-right: 196rpx;
}

.card {
  border-radius: 40rpx;
  background: #ffffff;
  background: var(--improv-card-strong, #ffffff);
  border: 2rpx solid rgba(94, 114, 144, 0.08);
  border: 2rpx solid var(--improv-line-subtle, rgba(94, 114, 144, 0.08));
  box-shadow: 0 24rpx 56rpx rgba(55, 82, 150, 0.12);
  box-shadow: var(--improv-shadow-md, 0 24rpx 56rpx rgba(55, 82, 150, 0.14));
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover {
  transform: scale(0.98);
  box-shadow: 0 12rpx 24rpx rgba(55, 82, 150, 0.08) !important;
}

.title {
  color: var(--improv-text);
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.1;
}

.kicker,
.mini-title {
  display: block;
  color: var(--improv-light-strong);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
}

.muted {
  color: var(--improv-muted-strong);
  font-size: 25rpx;
  line-height: 1.7;
}

.primary-btn,
.ghost-btn,
.small-btn,
.chip,
.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.primary-btn {
  min-height: 76rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, #ff7a45, #ff5b2e);
  background: linear-gradient(135deg, var(--improv-primary, #ff7a45), var(--improv-primary-strong, #ff5b2e));
  color: #ffffff;
  color: var(--improv-on-brand, #ffffff);
  box-shadow: 0 20rpx 40rpx rgba(255, 91, 46, 0.2);
  box-shadow: 0 20rpx 40rpx var(--improv-shadow-action-color, rgba(255, 91, 46, 0.2));
}

.ghost-btn {
  min-height: 74rpx;
  padding: 0 26rpx;
  background: #e8f0ff;
  background: var(--improv-secondary-soft, #e8f0ff);
  color: #2f6ff2;
  color: var(--improv-secondary-strong, #2f6ff2);
}

.small-btn {
  min-height: 58rpx;
  padding: 0 22rpx;
  background: #ffffff;
  background: var(--improv-card-strong, #ffffff);
  border: 2rpx solid rgba(94, 114, 144, 0.14);
  border: 2rpx solid var(--improv-line, rgba(94, 114, 144, 0.14));
  color: #667289;
  color: var(--improv-muted, #667289);
  font-size: 24rpx;
}

.chip {
  flex: none;
  width: auto;
  min-width: 0;
  min-height: 70rpx;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.92);
  background: var(--improv-card-translucent, rgba(255, 255, 255, 0.92));
  color: #24324a;
  color: var(--improv-text, #24324a);
  box-shadow: 0 12rpx 24rpx rgba(50, 68, 120, 0.06);
  box-shadow: 0 12rpx 24rpx var(--improv-shadow-chip-color, rgba(50, 68, 120, 0.06));
  white-space: nowrap;
}

.chip.active {
  background: #e8f0ff;
  background: var(--improv-secondary-soft, #e8f0ff);
  color: #2f6ff2;
  color: var(--improv-secondary-strong, #2f6ff2);
}

.main-filter-chip {
  min-width: 102rpx;
  min-height: 68rpx;
  padding: 0 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  border: 2rpx solid var(--improv-line-soft, rgba(255, 255, 255, 0.28));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.9));
  background: linear-gradient(180deg, var(--improv-card-strong, rgba(255, 255, 255, 0.98)), var(--improv-card-translucent, rgba(255, 255, 255, 0.9)));
  color: #4f5d78;
  color: var(--improv-text-soft, #4f5d78);
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.4rpx;
  line-height: 1;
  box-shadow: 0 12rpx 26rpx rgba(50, 68, 120, 0.08);
  box-shadow: 0 12rpx 26rpx var(--improv-shadow-chip-color, rgba(50, 68, 120, 0.08));
}

.main-filter-chip.active {
  border-color: rgba(79, 140, 255, 0.06);
  background: linear-gradient(135deg, #4f8cff, #ff7a45);
  background: linear-gradient(135deg, var(--improv-secondary, #4f8cff), var(--improv-primary, #ff7a45));
  color: #ffffff;
  color: var(--improv-on-brand, #ffffff);
  box-shadow: 0 18rpx 34rpx rgba(82, 107, 209, 0.2);
  box-shadow: 0 18rpx 34rpx var(--improv-shadow-secondary-color, rgba(82, 107, 209, 0.2));
}

.compact-filter-chip {
  min-width: 80rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(94, 114, 144, 0.1);
  border: 2rpx solid var(--improv-line-soft, rgba(94, 114, 144, 0.1));
  background: rgba(255, 255, 255, 0.9);
  background: var(--improv-card, rgba(255, 255, 255, 0.9));
  color: #74819a;
  color: var(--improv-muted, #74819a);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: none;
}

.compact-filter-chip.active {
  border-color: rgba(79, 140, 255, 0.12);
  border-color: var(--improv-secondary-wash-soft, rgba(79, 140, 255, 0.12));
  background: rgba(232, 240, 255, 0.78);
  background: var(--improv-secondary-soft, rgba(232, 240, 255, 0.78));
  color: #2f6ff2;
  color: var(--improv-secondary-strong, #2f6ff2);
  box-shadow: none;
}

.chip-scroll {
  width: 100%;
  min-width: 0;
  height: 104rpx;
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
}

.chip-row {
  width: auto;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 2rpx 0 14rpx;
  gap: 14rpx;
  white-space: nowrap;
  height: 100%;
}

.chip-row .chip {
  flex: 0 0 auto !important;
  width: auto !important;
}

.pill {
  flex: 0 0 auto;
  align-self: flex-start;
  width: auto;
  max-width: 100%;
  min-height: 52rpx;
  padding: 0 20rpx;
  background: var(--improv-bg-soft);
  color: var(--improv-muted);
  font-size: 24rpx;
}

.pill.blue {
  background: var(--improv-secondary-soft);
  color: var(--improv-secondary-strong);
}

.pill.orange {
  background: var(--improv-primary-soft);
  color: var(--improv-primary-strong);
}

.app-toast {
  position: fixed;
  left: 50%;
  bottom: calc(280rpx + env(safe-area-inset-bottom));
  z-index: 120;
  width: auto;
  min-width: 0;
  max-width: 600rpx;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 26rpx;
  border: 1rpx solid var(--improv-toast-line);
  border-radius: 999rpx;
  background: var(--improv-toast-bg);
  box-shadow: 0 18rpx 40rpx var(--improv-shadow-toast-color);
  transform: translateX(-50%);
  backdrop-filter: blur(18rpx);
  pointer-events: none;
}

.app-toast text {
  color: var(--improv-on-brand);
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  text-align: center;
}

.app-toast-warm {
  background: var(--improv-toast-warm-bg);
  border-color: var(--improv-toast-line-strong);
}

.app-toast-warm text {
  color: var(--improv-on-brand);
}

.app-toast-error {
  background: var(--improv-toast-error-bg);
  border-color: var(--improv-toast-error-line);
}

.app-toast-error text {
  color: var(--improv-on-brand);
}

page {
  --improv-form-gap-tight: 10rpx;
  --improv-form-gap-field-body: 14rpx;
  --improv-form-gap-inline: 16rpx;
  --improv-form-gap-related: 28rpx;
  --improv-form-gap-section: 48rpx;
}

.field {
  display: block;
  margin-top: 0;
  color: var(--improv-text);
  font-size: 26rpx;
  font-weight: 900;
}

.app-input,
.app-textarea,
.field input,
.field textarea {
  width: 100%;
  min-height: 82rpx;
  margin-top: 0 !important;
  padding: 26rpx 32rpx;
  border: 2rpx solid transparent;
  border-radius: 32rpx;
  background: var(--improv-bg-field-soft, var(--improv-bg-field));
  color: var(--improv-text);
  font-size: 28rpx;
}

.app-input,
.field input {
  height: 82rpx;
  line-height: 82rpx;
}

.app-textarea,
.field textarea {
  min-height: 220rpx;
  line-height: 1.55;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: var(--improv-form-gap-tight, 8rpx);
}

form-field {
  display: block;
  width: 100%;
}

.form-field-stack {
  display: flex;
  flex-direction: column;
  gap: 84rpx;
}

.form-field-stack > .form-field + .form-field {
  margin-top: 84rpx;
}

.form-field > input,
.form-field > textarea,
.form-field > .app-input,
.form-field > .app-textarea,
.form-field > .field-picker,
.form-field > .field-static,
.form-field > .input-shell {
  margin-top: 0;
}

.form-field > .input-shell input,
.form-field > .input-shell textarea,
.form-field > .input-shell .app-input,
.form-field > .input-shell .app-textarea {
  margin-top: 0;
}

.choice-section {
  display: flex;
  flex-direction: column;
  gap: var(--improv-form-gap-tight, 8rpx);
}

.choice-section > .section-head,
.choice-section > .card-head {
  margin-bottom: 0;
}

.choice-section .form-chip-row,
.choice-section .sheet-chip-row,
.choice-section .chip-scroll {
  margin-top: 0;
}

.section-stack > .choice-section + .choice-section {
  margin-top: var(--improv-form-gap-section, 40rpx);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.button-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.button-row-equal > button,
.button-row-equal > view,
.button-row-equal > .primary-btn,
.button-row-equal > .ghost-btn,
.button-row-equal > .small-btn {
  flex: 1 1 0;
  min-width: 0;
}

.tag-row {
  display: flex;
  gap: 18rpx;
  overflow-x: auto;
  padding-bottom: 12rpx;
  white-space: nowrap;
  width: 100%;
}

.form-chip-row,
.sheet-chip-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
  gap: 18rpx;
  margin-top: 10rpx;
  overflow: visible;
  padding-bottom: 0;
  white-space: normal;
}

.form-chip-row .chip,
.sheet-chip-row .chip {
  width: 100%;
  flex: 1 1 0;
  min-width: 0;
  max-width: 100%;
  min-height: 76rpx;
  padding: 0 14rpx;
  font-size: 26rpx;
  line-height: 1.15;
  white-space: nowrap;
}

.sheet-chip-row .chip {
  flex-basis: auto;
}

.subpage-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.subpage-header .back {
  margin-bottom: 30rpx;
}

.page-title,
.section-title {
  color: var(--improv-text);
  font-weight: 900;
}

.page-title {
  font-size: 56rpx;
  line-height: 1.1;
}

.section-head,
.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.25;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: var(--improv-bg-soft);
  color: var(--improv-muted);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.meta-pill.pending {
  background: var(--improv-primary-tint);
  color: var(--improv-warm);
}

.sync-pill {
  flex: 0 0 auto;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: var(--improv-primary-tint);
  color: var(--improv-warm);
  font-size: 22rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.state-note-card,
.notice-note-card {
  padding: 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 800;
}

.state-note-card {
  background: var(--improv-card-light);
  color: var(--improv-muted);
}

.notice-note-card {
  margin-bottom: 22rpx;
  background: var(--improv-primary-tint);
  color: var(--improv-warm);
}

.empty-state-card {
  padding: 42rpx 36rpx 40rpx;
  border-radius: 40rpx;
  background: var(--improv-card-strong);
  border: 2rpx solid var(--improv-line-soft);
  box-shadow: var(--improv-shadow-xs);
}

.empty-state-card .section-title {
  margin-bottom: 10rpx;
}

.empty-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-action-btn {
  flex: 1 1 0;
}

.record-form-card {
  padding: 38rpx 34rpx;
  margin-bottom: 32rpx;
}

.field-picker {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 10rpx;
}

.field-picker input {
  flex: 1;
  min-width: 0;
  margin-top: 0;
}

.field-picker .small-btn {
  flex: 0 0 156rpx;
  min-height: 82rpx;
}

.form-actions,
.fixed-actions,
.save-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.form-actions,
.fixed-actions {
  position: fixed;
  left: 34rpx;
  right: 34rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 30;
  margin-top: 0;
  padding: 14rpx;
  border-radius: 44rpx;
  background: var(--improv-card);
  box-shadow: 0 18rpx 42rpx var(--improv-shadow-fixed-color);
  backdrop-filter: blur(16rpx);
}

.form-actions button,
.fixed-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.form-actions button,
.fixed-actions button {
  min-height: 76rpx;
}

.sheet-submit {
  width: 320rpx;
  max-width: 72%;
  margin: 24rpx auto 0;
  align-self: center;
}

.option-card {
  padding: 28rpx;
  margin-top: 18rpx;
}

.card-head > view,
.row > view {
  flex: 1 1 0;
  min-width: 0;
}

.card-head > .small-btn,
.row > .small-btn,
.option-card .small-btn {
  flex: 0 0 auto;
  width: auto;
  min-width: 112rpx;
  max-width: 176rpx;
  min-height: 56rpx;
  padding: 0 22rpx;
}

.icon-close-btn {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  min-height: 56rpx;
  max-width: 56rpx;
  max-height: 56rpx;
  border-radius: 28rpx;
  background: var(--improv-card-strong, #ffffff);
  color: var(--improv-muted);
  font-weight: 900;
  font-size: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  border: 2rpx solid var(--improv-line, rgba(94, 114, 144, 0.14));
}
