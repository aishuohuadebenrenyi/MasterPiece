@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
}

.selection-card {
  padding: 28rpx;
  margin-top: 20rpx;
  border: 2rpx solid transparent;
}

.selection-card-selected {
  border-color: var(--improv-primary);
  background: var(--improv-primary-tint);
}

.selection-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.selection-card-main {
  flex: 1 1 auto;
  min-width: 0;
}

.selection-card-title {
  margin-top: 8rpx;
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.selection-card-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
}

.selection-card-desc {
  display: block;
  margin-top: 10rpx;
  line-height: 1.6;
}

.selection-card-meta {
  margin-top: 16rpx;
}

.selection-card-selected-pill {
  flex: 0 0 auto;
}
