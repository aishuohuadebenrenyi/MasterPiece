@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.selection-card {
  padding: var(--improv-card-padding-sm, 28rpx);
  margin-top: 20rpx;
  border: 2rpx solid var(--improv-card-container-border, transparent);
}

.selection-card-selected {
  border-color: var(--improv-primary);
  background: linear-gradient(160deg, var(--improv-primary-tint), var(--improv-card-container-bg, rgba(255, 255, 255, 0.94)));
  box-shadow: 0 22rpx 44rpx var(--improv-shadow-primary-soft-color, rgba(255, 91, 46, 0.22));
}

.selection-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.selection-card-main {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.selection-card-title {
  margin-top: 8rpx;
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.selection-card-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
  align-self: flex-start;
}

.selection-card-actions .small-btn {
  flex: 0 0 132rpx;
  width: 132rpx;
  min-width: 132rpx;
  max-width: 132rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 34rpx;
}

.selection-card-desc {
  display: block;
  margin-top: 14rpx;
  line-height: 1.6;
}

.selection-card-meta {
  margin-top: 16rpx;
}

.selection-card-selected-pill {
  flex: 0 0 auto;
}
