@import "../../styles/theme.wxss";

.game-card {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 28rpx;
  min-height: 196rpx;
  padding: 30rpx;
  border-radius: var(--improv-radius-card);
  background: #ffffff;
  background: var(--improv-card-strong, #ffffff);
  border: 2rpx solid var(--improv-line-subtle);
  box-shadow: var(--improv-shadow-md);
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.game-card.large {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 640rpx;
  padding: 44rpx 38rpx 34rpx;
  background:
    linear-gradient(160deg, var(--improv-card-translucent, rgba(255, 255, 255, 0.92)), var(--improv-card-muted, rgba(255, 255, 255, 0.74))),
    linear-gradient(135deg, var(--improv-primary-wash, rgba(255, 122, 69, 0.14)), var(--improv-secondary-wash-soft, rgba(79, 140, 255, 0.14)));
}

.large .stripe {
  display: none;
}

.large .game-main {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.stripe,
.stripe.orange {
  flex: 0 0 12rpx;
  width: 12rpx;
  height: 124rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, var(--improv-primary, #ff7a45), var(--improv-primary-glow, #ffb569));
}

.stripe.blue {
  background: linear-gradient(180deg, var(--improv-secondary, #4f8cff), var(--improv-secondary-glow, #7fb1ff));
}

.stripe.mint {
  background: linear-gradient(180deg, var(--improv-success, #35bfa6), var(--improv-success-soft, #7ce0cf));
}

.game-main {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.game-head {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.game-head-text {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  white-space: normal;
}

.game-tag-pill {
  align-self: flex-start;
  width: auto;
  max-width: 100%;
}

.game-title {
  color: var(--improv-text);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.18;
  white-space: normal;
  word-break: break-all;
}

.large .game-title {
  margin-top: 4rpx;
  font-size: 52rpx;
  line-height: 1.12;
}

.game-desc-block {
  display: flex;
  width: 100%;
  min-width: 0;
}

.game-desc {
  color: var(--improv-text-soft, #5a6781);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.55;
  letter-spacing: 0.2rpx;
  white-space: normal;
  word-break: break-all;
}

.large .game-desc {
  font-size: 30rpx;
}

.save {
  flex: 0 0 auto;
  align-self: flex-start;
  width: 74rpx;
  height: 74rpx;
  min-width: 74rpx;
  min-height: 74rpx;
  max-width: 74rpx;
  max-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: transparent;
  color: var(--improv-muted-strong, #7b88a2);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Rounded", "PingFang SC", sans-serif;
  font-size: 40rpx;
  font-weight: 500;
  line-height: 1;
  border: 0;
  box-shadow: none;
}

.save-idle {
  color: var(--improv-favorite-idle, #b7c5e6);
  opacity: 0.96;
}

.save-active {
  color: var(--improv-favorite-active, #f2aea4);
  opacity: 0.98;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  white-space: normal;
}

.meta text {
  display: inline-flex;
  align-items: center;
  min-height: 0;
  padding: 6rpx 16rpx;
  background: var(--improv-bg-soft);
  color: var(--improv-muted);
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 999rpx;
}

.large .meta {
  margin: 0;
}
