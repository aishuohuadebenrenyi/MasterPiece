<view class="game-card card card-surface-content {{modeClass}}" hover-class="card-hover" bindtap="open">
  <view class="stripe {{stripeClass}}"></view>
  <view class="game-main">
    <view class="row game-head">
      <view class="game-head-text">
        <text wx:if="{{isCard}}" class="pill blue game-tag-pill">{{primaryTag}}</text>
        <view class="game-title">{{game.title}}</view>
      </view>
      <button class="save {{saved || game.saved ? 'save-active' : 'save-idle'}}" catchtap="save">{{saveIcon}}</button>
    </view>

    <view wx:if="{{game.desc}}" class="game-desc-block">
      <text class="game-desc">{{game.desc}}</text>
    </view>

    <view wx:if="{{isCard && displayMeta && displayMeta.length}}" class="meta">
      <text wx:for="{{displayMeta}}" wx:key="*this">{{item}}</text>
    </view>
  </view>
</view>
