view,
button,
text {
  box-sizing: border-box;
}

.sheet-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 80;
  pointer-events: none;
}

.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  opacity: 0;
  background: rgba(36, 50, 74, 0.14);
  transition: opacity 0.2s ease;
  pointer-events: auto;
}

.sheet-mask.visible {
  opacity: 1;
}

.sheet-mask.mask-light {
  background: rgba(36, 50, 74, 0.14);
}

.sheet-mask.mask-medium {
  background: rgba(36, 50, 74, 0.24);
}

.sheet-mask.mask-strong {
  background: rgba(18, 26, 44, 0.36);
}

.sheet {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 1;
  max-height: 78vh;
  overflow-y: auto;
  padding: 36rpx 30rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--improv-sheet-shadow);
  transform: translateY(calc(100% + 40rpx));
  transition: transform 0.24s ease;
  pointer-events: auto;
}

.sheet-content {
  width: 100%;
}

.sheet.filter-sheet {
  left: 26rpx;
  right: 26rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  padding: 34rpx 28rpx 34rpx;
  border-radius: 42rpx;
}

.sheet.tab-sheet {
  left: 24rpx;
  right: 24rpx;
  bottom: calc(14rpx + env(safe-area-inset-bottom));
  border-radius: 44rpx;
}

.sheet.mine-list-sheet,
.sheet.mine-detail-sheet {
  left: 24rpx;
  right: 24rpx;
  bottom: calc(14rpx + env(safe-area-inset-bottom));
  padding: 34rpx 26rpx 30rpx;
  border-radius: 44rpx;
  max-height: 72vh;
}

.sheet.mine-detail-sheet {
  padding-bottom: 34rpx;
}

.sheet.show {
  transform: translateY(0);
}

.handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #d7dfef;
}

.sheet-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.sheet-title {
  flex: 1 1 0;
  min-width: 0;
  color: #24324a;
  font-size: 34rpx;
  font-weight: 900;
}

.small-btn {
  min-height: 58rpx;
  padding: 0 20rpx;
  border: 2rpx solid rgba(94, 114, 144, 0.14);
  border-radius: 999rpx;
  background: #fff;
  color: #667289;
  font-size: 24rpx;
  font-weight: 900;
}

.sheet-close-btn {
  width: 86rpx;
  min-width: 86rpx;
  max-width: 86rpx;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 24rpx;
  box-shadow: none;
  font-size: 22rpx;
  margin-left: auto;
}
