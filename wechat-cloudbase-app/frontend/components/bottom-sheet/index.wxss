@import "../../styles/theme.wxss";

view,
button,
text {
  box-sizing: border-box;
}

.sheet-layer {
  --sheet-bottom: calc(16rpx + env(safe-area-inset-bottom));
  --sheet-action-bottom-gap: 24rpx;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 80;
  pointer-events: none;
}

.sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  opacity: 0;
  background: rgba(36, 50, 74, 0.34);
  background: var(--improv-mask-overlay, rgba(36, 50, 74, 0.34));
  transition: opacity 0.2s ease;
  pointer-events: auto;
}

.sheet-mask.visible {
  opacity: 1;
}

.sheet-mask.mask-light {
  background: rgba(36, 50, 74, 0.24);
  background: var(--improv-mask-medium, rgba(36, 50, 74, 0.24));
}

.sheet-mask.mask-medium {
  background: rgba(36, 50, 74, 0.34);
  background: var(--improv-mask-overlay, rgba(36, 50, 74, 0.34));
}

.sheet-mask.mask-strong {
  background: rgba(18, 26, 44, 0.44);
  background: var(--improv-mask-solid, rgba(18, 26, 44, 0.44));
}

.sheet {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: var(--sheet-bottom);
  z-index: 1;
  display: flex;
  flex-direction: column;
  max-height: 78vh;
  overflow: hidden;
  padding: var(--improv-card-padding-md, 40rpx);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.96);
  background: var(--improv-sheet-bg, rgba(255, 255, 255, 0.96));
  box-shadow: 0 24rpx 60rpx rgba(27, 45, 87, 0.18);
  box-shadow: var(--improv-shadow-sheet, 0 24rpx 60rpx rgba(27, 45, 87, 0.18));
  transform: translateY(calc(100% + 40rpx));
  transition: transform 0.24s ease; /* bottom sheet slide up usually slightly longer than normal 0.2s */
  pointer-events: auto;
}

.sheet.sheet-with-actions {
  padding-bottom: 0;
}

.sheet-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  min-height: 0;
  max-height: 100%;
}

.sheet-scroll {
  width: 100%;
  flex: 1 1 auto;
  min-height: 0;
  height: calc(78vh - 160rpx);
  max-height: calc(78vh - 160rpx);
  box-sizing: border-box;
  padding-bottom: 12rpx;
  display: flex;
  flex-direction: column;
}

.sheet-scroll-static {
  width: 100%;
  flex: 0 0 auto;
  min-height: 0;
  max-height: calc(78vh - 160rpx);
  box-sizing: border-box;
  padding-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
  overflow-y: auto;
}

.sheet-actions {
  position: relative;
  z-index: 2;
  flex: 0 0 auto;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 14rpx;
  padding-bottom: var(--sheet-action-bottom-gap);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.76), #ffffff 38%);
  background: var(--improv-sheet-action-gradient, linear-gradient(180deg, rgba(255, 255, 255, 0.76), #ffffff 38%));
}

.sheet.sheet-with-actions .sheet-scroll {
  height: calc(78vh - 238rpx);
  max-height: calc(78vh - 238rpx);
  padding-bottom: 8rpx;
}

.sheet.sheet-with-actions .sheet-scroll-static {
  max-height: calc(78vh - 238rpx);
  padding-bottom: 8rpx;
}

.sheet.compact-sheet {
  max-height: 65vh;
}

.sheet.compact-sheet .sheet-scroll {
  height: calc(65vh - 150rpx);
  max-height: calc(65vh - 150rpx);
}

.sheet.task-sheet {
  max-height: 82vh;
}

.sheet.task-sheet .sheet-scroll {
  height: calc(82vh - 154rpx);
  max-height: calc(82vh - 154rpx);
  padding-bottom: 10rpx;
}

.sheet.task-sheet.sheet-with-actions .sheet-scroll {
  height: calc(82vh - 238rpx);
  max-height: calc(82vh - 238rpx);
}

.sheet.task-sheet.sheet-with-actions .sheet-scroll-static {
  max-height: calc(82vh - 238rpx);
}

.sheet.task-sheet .sheet-scroll-static {
  max-height: calc(82vh - 154rpx);
  padding-bottom: 10rpx;
  display: flex;
  flex-direction: column;
}

.sheet.path-sheet {
  bottom: var(--sheet-bottom);
  max-height: 72vh;
  background: var(--improv-sheet-bg, rgba(255, 255, 255, 0.98));
}

.sheet.path-sheet .sheet-content {
  max-height: calc(72vh - 40rpx);
  overflow: hidden;
}

.sheet.path-sheet .sheet-scroll {
  height: calc(72vh - 330rpx);
  max-height: calc(72vh - 330rpx);
  padding-bottom: 40rpx;
}

.sheet.path-sheet .sheet-scroll-static {
  max-height: calc(72vh - 330rpx);
  padding-bottom: 40rpx;
  overflow-y: auto;
}

.sheet.path-sheet .sheet-actions {
  padding-top: 10rpx;
  padding-bottom: var(--sheet-action-bottom-gap);
  background: var(--improv-sheet-action-gradient, linear-gradient(180deg, rgba(255, 255, 255, 0.76), #ffffff 38%));
}

.sheet.profile-edit-sheet-shell {
  max-height: 72vh;
  padding-bottom: 30rpx;
}

.sheet.profile-edit-sheet-shell.sheet-with-actions {
  padding-bottom: 0;
}

.sheet.profile-edit-sheet-shell .sheet-scroll-static {
  max-height: calc(72vh - 154rpx);
  padding-bottom: 0;
  display: flex;
  flex-direction: column;
}

.sheet.profile-edit-sheet-shell.sheet-with-actions .sheet-scroll-static {
  max-height: calc(72vh - 238rpx);
}

.sheet.full-sheet {
  max-height: 88vh;
}

.sheet.full-sheet .sheet-scroll {
  height: calc(88vh - 246rpx);
  max-height: calc(88vh - 246rpx);
}

.sheet.filter-sheet {
  left: 26rpx;
  right: 26rpx;
  bottom: var(--sheet-bottom);
  padding: var(--improv-card-padding-md, 40rpx);
  border-radius: 42rpx;
  background: #ffffff;
  background: var(--improv-card-strong, #ffffff);
  box-shadow: 0 36rpx 80rpx rgba(27, 45, 87, 0.24);
  box-shadow: var(--improv-shadow-floating, 0 36rpx 80rpx rgba(27, 45, 87, 0.24));
}

.sheet.filter-sheet .sheet-head {
  margin-bottom: 22rpx;
}

.sheet.filter-sheet .sheet-scroll-static {
  padding-bottom: 6rpx;
}

.sheet.tab-sheet {
  left: 24rpx;
  right: 24rpx;
  bottom: var(--sheet-bottom);
  border-radius: 44rpx;
}

.sheet.add-sheet {
  left: 24rpx;
  right: 24rpx;
  bottom: var(--sheet-bottom);
  padding: var(--improv-card-padding-md, 40rpx);
  border-radius: 44rpx;
  max-height: 82vh;
  background: var(--improv-sheet-bg, rgba(255, 255, 255, 0.96));
}

.sheet.add-sheet .sheet-scroll {
  height: calc(82vh - 254rpx);
  max-height: calc(82vh - 254rpx);
  padding-bottom: 18rpx;
}

.sheet.add-sheet .sheet-scroll-static {
  max-height: calc(82vh - 254rpx);
  padding-bottom: 18rpx;
  display: flex;
  flex-direction: column;
}

.sheet.add-sheet .sheet-actions {
  padding-top: 18rpx;
  padding-bottom: var(--sheet-action-bottom-gap);
  background: var(--improv-sheet-action-gradient, linear-gradient(180deg, rgba(255, 255, 255, 0.72), #ffffff 34%));
}

.sheet.mine-list-sheet,
.sheet.mine-detail-sheet {
  left: 24rpx;
  right: 24rpx;
  bottom: var(--sheet-bottom);
  padding: var(--improv-card-padding-md, 40rpx);
  border-radius: 44rpx;
  max-height: 72vh;
  background: var(--improv-bg-subtle, #f7f9fe);
}

.sheet.mine-list-sheet {
  text-align: left;
}

.sheet.mine-detail-sheet {
  padding-bottom: var(--improv-card-padding-md, 40rpx);
}

.sheet.mine-list-sheet .sheet-scroll,
.sheet.mine-detail-sheet .sheet-scroll {
  height: calc(72vh - 150rpx);
  max-height: calc(72vh - 150rpx);
}

.sheet.mine-list-sheet .sheet-scroll-static,
.sheet.mine-detail-sheet .sheet-scroll-static {
  max-height: calc(72vh - 150rpx);
  display: flex;
  flex-direction: column;
}

.sheet.mine-list-sheet .sheet-scroll-static {
  padding-bottom: 0;
}

.sheet.show {
  transform: translateY(0);
}

.handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #d7dfef;
  background: var(--improv-handle, #d7dfef);
}

.sheet-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.sheet-title {
  flex: 1 1 0;
  min-width: 0;
  color: #24324a;
  color: var(--improv-text, #24324a);
  font-size: 34rpx;
  font-weight: 900;
}

.small-btn {
  min-height: 58rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--improv-btn-tertiary-border, rgba(68, 108, 140, 0.08));
  border-radius: 999rpx;
  background: var(--improv-btn-tertiary-bg, rgba(239, 233, 214, 0.58));
  color: var(--improv-btn-tertiary-text, var(--improv-text-soft, #5a6781));
  font-size: 24rpx;
  font-weight: 900;
}
