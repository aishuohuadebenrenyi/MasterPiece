<root-portal wx:if="{{mounted}}">
  <view class="sheet-layer {{themeClass}}">
    <view class="sheet-mask mask-{{resolvedMaskVariant}} {{maskVisibleClass}} {{maskClass}}" catchtap="closeFromMask" catchtouchmove="noop"></view>
    <view class="sheet {{showClass}} {{sheetClass}} {{showActions ? 'sheet-with-actions' : ''}}" catchtap="noop">
      <view class="sheet-content">
        <view class="handle"></view>
        <view class="sheet-head">
          <text class="sheet-title">{{title}}</text>
          <button class="icon-close-btn" catchtap="close">✕</button>
        </view>
        <block wx:if="{{resolvedBodyMode === 'fit'}}">
          <view class="sheet-scroll-static">
            <slot></slot>
          </view>
        </block>
        <block wx:else>
          <scroll-view scroll-y enable-flex enhanced show-scrollbar="{{false}}" class="sheet-scroll">
            <slot></slot>
          </scroll-view>
        </block>
        <view wx:if="{{showActions}}" class="sheet-actions">
          <slot name="actions"></slot>
        </view>
      </view>
    </view>
  </view>
</root-portal>
