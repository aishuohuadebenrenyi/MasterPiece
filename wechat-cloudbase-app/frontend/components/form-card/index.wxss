@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
}

.form-card {
  padding: 38rpx 34rpx;
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.card-head-title {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.kicker {
  display: block;
  color: var(--improv-light-strong);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
  margin-bottom: 6rpx;
}

.title {
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.action-btn {
  flex: 0 0 auto;
  width: auto !important;
  min-width: 112rpx;
  max-width: 184rpx;
  min-height: 64rpx;
  padding: 0 20rpx !important;
  align-self: flex-start;
}

.card-body {
  display: flex;
  flex-direction: column;
}
