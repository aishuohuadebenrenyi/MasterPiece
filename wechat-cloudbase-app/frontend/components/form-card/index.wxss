@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
}

.form-card {
  padding: var(--improv-card-padding-md, 40rpx);
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.form-card-content-safe {
  padding-bottom: calc(var(--improv-card-padding-md, 40rpx) + 28rpx);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.card-head-title {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.kicker {
  margin-bottom: 0;
}

.title {
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.action-btn {
  flex: 0 0 auto;
  width: auto !important;
  min-width: 112rpx;
  max-width: 184rpx;
  min-height: 64rpx;
  padding: 0 20rpx !important;
  align-self: flex-start;
}

.card-body {
  width: 100%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-sizing: border-box;
}
