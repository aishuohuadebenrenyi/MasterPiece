@import '../../styles/theme.wxss';

.privacy-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--improv-mask-overlay, rgba(18, 20, 30, 0.5));
}

.privacy-dialog {
  position: relative;
  width: 600rpx;
  background: var(--improv-sheet-bg, var(--improv-card-strong, #ffffff));
  border: 2rpx solid var(--improv-line-soft, rgba(108, 118, 134, 0.1));
  border-radius: var(--improv-radius-xl, 40rpx);
  padding: 44rpx 40rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--improv-shadow-lg, 0 24rpx 80rpx rgba(34, 27, 20, 0.18));
}

.privacy-dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--improv-text, #1a1a2e);
  margin-bottom: 24rpx;
}

.privacy-dialog-desc {
  font-size: 26rpx;
  color: var(--improv-muted, #4a4a6a);
  line-height: 1.6;
  text-align: center;
}

.privacy-dialog-link {
  font-size: 26rpx;
  color: var(--improv-secondary, #2f6f93);
  text-decoration: underline;
}

.privacy-dialog-actions {
  display: flex;
  flex-direction: row;
  margin-top: 32rpx;
  width: 100%;
  gap: 24rpx;
}

.privacy-btn-refuse {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  text-align: center;
}

.privacy-btn-agree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  text-align: center;
}
