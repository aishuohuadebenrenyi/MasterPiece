@import '../../styles/theme.wxss';

.privacy-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.privacy-dialog {
  position: relative;
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.privacy-dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.privacy-dialog-desc {
  font-size: 26rpx;
  color: #4a4a6a;
  line-height: 1.6;
  text-align: center;
}

.privacy-dialog-link {
  font-size: 26rpx;
  color: var(--improv-primary, #ff7a45);
  text-decoration: underline;
}

.privacy-dialog-actions {
  display: flex;
  flex-direction: row;
  margin-top: 40rpx;
  width: 100%;
  gap: 24rpx;
}

.privacy-btn-refuse {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  background: #f4f6fb;
  color: #4a4a6a;
  border: none;
  text-align: center;
}

.privacy-btn-agree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  background: var(--improv-primary, #ff7a45);
  color: #ffffff;
  border: none;
  text-align: center;
}
