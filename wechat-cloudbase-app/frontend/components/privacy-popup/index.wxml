<view class="privacy-popup" wx:if="{{visible}}">
  <view class="privacy-mask" bindtap="onRefuse"></view>
  <view class="privacy-dialog">
    <text class="privacy-dialog-title">用户隐私保护提示</text>
    <text class="privacy-dialog-desc">在使用即兴工具箱服务之前，请仔细阅读</text>
    <text class="privacy-dialog-link" bindtap="openPrivacy">《即兴工具箱隐私政策》</text>
    <text class="privacy-dialog-desc">。如您同意，请点击"同意"开始使用。</text>
    <view class="privacy-dialog-actions">
      <button class="privacy-btn-refuse" bindtap="onRefuse">拒绝</button>
      <button class="privacy-btn-agree" id="agree-btn" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="onAgree">同意</button>
    </view>
  </view>
</view>
