@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
}

.game-form {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: var(--improv-form-gap-related, 28rpx);
}

.game-form-group {
  display: flex;
  flex-direction: column;
}

.primary-group {
  gap: var(--improv-form-gap-section, 36rpx);
}

.advanced-group {
  gap: var(--improv-form-gap-related, 24rpx);
}

.advanced-toggle-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0 4rpx;
  position: relative;
  z-index: 1;
}

.form-grid {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 8rpx;
}

.add-sheet-grid-item {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
}

.category-stack {
  display: flex;
  flex-direction: column;
  flex: 0 0 auto;
  gap: 34rpx;
  padding-top: 2rpx;
  padding-bottom: 12rpx;
}

.add-sheet-grid-item .input-shell {
  width: 100%;
}

.custom-category-chip.active {
  background: var(--improv-primary-wash);
  border: 2rpx solid var(--improv-primary);
  color: var(--improv-primary);
}

.custom-category-panel {
  margin-top: var(--improv-form-gap-inline, 16rpx);
  padding: 18rpx;
  border-radius: 24rpx;
  background: var(--improv-bg-subtle-glass);
  border: 2rpx solid var(--improv-neutral-line);
}

.custom-category-input {
  width: 100%;
}

.custom-category-input input {
  min-height: 72rpx;
}

.category-suggestions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: var(--improv-form-gap-inline, 16rpx);
  margin-top: var(--improv-form-gap-inline, 16rpx);
}

.category-suggestion {
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: var(--improv-card-strong);
  border: 2rpx solid var(--improv-blue-line-strong);
  color: var(--improv-secondary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.custom-category-confirm {
  width: 100%;
  min-height: 64rpx;
  margin-top: var(--improv-form-gap-inline, 16rpx);
  padding: 0;
  font-size: 24rpx;
}

.steps-toggle {
  min-width: 240rpx;
  min-height: 70rpx;
  margin: 0 !important;
  align-self: flex-start;
  padding: 0 40rpx;
  border-radius: 24rpx;
  background: var(--improv-card-muted);
  border: 2rpx solid var(--improv-neutral-line);
  color: var(--improv-muted);
  font-size: 26rpx;
  font-weight: 900;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
}

.steps-textarea {
  min-height: 180rpx;
}
