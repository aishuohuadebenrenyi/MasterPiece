@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
}

.game-form {
  display: flex;
  flex-direction: column;
}

.add-sheet-field {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 28rpx;
}

.add-sheet-section + .add-sheet-grid,
.category-field + .add-sheet-grid {
  margin-top: 30rpx;
}

.add-sheet-grid-item {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.category-chip {
  flex: 0 0 auto;
  margin: 0;
  min-width: 100rpx;
  min-height: 70rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  box-shadow: 0 8rpx 18rpx var(--improv-shadow-xs-color);
}

.custom-category-chip.active {
  background: var(--improv-primary-wash);
  border: 2rpx solid var(--improv-primary);
  color: var(--improv-primary);
}

.custom-category-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: var(--improv-bg-subtle-glass);
  border: 2rpx solid var(--improv-neutral-line);
}

.custom-category-input {
  width: 100%;
}

.custom-category-input input {
  min-height: 72rpx;
}

.category-suggestions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.category-suggestion {
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: var(--improv-card-strong);
  border: 2rpx solid var(--improv-blue-line-strong);
  color: var(--improv-secondary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.custom-category-confirm {
  width: 100%;
  min-height: 64rpx;
  margin-top: 12rpx;
  padding: 0;
  font-size: 24rpx;
}

.steps-toggle {
  min-width: 240rpx;
  min-height: 70rpx;
  margin: 36rpx 0 20rpx 0 !important;
  align-self: flex-start !important;
  padding: 0 40rpx;
  border-radius: 24rpx;
  background: var(--improv-card-muted);
  border: 2rpx solid var(--improv-neutral-line);
  color: var(--improv-muted);
  font-size: 26rpx;
  font-weight: 900;
  justify-content: center;
}

.steps-textarea {
  min-height: 180rpx;
}
