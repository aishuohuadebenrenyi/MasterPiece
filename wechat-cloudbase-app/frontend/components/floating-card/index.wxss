@import "../../app.wxss";
@import "../../styles/theme.wxss";

view,
button,
text {
  box-sizing: border-box;
}

.float-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  background: rgba(21, 31, 53, 0.34);
  background: var(--improv-floating-mask, rgba(21, 31, 53, 0.34));
}

.float-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 100;
}

.float-card {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  z-index: 110;
  height: 75vh;
  max-height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 80rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 48rpx 36rpx 38rpx;
  border-radius: 52rpx;
  transform: translateY(-50%);
}

.float-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  position: relative;
  min-height: 56rpx;
  padding-bottom: 4rpx;
}

.float-head .icon-close-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 28rpx;
  color: #96a1b4;
  color: var(--improv-light, #96a1b4);
  font-size: 28rpx;
  font-weight: 900;
}

.detail-nav-btn {
  flex: 0 0 156rpx;
  width: 156rpx;
  min-width: 156rpx;
  max-width: 156rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  background: var(--improv-card-soft, rgba(255, 255, 255, 0.72));
  color: #667289;
  color: var(--improv-muted, #667289);
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx var(--improv-shadow-soft-color, rgba(50, 68, 120, 0.08));
}

.detail-nav-count {
  flex: 1 1 auto;
  min-width: 96rpx;
  text-align: center;
}

.float-title {
  color: #24324a;
  color: var(--improv-text, #24324a);
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
}

.float-scroll {
  flex: 1 1 0;
  min-height: 0;
  margin-top: 26rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
