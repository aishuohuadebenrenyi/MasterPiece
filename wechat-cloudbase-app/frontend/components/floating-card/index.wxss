view,
button,
text {
  box-sizing: border-box;
}

.float-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(21, 31, 53, 0.28);
}

.float-card {
  position: fixed;
  left: 36rpx;
  right: 36rpx;
  top: 50%;
  z-index: 110;
  min-height: 430rpx;
  max-height: 66vh;
  overflow-y: auto;
  padding: 36rpx 28rpx 32rpx;
  border-radius: 48rpx;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.84)),
    linear-gradient(135deg, rgba(255, 122, 69, 0.12), rgba(79, 140, 255, 0.12));
  box-shadow: 0 36rpx 80rpx rgba(27, 45, 87, 0.24);
  transform: translateY(-50%) scale(0.98);
}

.float-head,
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.float-title {
  color: #24324a;
  font-size: 34rpx;
  font-weight: 900;
}

.detail-nav {
  margin-top: 24rpx;
  color: #96a1b4;
  font-size: 24rpx;
  font-weight: 900;
}

.small-btn {
  min-height: 58rpx;
  padding: 0 20rpx;
  border: 2rpx solid rgba(94, 114, 144, 0.14);
  border-radius: 999rpx;
  background: #fff;
  color: #667289;
  font-size: 24rpx;
  font-weight: 900;
}
