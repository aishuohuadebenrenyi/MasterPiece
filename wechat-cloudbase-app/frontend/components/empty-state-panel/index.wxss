@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.empty-state-panel {
  margin-bottom: 0;
}

.empty-state-kicker {
  align-self: flex-start;
  margin-bottom: 16rpx;
}

.state-panel-loading {
  background: var(--improv-card-light);
}

.state-panel-error {
  background: var(--improv-primary-tint);
  border-color: var(--improv-primary-soft);
}

.state-panel-notice {
  background: var(--improv-card);
}
