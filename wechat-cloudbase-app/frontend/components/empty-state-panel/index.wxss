@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.empty-state-panel {
  min-width: 0;
  margin-bottom: 0;
}

.empty-state-panel .empty-actions {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.empty-state-panel .empty-action-btn {
  flex: 1 1 0;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state-kicker {
  align-self: flex-start;
  margin-bottom: 16rpx;
}

.state-panel-loading {
  background: var(--improv-card-light);
}

.state-panel-error {
  background: var(--improv-primary-tint);
  border-color: var(--improv-primary-soft);
}

.state-panel-notice {
  background: var(--improv-card);
}
