<view class="detail-panel">
  <view class="detail-content-wrapper">
    <view class="detail-header-row" wx:if="{{badgeText || pending || canEdit}}">
      <view class="detail-top-tags" wx:if="{{badgeText || pending}}">
        <text wx:if="{{badgeText}}" class="pill {{badgeTone}}">{{badgeText}}</text>
        <text wx:if="{{pending}}" class="sync-pill">本地暂存</text>
      </view>
      <button wx:if="{{canEdit}}" class="mini-action-btn detail-edit-btn" catchtap="onEdit">编辑</button>
    </view>
    <view class="detail-middle">
      <view class="detail-title">{{title}}</view>
      <text class="muted detail-desc">{{desc}}</text>
    </view>
    <view class="detail-bottom-tags" wx:if="{{meta.length}}">
      <view class="meta-row detail-tags">
        <text wx:for="{{meta}}" wx:key="*this" class="meta-pill">{{item}}</text>
      </view>
    </view>
  </view>
  <view wx:if="{{canSediment}}" class="detail-action-block">
    <view wx:if="{{canMarkIntent}}" class="detail-action-row detail-intent-row">
      <view class="meta-pill detail-intent-chip {{selectedIntent === 'training' ? 'active' : ''}}" data-intent="training" catchtap="onMarkIntent">训练线索</view>
      <view class="meta-pill detail-intent-chip {{selectedIntent === 'rehearsal' ? 'active' : ''}}" data-intent="rehearsal" catchtap="onMarkIntent">排练线索</view>
    </view>
    <view class="detail-action-row">
      <button class="ghost-btn detail-discard-btn" bindtap="onDiscard">不再整理</button>
      <button class="primary-btn detail-action-btn" loading="{{loading}}" bindtap="onSediment">沉淀为方法卡</button>
    </view>
    <text class="detail-action-note">选择用途后，沉淀时一并保存；原记录始终保留。</text>
  </view>
</view>
