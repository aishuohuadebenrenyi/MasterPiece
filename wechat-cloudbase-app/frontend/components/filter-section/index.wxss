@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
}

.filter-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--improv-form-gap-field-body, 14rpx);
}

.filter-label {
  color: var(--improv-text);
  font-size: 28rpx;
  font-weight: 900;
}

.chip-scroll {
  height: 84rpx;
}

.chip-row {
  padding: 0 0 8rpx;
}

.filter-chip-track {
  display: inline-flex;
  width: auto;
  min-width: 100%;
  padding: 4rpx 0 2rpx;
  white-space: nowrap;
}

.filter-chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: var(--improv-form-gap-inline, 16rpx);
}

.filter-chip {
  flex: 0 0 auto;
  min-width: 88rpx;
  white-space: nowrap;
}
