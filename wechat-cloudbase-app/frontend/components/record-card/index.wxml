<view class="record-card-swipe {{swiped ? 'record-card-swipe-open' : ''}}" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <view wx:if="{{secondaryActionText}}" class="record-card-delete-reveal" catchtap="onDangerTap">{{secondaryActionText}}</view>
  <view class="record-card {{customClass}}" bindtap="onCardTap">
    <view class="record-card-action-btn record-card-action-top-right" wx:if="{{primaryActionText}}" catchtap="onActionTap">{{primaryActionText}}</view>
    <view class="record-card-header record-card-header-{{layoutKind}} {{primaryActionText ? 'has-action' : ''}}">
      <view class="record-card-top-tags" wx:if="{{badgeText || pending}}">
        <view wx:if="{{badgeText}}" class="pill {{badgeTone}}">{{badgeText}}</view>
        <view wx:if="{{pending}}" class="sync-pill">本地暂存</view>
      </view>
      <view wx:if="{{eyebrow}}" class="mini-title record-card-eyebrow">{{eyebrow}}</view>
    </view>
    <view class="record-card-body {{primaryActionText ? 'has-action' : ''}}">
      <view class="record-card-copy">
        <view class="section-title">{{title}}</view>
        <view wx:if="{{bodyText}}" class="muted record-card-body-text">{{bodyText}}</view>
      </view>
    </view>
    <view class="record-card-footer record-card-footer-{{layoutKind}}" wx:if="{{metaPills.length}}">
      <view class="meta-row record-card-meta-row" wx:if="{{metaPills.length}}">
        <view wx:for="{{metaPills}}" wx:key="*this" class="meta-pill">{{item}}</view>
      </view>
    </view>
  </view>
</view>
