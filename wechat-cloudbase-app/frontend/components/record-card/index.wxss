@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
  width: 100%;
  min-width: 0;
  --record-card-inset: var(--improv-card-padding-md, 40rpx);
  --record-card-action-width: 132rpx;
}

.record-card-swipe {
  position: relative;
  width: 100%;
  min-width: 0;
  border-radius: 40rpx;
  overflow: hidden;
}

.record-card-delete-reveal {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: var(--record-card-action-width);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0eb;
  color: #ff6a3d;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 900;
}

.record-card {
  --record-card-inset: var(--improv-card-padding-md, 40rpx);
  padding: var(--record-card-inset);
  display: block;
  position: relative;
  width: 100%;
  min-width: 0;
  border-radius: 40rpx;
  background: var(--improv-card-strong, #ffffff);
  border: 2rpx solid var(--improv-line-subtle, rgba(94, 114, 144, 0.08));
  box-shadow: var(--improv-shadow-md, 0 24rpx 56rpx rgba(55, 82, 150, 0.14));
  box-sizing: border-box;
  overflow: hidden;
  transform: translateX(0);
  transition: transform var(--improv-anim-normal) ease;
}

.record-card-swipe-open .record-card {
  transform: translateX(calc(-1 * var(--record-card-action-width)));
}

.record-card.mine-list-record-card {
  --record-card-inset: var(--improv-card-padding-md, 40rpx);
}

.record-card-header {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.record-card-header.has-action {
  padding-right: 140rpx;
}

.record-card-top-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.record-card-eyebrow {
  display: block;
  line-height: 1.2;
}

.record-card-top-tags + .record-card-eyebrow {
  margin-top: 12rpx;
}

.record-card-body {
  width: 100%;
  min-width: 0;
  margin-top: 14rpx;
  box-sizing: border-box;
}

.record-card-body.has-action {
  padding-right: 140rpx;
}

.record-card-copy {
  width: 100%;
  min-width: 0;
}

.record-card .section-title,
.record-card .muted,
.record-card .mini-title {
  max-width: 100%;
  overflow: hidden;
  word-break: break-all;
}

.record-card .section-title {
  display: block;
  line-height: 1.28;
  max-height: 82rpx;
}

.record-card-body-text {
  display: block;
  margin-top: 10rpx;
  line-height: 1.5 !important;
  max-height: 76rpx;
}

.record-card-footer {
  width: 100%;
  min-width: 0;
  margin-top: 20rpx;
  display: block;
}

.record-card-footer-history {
  padding-top: 4rpx;
}

.record-card-meta-row {
  margin-top: 0 !important;
  display: block;
  line-height: 0;
  margin-bottom: -12rpx;
}

.record-card-meta-row .meta-pill {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  line-height: 1;
  vertical-align: top;
}

.record-card-action-top-right {
  position: absolute;
  top: var(--record-card-inset);
  right: var(--record-card-inset);
  z-index: 10;
}

.record-card-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: var(--improv-btn-tertiary-bg);
  border: 2rpx solid var(--improv-btn-tertiary-border);
  color: var(--improv-btn-tertiary-text);
  box-shadow: var(--improv-btn-tertiary-shadow);
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
}
