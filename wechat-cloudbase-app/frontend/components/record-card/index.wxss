@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
}

.record-card {
  padding: var(--improv-card-padding-md, 40rpx);
  margin-bottom: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card-top-tags {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
}

.record-card-middle {
  width: 100%;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.record-card-bottom-tags {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  flex-wrap: wrap;
}

.record-card .meta-row {
  margin-top: 0;
  flex: 1 1 auto;
  display: flex;
  flex-wrap: nowrap;
  gap: 12rpx;
  overflow: hidden;
}

.record-card .meta-row .meta-pill {
  flex: 0 0 auto;
}

.record-card-bottom-tags .small-btn {
  flex: 0 0 112rpx;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 34rpx;
}
