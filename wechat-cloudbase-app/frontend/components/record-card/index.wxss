@import "../../app.wxss";
@import "../../styles/theme.wxss";

:host {
  display: block;
}

.record-card {
  padding: 36rpx;
  margin-bottom: 18rpx;
}

.record-card-main {
  flex: 1 1 0;
  min-width: 0;
}

.record-card-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
  align-self: flex-start;
}

.record-card-actions .small-btn {
  flex: 0 0 112rpx;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 34rpx;
}
