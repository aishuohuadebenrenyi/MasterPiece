@import "../styles/theme.wxss";

view,
button,
text {
  box-sizing: border-box;
}

.tabbar-shell {
  position: fixed;
  left: 36rpx;
  right: 36rpx;
  bottom: calc(10rpx + env(safe-area-inset-bottom));
  z-index: 70;
  width: auto;
  padding: 0;
  pointer-events: none;
  transition: transform var(--improv-anim-slow) cubic-bezier(0.4, 0, 0.2, 1), opacity var(--improv-anim-slow) cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
  opacity: 1;
}

.tabbar-shell.is-hidden {
  transform: translateY(150%);
  opacity: 0;
  pointer-events: none;
}

.tab-item::after {
  border: 0;
}

.tabbar {
  width: 100%;
  height: 104rpx;
  min-height: 104rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 40rpx;
  background: var(--improv-card-glass);
  border: 1px solid var(--improv-line-light);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: var(--improv-shadow-sm);
  pointer-events: auto;
  overflow: visible;
}

.tab-item {
  flex: 1 1 0;
  min-width: 0;
  width: 0;
  max-width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 44rpx;
  background: transparent;
  color: #96a1b4;
  color: var(--improv-light, #96a1b4);
  font-size: 22rpx;
  font-weight: 900;
}

.tab-item.active {
  background: transparent;
  color: #ff7a45;
  color: var(--improv-primary, #ff7a45);
  box-shadow: none;
  overflow: hidden;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-text {
  font-size: 23rpx;
  line-height: 1.1;
}
