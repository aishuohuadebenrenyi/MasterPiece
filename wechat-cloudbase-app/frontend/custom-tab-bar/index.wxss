@import "../styles/theme.wxss";

view,
button,
text {
  box-sizing: border-box;
}

.tabbar-shell {
  position: fixed;
  left: 36rpx;
  right: 36rpx;
  bottom: calc(10rpx + env(safe-area-inset-bottom));
  z-index: 70;
  width: auto;
  padding: 0;
  pointer-events: none;
  transition: transform var(--improv-anim-slow) cubic-bezier(0.4, 0, 0.2, 1), opacity var(--improv-anim-slow) cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
  opacity: 1;
}

.tabbar-shell.is-hidden {
  transform: translateY(150%);
  opacity: 0;
  pointer-events: none;
}

.tab-item::after {
  border: 0;
}

.tabbar {
  width: 100%;
  height: 104rpx;
  min-height: 104rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  background: var(--improv-card-frost, rgba(255, 255, 255, 0.94));
  border: 1px solid rgba(47, 111, 147, 0.12);
  border: 1px solid var(--improv-line-soft, rgba(47, 111, 147, 0.12));
  box-shadow: var(--improv-shadow-sm);
  pointer-events: auto;
  overflow: visible;
}

.tab-item {
  flex: 1 1 0;
  min-width: 0;
  width: 0;
  max-width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
  border-radius: 44rpx;
  background: transparent;
  color: #65717d;
  color: var(--improv-text-soft, #65717d);
  font-size: 26rpx;
  font-weight: 900;
}

.tab-item.active {
  background: #ffe6b8;
  background: var(--improv-primary-soft, #ffe6b8);
  color: #3a2a10;
  color: var(--improv-primary-warm, #3a2a10);
  border: 2rpx solid rgba(255, 159, 28, 0.26);
  border: 2rpx solid var(--improv-primary-wash-strong, rgba(255, 159, 28, 0.26));
  box-shadow: 0 12rpx 24rpx rgba(255, 159, 28, 0.14);
  box-shadow: 0 12rpx 24rpx var(--improv-shadow-primary-soft-color, rgba(255, 159, 28, 0.14));
  overflow: hidden;
}

.tab-text {
  font-size: 26rpx;
  line-height: 1;
}
