<view class="tabbar-shell {{themeClass}} {{hidden ? 'is-hidden' : ''}}">
  <view class="tabbar">
    <button wx:for="{{tabs}}" wx:key="pagePath" class="tab-item {{item.activeClass}}" data-index="{{index}}" bindtap="switchTab">
      <text class="tab-text">{{item.text}}</text>
    </button>
  </view>
</view>
