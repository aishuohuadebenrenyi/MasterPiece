<scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="page subpage-page detail" style="{{layoutStyle}}" wx:if="{{game}}">
  <view class="subpage-header detail-header-row safe-right">
    <view class="back" aria-label="返回" bindtap="back">←</view>
  </view>
  <view class="card header">
    <button wx:if="{{isCustomGame && !isEditMode}}" class="card-action-btn" bindtap="enterEditMode">编辑</button>
    <button wx:if="{{isEditMode}}" class="card-action-btn" bindtap="cancelEdit">取消</button>
    <view class="detail-heading">
      <text class="kicker">{{tagText}}</text>
      <view class="detail-title">{{game.title}}</view>
    </view>
    <text class="muted">{{game.lead}}</text>
    <view class="meta"><text wx:for="{{game.meta}}" wx:key="*this">{{item}}</text></view>
  </view>

  <block wx:if="{{!isEditMode}}">
    <view class="card block">
      <view class="block-title">玩法步骤</view>
      <view wx:for="{{game.steps}}" wx:key="*this" class="step">
        <text>{{index + 1}}</text>
        <text>{{item}}</text>
      </view>
    </view>

    <view class="card block">
      <view class="block-title">带领提示</view>
      <text class="muted">{{game.tips}}</text>
    </view>

    <view class="card block" wx:if="{{game.variant || game.issue}}">
      <view class="block-title">变体与翻车点</view>
      <text class="muted" wx:if="{{game.variant}}">{{game.variant}}</text>
      <text class="muted issue" wx:if="{{game.issue}}">{{game.issue}}</text>
    </view>

    <view class="card block" wx:if="{{related}}">
      <view class="row">
        <view class="block-title">相似游戏</view>
        <button class="small-btn" bindtap="openRelated">去看看</button>
      </view>
      <text class="muted">{{related.title}}：{{related.desc}}</text>
    </view>

    <view class="history-section" wx:if="{{historyCards && historyCards.length > 0}}">
      <view class="block-title" style="margin-bottom: 24rpx; padding: 0 8rpx;">历史复盘</view>
      <view wx:for="{{historyCards}}" wx:key="id" class="card history-card">
        <view class="row">
          <view class="card-title">{{item.title}}</view>
          <text class="muted">{{item.date}}</text>
        </view>
        <text class="muted">{{item.desc}}</text>
        <view class="meta" wx:if="{{item.meta && item.meta.length}}"><text wx:for="{{item.meta}}" wx:key="*this">{{item}}</text></view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="card block edit-form-block">
      <view class="field add-sheet-field">
        <text>游戏名称</text>
        <view class="input-voice-row">
          <view class="input-shell">
            <input value="{{editGame.title}}" data-field="title" placeholder="例如：情绪接力" bindblur="updateEditGame" bindconfirm="updateEditGame" />
          </view>
          <button class="voice-circle-btn" data-target="title" bindtap="voiceFill">语音</button>
        </view>
      </view>
      <view class="field add-sheet-field category-field add-sheet-section">
        <text>分类</text>
        <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}" style="margin-top: 14rpx;">
          <view class="chip-row">
            <button wx:for="{{categoryOptions}}" wx:key="value" class="chip category-chip {{item.activeClass}}" data-category="{{item.value}}" catchtap="toggleEditGameCategory">{{item.label}}</button>
            <button class="chip category-chip custom-category-chip {{customCategoryVisible ? 'active' : ''}}" catchtap="toggleCustomCategory">+ 自定义</button>
          </view>
        </scroll-view>
        <view wx:if="{{customCategoryVisible}}" class="custom-category-panel custom-category-block">
          <view class="input-shell custom-category-input">
            <input value="{{customCategoryInput}}" focus="{{customCategoryFocus}}" placeholder="输入或选择已有分类" bindinput="updateCustomCategory" bindfocus="handleCustomCategoryFocus" bindblur="handleCustomCategoryBlur" bindconfirm="confirmCustomCategory" />
          </view>
          <view wx:if="{{categorySuggestions.length}}" class="category-suggestions">
            <button wx:for="{{categorySuggestions}}" wx:key="value" class="category-suggestion" data-category="{{item.value}}" catchtap="selectCategorySuggestion">{{item.label}}</button>
          </view>
          <button class="ghost-btn custom-category-confirm" catchtap="confirmCustomCategory">添加分类</button>
        </view>
      </view>
      <view class="form-grid add-sheet-grid">
        <view class="field compact-field add-sheet-field add-sheet-grid-item">
          <text>适合人数</text>
          <view class="input-shell">
            <input value="{{editGame.people}}" data-field="people" placeholder="4-8 人" bindblur="updateEditGame" bindconfirm="updateEditGame" />
          </view>
        </view>
        <view class="field compact-field add-sheet-field add-sheet-grid-item">
          <text>时长</text>
          <view class="input-shell">
            <input value="{{editGame.duration}}" data-field="duration" placeholder="10 分钟" bindblur="updateEditGame" bindconfirm="updateEditGame" />
          </view>
        </view>
      </view>
      <view class="field add-sheet-field">
        <text>简短描述</text>
        <view class="textarea-voice-row">
          <view class="textarea-shell">
            <textarea value="{{editGame.desc}}" data-field="desc" placeholder="用一句话说清它适合什么时候玩" bindblur="updateEditGame"></textarea>
          </view>
          <button class="voice-circle-btn voice-circle-btn-bottom" data-target="desc" bindtap="voiceFill">语音</button>
        </view>
      </view>
      <button class="steps-toggle" catchtap="toggleMoreOptions">{{moreOptionsToggleText}}</button>
      <view wx:if="{{showMoreOptions}}" class="add-sheet-section">
        <view class="field add-sheet-field steps-field">
          <text>补充玩法步骤</text>
          <view class="textarea-voice-row">
            <view class="textarea-shell">
              <textarea value="{{editGame.steps}}" data-field="steps" placeholder="每行一步，例如：先围成一圈..." bindblur="updateEditGame"></textarea>
            </view>
            <button class="voice-circle-btn voice-circle-btn-bottom" data-target="steps" bindtap="voiceFill">语音</button>
          </view>
        </view>
        <view class="field add-sheet-field steps-field">
          <text>带领提示</text>
          <view class="textarea-voice-row">
            <view class="textarea-shell">
              <textarea value="{{editGame.tips}}" data-field="tips" placeholder="第一次带领时需要注意什么？" bindblur="updateEditGame"></textarea>
            </view>
            <button class="voice-circle-btn voice-circle-btn-bottom" data-target="tips" bindtap="voiceFill">语音</button>
          </view>
        </view>
        <view class="field add-sheet-field steps-field">
          <text>变体玩法</text>
          <view class="textarea-voice-row">
            <view class="textarea-shell">
              <textarea value="{{editGame.variant}}" data-field="variant" placeholder="这个游戏还有什么其他玩法？" bindblur="updateEditGame"></textarea>
            </view>
            <button class="voice-circle-btn voice-circle-btn-bottom" data-target="variant" bindtap="voiceFill">语音</button>
          </view>
        </view>
        <view class="field add-sheet-field steps-field">
          <text>可能翻车点</text>
          <view class="textarea-voice-row">
            <view class="textarea-shell">
              <textarea value="{{editGame.issue}}" data-field="issue" placeholder="大家最容易在哪个环节卡住？" bindblur="updateEditGame"></textarea>
            </view>
            <button class="voice-circle-btn voice-circle-btn-bottom" data-target="issue" bindtap="voiceFill">语音</button>
          </view>
        </view>
      </view>
    </view>
  </block>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}}"><text>{{appToastTitle}}</text></view>
  </root-portal>

  <root-portal>
    <view class="fixed-actions" wx:if="{{isEditMode}}">
      <button class="ghost-btn delete-btn" bindtap="confirmDelete">删除游戏</button>
      <button class="primary-btn add-submit-btn" bindtap="saveGame">保存修改</button>
    </view>
    <view class="fixed-actions" wx:else>
      <block wx:if="{{!currentGameSession}}">
        <button class="small-btn" bindtap="togglePlayed">{{playedText}}</button>
        <button class="small-btn" bindtap="toggleSaved">{{savedText}}</button>
        <button class="primary-btn" bindtap="startGame">开始游戏</button>
      </block>
      <block wx:else>
        <button class="ghost-btn" bindtap="pauseGame" wx:if="{{currentGameSession.status === '进行中'}}">暂停</button>
        <button class="ghost-btn" bindtap="resumeGame" wx:if="{{currentGameSession.status === '暂停中'}}">继续</button>
        <button class="primary-btn" bindtap="finishGame">结束并复盘</button>
      </block>
    </view>
  </root-portal>
</scroll-view>
