.detail {
  padding-bottom: 192rpx;
}

.back {
  margin-bottom: 24rpx;
}

.header,
.block {
  padding: 32rpx;
  margin-bottom: 22rpx;
}

.detail-title {
  margin: 8rpx 0 18rpx;
  color: #24324a;
  font-size: 44rpx;
  font-weight: 900;
}

.save {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #fff;
  color: #2f6ff2;
  box-shadow: 0 14rpx 32rpx rgba(50, 68, 120, 0.08);
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 18rpx 0;
}

.meta text {
  padding: 10rpx 18rpx;
  background: #f4f6fb;
  color: #667289;
  font-size: 24rpx;
  font-weight: 800;
}

.verdict {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fff8f4;
  color: #ff5b2e;
  font-size: 24rpx;
  font-weight: 900;
}

.block-title {
  margin-bottom: 20rpx;
  color: #24324a;
  font-size: 32rpx;
  font-weight: 900;
}

.step {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 18rpx;
  color: #667289;
  font-size: 26rpx;
  line-height: 1.6;
}

.step text:first-child {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #ffe4da;
  color: #ff5b2e;
  text-align: center;
  line-height: 52rpx;
  font-weight: 900;
}

.issue {
  display: block;
  margin-top: 16rpx;
}

.fixed-actions {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 40rpx rgba(50, 68, 120, 0.1);
}

.fixed-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.fixed-actions button:last-child {
  flex-grow: 1.25;
}
