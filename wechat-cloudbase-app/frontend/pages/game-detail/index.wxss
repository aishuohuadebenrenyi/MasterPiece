.detail {
  padding-bottom: 192rpx;
}

.back {
  margin-bottom: 24rpx;
}

.header,
.block {
  padding: 32rpx;
  margin-bottom: 22rpx;
}

.header {
  position: relative;
  padding-right: 168rpx;
}

.detail-heading {
  min-width: 0;
}

.detail-title {
  margin: 8rpx 0 18rpx;
  color: var(--improv-text);
  font-size: 44rpx;
  font-weight: 900;
}

.card-action-btn {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: auto !important;
  min-width: 120rpx;
  margin: 0;
  min-height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  background: var(--improv-bg-soft);
  color: var(--improv-secondary-strong);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 64rpx;
  z-index: 10;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 18rpx 0;
}

.meta text {
  padding: 10rpx 18rpx;
  background: var(--improv-bg-soft);
  color: var(--improv-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.verdict {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: var(--improv-primary-faint);
  color: var(--improv-primary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.block-title {
  margin-bottom: 20rpx;
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 900;
}

.step {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 18rpx;
  color: var(--improv-muted);
  font-size: 26rpx;
  line-height: 1.6;
}

.step text:first-child {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: var(--improv-primary-soft);
  color: var(--improv-primary-strong);
  text-align: center;
  line-height: 52rpx;
  font-weight: 900;
}

.issue {
  display: block;
  margin-top: 16rpx;
  color: #ff4d4f;
}

.fixed-actions {
  flex-direction: row;
  gap: 14rpx;
}

.fixed-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.fixed-actions button:last-child {
  flex-grow: 1.25;
}

.delete-btn {
  color: #ff4d4f;
  border-color: rgba(255, 77, 79, 0.2);
  background: rgba(255, 77, 79, 0.05);
}

/* 细节头部栏 */
.detail-header-row {
  flex-direction: row;
  align-items: center;
  margin-bottom: 28rpx;
}
.detail-header-row .back {
  margin-bottom: 0;
}

/* 更多操作菜单按钮 */
.more-action {
  display: none;
}

/* 复用添加/编辑游戏的表单样式 */
.compact-field {
  margin-top: 0;
}

.add-sheet-field {
  margin-top: 22rpx;
}

.add-sheet-field:first-child {
  margin-top: 4rpx;
}

.add-sheet-field > text {
  display: block;
}

.add-sheet-section + .add-sheet-grid,
.category-field + .add-sheet-grid {
  margin-top: 30rpx;
}

.add-sheet-grid-item {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.add-sheet-grid-item .input-shell {
  width: 100%;
}

.category-chip {
  flex: 0 0 auto;
  margin: 0;
  min-width: 100rpx;
  min-height: 70rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(50, 68, 120, 0.05);
  box-shadow: 0 8rpx 18rpx var(--improv-shadow-xs-color, rgba(50, 68, 120, 0.05));
}

.custom-category-chip {
  flex: 0 0 auto;
}

.custom-category-chip.active {
  background: var(--improv-primary-wash);
  border: 2rpx solid var(--improv-primary);
  color: var(--improv-primary);
}

.custom-category-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(247, 249, 253, 0.94);
  background: var(--improv-bg-subtle-glass, rgba(247, 249, 253, 0.94));
  border: 2rpx solid rgba(225, 231, 242, 0.82);
  border: 2rpx solid var(--improv-neutral-line, rgba(225, 231, 242, 0.82));
}

.custom-category-input input {
  min-height: 72rpx;
}

.category-suggestions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.category-suggestion {
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: var(--improv-card-strong);
  border: 2rpx solid var(--improv-blue-line-strong);
  color: var(--improv-secondary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.custom-category-confirm {
  width: 100%;
  min-height: 64rpx;
  margin-top: 12rpx;
  padding: 0;
  font-size: 24rpx;
}

.input-voice-row,
.textarea-voice-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 10rpx;
}

.textarea-voice-row {
  align-items: flex-end;
}

.input-shell,
.textarea-shell {
  flex: 1 1 auto;
  min-width: 0;
}

.add-sheet-field .input-shell input,
.add-sheet-field .textarea-shell textarea {
  width: 100%;
  margin-top: 0;
}

.textarea-shell textarea {
  width: 100%;
  height: 180rpx;
  background: transparent;
  color: var(--improv-text);
  font-size: 30rpx;
  line-height: 1.5;
}

.steps-field .textarea-shell textarea {
  height: auto;
  min-height: 180rpx;
  max-height: 360rpx;
}

.voice-circle-btn {
  flex: 0 0 86rpx;
  width: 86rpx;
  min-width: 86rpx;
  height: 86rpx;
  min-height: 86rpx;
  border-radius: 43rpx;
  background: rgba(255, 255, 255, 0.9);
  background: var(--improv-card-soft, rgba(255, 255, 255, 0.9));
  border: 1rpx solid rgba(121, 136, 168, 0.12);
  border: 1rpx solid var(--improv-overlay-line, rgba(121, 136, 168, 0.12));
  box-shadow: 0 10rpx 24rpx rgba(35, 52, 88, 0.08);
  box-shadow: 0 10rpx 24rpx var(--improv-shadow-panel-color, rgba(35, 52, 88, 0.08));
  color: #667289;
  color: var(--improv-muted, #667289);
  font-size: 24rpx;
  font-weight: 800;
}

.voice-circle-btn-bottom {
  margin-bottom: 2rpx;
}

.add-submit-btn {
  width: 100%;
  min-height: 88rpx;
  margin-top: 0;
  margin-bottom: 0;
  font-size: 32rpx;
}

.add-submit-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 0;
  padding: 0;
}

.add-sheet-spacer {
  height: 28rpx;
}

.steps-toggle {
  min-width: 240rpx;
  min-height: 70rpx;
  margin: 36rpx 0 20rpx 0 !important;
  align-self: flex-start !important;
  padding: 0 40rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.74);
  background: var(--improv-card-muted, rgba(255, 255, 255, 0.74));
  border: 2rpx solid rgba(225, 231, 242, 0.82);
  border: 2rpx solid var(--improv-neutral-line, rgba(225, 231, 242, 0.82));
  color: #667289;
  color: var(--improv-muted, #667289);
  font-size: 26rpx;
  font-weight: 900;
  justify-content: center;
}

.steps-field {
  margin-top: 24rpx;
}

.history-section {
  margin-top: 32rpx;
  padding-bottom: 240rpx;
}

.history-card {
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
