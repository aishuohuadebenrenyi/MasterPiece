<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <view class="subpage-header safe-right">
    <view class="back" aria-label="返回" bindtap="back">←</view>
    <text class="kicker">灵感记录</text>
    <view class="page-title">先把想法留下来</view>
  </view>

  <view class="card record-form-card">
    <view class="section-head">
      <view>
        <text class="mini-title">整理方式</text>
        <view class="section-title">先定下这条灵感的方向</view>
      </view>
    </view>
    <view class="form-chip-row">
      <button wx:for="{{arrangementOptions}}" wx:key="value" class="chip {{item.activeClass}}" data-value="{{item.value}}" bindtap="setArrangement">{{item.label}}</button>
    </view>
    <view class="form-chip-row tag-row-spaced">
      <button wx:for="{{tagOptions}}" wx:key="value" class="chip {{item.activeClass}}" data-value="{{item.value}}" bindtap="toggleTag">{{item.label}}</button>
    </view>
  </view>

  <view class="card record-form-card">
    <view class="card-head">
      <view>
        <text class="mini-title">语音 / 文字</text>
        <view class="section-title">灵感草稿</view>
      </view>
      <button class="small-btn" bindtap="openVoice">语音</button>
    </view>
    <label class="field">标题<input value="{{titleValue}}" data-field="titleValue" bindblur="updateField" bindconfirm="updateField" /></label>
    <label class="field">内容<textarea value="{{contentValue}}" data-field="contentValue" bindblur="updateField" /></label>
  </view>

  <view class="card record-form-card">
    <view class="section-head">
      <view>
        <text class="mini-title">可选关联</text>
        <view class="section-title">把灵感挂到游戏或排练里</view>
      </view>
    </view>
    <label class="field">关联游戏
      <view class="field-picker">
        <input value="{{linkedGame}}" placeholder="选择关联游戏" disabled />
        <button class="small-btn" data-kind="game" bindtap="openLink">选择</button>
      </view>
    </label>
    <label class="field">关联排练
      <view class="field-picker">
        <input value="{{linkedRehearsal}}" placeholder="可选，例如：开心即兴团 06.01 排练" disabled />
        <button class="small-btn" data-kind="rehearsal" bindtap="openLink">选择</button>
      </view>
    </label>
  </view>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" bindtap="openInsight">沉淀为方法卡</button>
      <button class="primary-btn" bindtap="save">保存灵感</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{voiceVisible}}" title="语音速记" bodyMode="fit" bind:close="closeSheet">
    <text class="muted">先说下来，整理可以稍后再做。</text>
    <view class="voice-pulse">00:36</view>
    <view class="card draft-preview">
      <text class="mini-title">最近语音草稿</text>
      <view class="entry-title sheet-title">{{draftTitle}}</view>
      <text class="muted">{{draftSummary}}</text>
    </view>
    <button class="primary-btn sheet-submit" bindtap="fillVoiceDraft">填入当前草稿</button>
  </bottom-sheet>

  <bottom-sheet visible="{{linkVisible}}" title="{{linkSheetTitle}}" bodyMode="fit" bind:close="closeSheet">
    <view wx:for="{{linkOptions}}" wx:key="value" class="card option-card">
      <view class="card-head">
        <view>
          <view class="entry-title">{{item.title}}</view>
          <text class="muted">{{item.desc}}</text>
        </view>
        <button class="small-btn" data-value="{{item.value}}" bindtap="chooseLink">选择</button>
      </view>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{insightVisible}}" title="个人沉淀" bodyMode="fit" bind:close="closeSheet">
    <view class="insight-list">
      <view class="card insight-card">
        <text class="pill orange">{{arrangementLabel}}</text>
        <view class="entry-title">{{titleValue}}</view>
        <text class="muted">新手场先用身体和声音统一节奏，再进入关系和叙事，会明显更顺。</text>
      </view>
      <view class="card insight-card">
        <text class="pill blue">游戏改造</text>
        <view class="entry-title">一句话交换身份只推进一个信息</view>
        <text class="muted">每轮只确认一个关系点，现场会更稳，也更容易接住。</text>
      </view>
    </view>
    <button class="primary-btn sheet-submit" bindtap="createMethodCard">保存为方法卡</button>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
