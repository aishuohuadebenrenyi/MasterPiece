<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page {{modalOpen ? 'modal-open' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <subpage-header kicker="灵感记录" title="先把想法留下来" bind:back="back" />

  <form-card title="先定下这条灵感的方向" kicker="整理方式">
    <view class="filter-section-stack">
      <filter-section label="整理方式" options="{{arrangementOptions}}" wrap="{{true}}" customClass="arrangement-section" rowClass="form-chip-row" bind:select="setArrangement" />
      <filter-section label="标签" options="{{tagOptions}}" wrap="{{true}}" customClass="tag-section" rowClass="form-chip-row tag-row-spaced" bind:select="toggleTag" />
    </view>
  </form-card>

  <form-card title="灵感草稿" kicker="文字记录">
    <view class="form-field-stack">
      <form-field label="标题">
        <input class="app-input" value="{{titleValue}}" data-field="titleValue" bindblur="updateField" bindconfirm="updateField" />
      </form-field>
      <form-field label="内容">
        <textarea class="app-textarea" value="{{contentValue}}" data-field="contentValue" bindblur="updateField" />
      </form-field>
    </view>
  </form-card>

  <form-card wx:if="{{showLinkSection}}" title="把灵感挂到素材或排练里" kicker="可选关联">
    <view class="form-field-stack">
      <form-field label="关联素材">
        <view class="field-picker">
          <input class="app-input" value="{{linkedMaterial}}" placeholder="选择关联素材" disabled />
          <button class="small-btn" data-kind="material" bindtap="openLink">选择</button>
        </view>
      </form-field>
      <form-field label="关联排练">
        <view class="field-picker">
          <input class="app-input" value="{{linkedRehearsal}}" placeholder="可选，例如：开心即兴团 06.01 排练" disabled />
          <button class="small-btn" data-kind="rehearsal" bindtap="openLink">选择</button>
        </view>
      </form-field>
    </view>
  </form-card>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" bindtap="openInsight">沉淀为方法卡</button>
      <button class="primary-btn" bindtap="save">保存灵感</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{linkVisible}}" title="{{linkSheetTitle}}" bodyMode="fit" bind:close="closeSheet">
    <empty-state-panel wx:if="{{!linkOptions.length}}" customClass="empty-link-card" title="{{linkEmptyTitle}}" desc="{{linkEmptyDesc}}" secondaryText="先不关联" bind:secondary="closeSheet" />
    <selection-card
      wx:for="{{linkOptions}}"
      wx:key="value"
      itemId="{{item.value}}"
      customClass="option-card"
      title="{{item.title}}"
      desc="{{item.desc}}"
      actionText="选择"
      bind:action="chooseLink"
      bind:tapcard="chooseLink"
    />
  </bottom-sheet>

  <bottom-sheet visible="{{insightVisible}}" title="个人沉淀" bodyMode="fit" closeOnMask="{{false}}" bind:close="closeSheet">
    <view class="insight-list">
      <view class="card insight-card">
        <text class="pill orange">{{arrangementLabel}}</text>
        <view class="entry-title">{{titleValue}}</view>
        <text class="muted">新手场先用身体和声音统一节奏，再进入关系和叙事，会明显更顺。</text>
      </view>
      <view class="card insight-card">
        <text class="pill blue">素材改造</text>
        <view class="entry-title">一句话交换身份只推进一个信息</view>
        <text class="muted">每轮只确认一个关系点，现场会更稳，也更容易接住。</text>
      </view>
    </view>
    <button class="primary-btn sheet-submit" bindtap="createMethodCard">保存为方法卡</button>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
