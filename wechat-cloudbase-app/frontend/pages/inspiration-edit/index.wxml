<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page {{modalOpen ? 'modal-open' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <subpage-header kicker="灵感记录" title="先把想法留下来" bind:back="back" />

  <form-card title="标签">
    <view class="filter-section-stack">
      <filter-section options="{{tagOptions}}" wrap="{{true}}" customClass="tag-section" rowClass="form-chip-row" bind:select="toggleTag" />
    </view>
  </form-card>

  <form-card contentSafe="{{true}}">
    <view class="form-field-stack">
      <form-field label="标题">
        <input class="app-input" value="{{titleValue}}" data-field="titleValue" bindblur="updateField" bindconfirm="updateField" />
      </form-field>
      <form-field label="内容">
        <textarea class="app-textarea" value="{{contentValue}}" data-field="contentValue" bindblur="updateField" />
      </form-field>
    </view>
  </form-card>

  <form-card wx:if="{{showLinkSection}}" title="关联" contentSafe="{{true}}">
    <view class="form-field-stack">
      <form-field label="素材">
        <view class="field-picker">
          <input class="app-input" value="{{linkedMaterial}}" placeholder="选择素材" disabled />
          <button class="small-btn" data-kind="material" bindtap="openLink">选择</button>
        </view>
      </form-field>
      <form-field label="排练">
        <view class="field-picker">
          <input class="app-input" value="{{linkedRehearsal}}" placeholder="选择排练（可选）" disabled />
          <button class="small-btn" data-kind="rehearsal" bindtap="openLink">选择</button>
        </view>
      </form-field>
    </view>
  </form-card>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" disabled="{{saving}}" bindtap="back">取消</button>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="save">保存修改</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{linkVisible}}" title="{{linkSheetTitle}}" bodyMode="fit" bind:close="closeSheet">
    <empty-state-panel wx:if="{{!linkOptions.length}}" customClass="empty-link-card" title="{{linkEmptyTitle}}" desc="{{linkEmptyDesc}}" secondaryText="先不关联" bind:secondary="closeSheet" />
    <selection-card
      wx:for="{{linkOptions}}"
      wx:key="value"
      itemId="{{item.value}}"
      customClass="option-card"
      title="{{item.title}}"
      desc="{{item.desc}}"
      actionText="选择"
      bind:action="chooseLink"
      bind:tapcard="chooseLink"
    />
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
