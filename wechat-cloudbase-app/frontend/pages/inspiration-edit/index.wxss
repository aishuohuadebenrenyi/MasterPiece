.back {
  margin-bottom: 24rpx;
}

.form-card {
  padding: 32rpx;
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 20rpx;
  color: #24324a;
  font-size: 32rpx;
  font-weight: 900;
}

.form-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 28rpx;
}

.form-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.field-picker {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.field-picker input {
  flex: 1;
}

.voice-pulse {
  width: 240rpx;
  height: 240rpx;
  margin: 24rpx auto;
  border-radius: 120rpx;
  background: linear-gradient(145deg, #4f8cff, #ff7a45);
  color: #fff;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 240rpx;
  text-align: center;
}

.sheet-submit {
  width: 100%;
  margin-top: 24rpx;
}

.option-card,
.insight-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.insight-list .entry-title {
  margin: 14rpx 0 10rpx;
  color: #24324a;
  font-size: 34rpx;
  font-weight: 900;
}
