.subpage-header {
  margin-bottom: 14rpx;
}

.subpage-page {
  padding-bottom: var(--fixed-action-spacer);
}

.subpage-header .back {
  margin-bottom: 12rpx;
}

.page-title,
.section-title,
.entry-title {
  color: var(--improv-text);
  font-weight: 900;
}

.page-title {
  font-size: 56rpx;
  line-height: 1.1;
}

.record-form-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.section-head {
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 32rpx;
}

.form-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 20rpx;
}

.form-actions button {
  flex: 0 1 268rpx;
  min-width: 0;
  max-width: 268rpx;
}

.field-picker {
  width: 100%;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.field-picker .app-input {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  max-width: 100%;
}

.field-picker .small-btn {
  flex: 0 0 132rpx;
  width: 132rpx;
  min-width: 132rpx;
  padding: 0 12rpx;
}

.form-field-stack {
  width: 100%;
  min-width: 0;
}

.form-field-stack form-field,
.form-field-stack .app-input,
.form-field-stack .app-textarea {
  display: block;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
}

.form-field-stack .app-textarea {
  height: 220rpx;
  min-height: 220rpx;
  max-height: 220rpx;
  overflow: auto;
}

.filter-section-stack {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.entry-title {
  margin: 12rpx 0 8rpx;
  font-size: 34rpx;
}

.option-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.empty-link-card {
  padding: 28rpx;
  margin-top: 12rpx;
}

.empty-link-card .muted {
  display: block;
  margin-top: 8rpx;
  line-height: 1.6;
}
