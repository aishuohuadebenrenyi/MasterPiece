.page-title {
  margin-bottom: 0;
}

.feedback {
  padding-bottom: calc(var(--fixed-action-spacer) + 72rpx);
}

.feedback-object-summary {
  display: flex;
  flex-direction: column;
}

.feedback-object-title {
  color: var(--improv-text);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.18;
}

.feedback-object-desc {
  display: block;
  margin-top: 12rpx;
  line-height: 1.62;
}

.feedback-object-meta {
  margin-top: 18rpx;
}

.context-chip-row,
.effect-chip-row {
  flex-wrap: wrap;
  row-gap: 16rpx;
}

.context-chip-row .chip,
.effect-chip-row .chip {
  flex: 0 0 auto;
  width: auto;
  min-height: 64rpx;
  padding: 0 24rpx;
}

.effect-chip-row .chip {
  min-width: 132rpx;
}

.feedback-section {
  margin-top: 26rpx;
}

.context-inline-section {
  margin-top: 8rpx;
}

.feedback-section-title {
  display: block;
  color: var(--improv-light-strong);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.4rpx;
  margin-bottom: 14rpx;
}

.feedback-status-card {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: var(--improv-bg-subtle);
}

.context-status-card {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
}

.feedback-status-title {
  display: block;
  color: var(--improv-text);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.45;
}

.feedback-helper {
  display: block;
  margin-top: 8rpx;
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.feedback-field-stack {
  margin-top: 30rpx;
}

.action-stack {
  position: fixed;
  left: 34rpx;
  right: 34rpx;
  bottom: var(--fixed-action-bottom);
  z-index: 30;
  padding: var(--fixed-action-padding);
  border-radius: 44rpx;
  background: var(--improv-card);
  box-shadow: 0 18rpx 42rpx var(--improv-shadow-fixed-color);
  backdrop-filter: blur(16rpx);
}

.action-note {
  display: block;
  margin: 0 10rpx 12rpx;
  color: var(--improv-muted);
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.form-actions,
.save-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 20rpx;
}

.form-actions {
  position: static;
  left: auto;
  right: auto;
  bottom: auto;
  z-index: auto;
  margin-top: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  backdrop-filter: none;
  flex-direction: row;
  gap: 20rpx;
}

.form-actions button,
.save-actions button {
  flex: 0 1 268rpx;
  min-width: 0;
  max-width: 268rpx;
}

.save-actions {
  width: 84%;
  margin: 24rpx auto 0;
}

.more-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 34rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: var(--improv-bg-subtle);
}

.more-toggle .muted {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.more-arrow {
  flex: 0 0 auto;
  color: var(--improv-secondary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.more-fields {
  margin-top: 20rpx;
  padding-bottom: 12rpx;
}

.field-static {
  margin-top: 10rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: var(--improv-bg-subtle);
  color: var(--improv-text);
  font-size: 28rpx;
  font-weight: 800;
}
