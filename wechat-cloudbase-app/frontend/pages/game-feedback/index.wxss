.page-title {
  margin-bottom: 0;
}

.feedback {
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
}

.record-form-card {
  padding: 38rpx 34rpx;
  margin-bottom: 32rpx;
}

.compact-card {
  padding-bottom: 34rpx;
}

.section-head {
  margin-bottom: 14rpx;
}

.form-actions,
.save-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 20rpx;
}

.form-actions {
  flex-direction: row;
  gap: 20rpx;
}

.form-actions button,
.save-actions button {
  flex: 0 1 268rpx;
  min-width: 0;
  max-width: 268rpx;
}

.save-actions {
  width: 84%;
  margin: 24rpx auto 0;
}

.option-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.insight-title {
  margin: 14rpx 0 10rpx;
}

.sheet-submit {
  width: 100%;
  margin-top: 24rpx;
}

.more-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 28rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: var(--improv-bg-subtle);
}

.more-toggle .muted {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.more-arrow {
  flex: 0 0 auto;
  color: var(--improv-secondary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.more-fields {
  margin-top: 12rpx;
}

.field-static {
  margin-top: 10rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: var(--improv-bg-subtle);
  color: var(--improv-text);
  font-size: 28rpx;
  font-weight: 800;
}
