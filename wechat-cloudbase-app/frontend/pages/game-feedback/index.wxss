.page-title,
.section-title {
  margin-bottom: 20rpx;
  color: var(--improv-text);
  font-weight: 900;
}

.page-title {
  margin-bottom: 0;
  font-size: 56rpx;
  line-height: 1.1;
}

.feedback {
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
}

.record-form-card {
  padding: 38rpx 34rpx;
  margin-bottom: 28rpx;
}

.compact-card {
  padding-bottom: 34rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta text {
  padding: 10rpx 18rpx;
  background: var(--improv-bg-soft);
  color: var(--improv-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.form-actions,
.save-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.form-actions {
  flex-direction: row;
  gap: 20rpx;
}

.form-actions button,
.save-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.save-actions {
  width: 84%;
  margin: 24rpx auto 0;
}

.option-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.insight-title {
  margin: 14rpx 0 10rpx;
}

.sheet-submit {
  width: 100%;
  margin-top: 24rpx;
}

.more-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 28rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: var(--improv-bg-subtle);
}

.more-toggle .muted {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.more-arrow {
  flex: 0 0 auto;
  color: var(--improv-secondary-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.more-fields {
  margin-top: 4rpx;
}
