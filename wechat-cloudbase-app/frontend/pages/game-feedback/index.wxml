<view class="page feedback" wx:if="{{game}}">
  <view class="safe-right">
    <button class="back" bindtap="back">← 返回</button>
    <text class="kicker">游戏实践反馈</text>
    <view class="title">{{game.title}}</view>
  </view>

  <view class="card form-card">
    <view class="row">
      <view>
        <text class="mini-title">本次记录对象</text>
        <view class="section-title">{{game.title}}</view>
      </view>
      <button class="small-btn" bindtap="openVoice">语音</button>
    </view>
    <text class="muted">{{game.desc}}</text>
    <view class="meta"><text wx:for="{{game.meta}}" wx:key="*this">{{item}}</text></view>
  </view>

  <view class="card form-card">
    <view class="section-title">这次在哪玩？</view>
    <view class="tag-row">
      <button class="chip active">单独记录</button>
      <button class="chip">加入当前排练</button>
      <button class="chip">新建排练</button>
    </view>
    <label class="field">人数<input value="8 人" /></label>
    <label class="field">关联排练 / 场景
      <view class="field-picker">
        <input value="{{linkedRehearsal}}" disabled />
        <button class="small-btn" bindtap="openLink">选择</button>
      </view>
    </label>
  </view>

  <view class="card form-card">
    <view class="section-title">效果反馈</view>
    <view class="tag-row">
      <button class="chip active">很有效</button>
      <button class="chip">一般</button>
      <button class="chip">不适合</button>
    </view>
    <label class="field">Keep<textarea value="大家进入状态很快，注意力明显集中。" /></label>
    <label class="field">Try<textarea value="口令可以少一点，给参与者更多感受空间。" /></label>
    <label class="field">下次提醒<input value="先走身体，再叠加关系规则。" /></label>
  </view>

  <view class="form-actions">
    <button class="ghost-btn" bindtap="back">保存并返回</button>
    <button class="primary-btn" bindtap="openConfirm">保存反馈</button>
  </view>

  <bottom-sheet visible="{{recordVisible}}" title="记录确认" bind:close="closeSheet">
    <label class="field">记录类型<input value="{{recordType}}" /></label>
    <label class="field">关联游戏<input value="{{game.title}}" /></label>
    <label class="field">关联排练<input value="{{linkedRehearsal}}" /></label>
    <label class="field">Keep / Try<textarea value="Keep：大家进入状态很快。Try：下一轮口令少一点，让感受多一点。" /></label>
    <view class="center-actions">
      <button class="ghost-btn" bindtap="createMethodCard">沉淀为方法卡</button>
      <button class="primary-btn" bindtap="saveRecord">保存记录</button>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{linkVisible}}" title="选择关联" bind:close="closeSheet">
    <view wx:for="{{linkOptions}}" wx:key="value" class="card option-card">
      <view class="row">
        <view>
          <view class="section-title">{{item.title}}</view>
          <text class="muted">{{item.desc}}</text>
        </view>
        <button class="small-btn" data-value="{{item.value}}" bindtap="chooseLink">选择</button>
      </view>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{insightVisible}}" title="个人沉淀" bind:close="closeSheet">
    <view class="card option-card">
      <text class="pill orange">带领提醒</text>
      <view class="section-title insight-title">{{game.title}}的带领提醒</view>
      <text class="muted">下一轮口令少一点，让感受多一点。</text>
    </view>
    <button class="primary-btn sheet-submit" bindtap="saveMethodCard">保存为方法卡</button>
  </bottom-sheet>
</view>
