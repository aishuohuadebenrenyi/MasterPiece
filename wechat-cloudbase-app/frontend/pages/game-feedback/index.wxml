<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page feedback {{modalOpen ? 'modal-open' : ''}} {{themeClass}}" style="{{layoutStyle}}" wx:if="{{game}}">
  <subpage-header kicker="{{duration > 0 ? '本次游戏时长：' + durationText : '游戏实践反馈'}}" title="{{game.title}}" bind:back="back" />

  <form-card title="{{game.title}}" kicker="本次记录对象" actionText="语音" bind:action="openVoice">
    <text class="muted">{{game.desc}}</text>
    <view class="meta-row"><text wx:for="{{game.meta}}" wx:key="*this" class="meta-pill">{{item}}</text></view>
  </form-card>

  <form-card title="这次在哪玩？" kicker="归属场景" class="compact-card">
    <view class="choice-section">
      <view class="form-chip-row">
        <button wx:for="{{contextOptions}}" wx:key="value" class="chip compact-filter-chip {{item.activeClass}}" data-value="{{item.value}}" bindtap="setContextType">{{item.label}}</button>
      </view>
    </view>
  </form-card>

  <form-card title="记录本次 Keep / Try" kicker="效果反馈">
    <view class="choice-section">
      <view class="form-chip-row">
        <button wx:for="{{effectOptions}}" wx:key="value" class="chip compact-filter-chip {{item.activeClass}}" data-value="{{item.value}}" bindtap="setEffect">{{item.label}}</button>
      </view>
    </view>
    <view class="form-field-stack">
      <form-field label="Keep">
        <textarea class="app-textarea" value="{{keepValue}}" data-field="keepValue" bindblur="updateField" />
      </form-field>
      <form-field label="Try">
        <textarea class="app-textarea" value="{{tryValue}}" data-field="tryValue" bindblur="updateField" />
      </form-field>
    </view>
    <view class="more-toggle" bindtap="toggleMore">
      <view>
        <text class="mini-title">更多信息</text>
        <text class="muted">人数、关联排练和下次提醒可以稍后补。</text>
      </view>
      <text class="more-arrow">{{moreVisible ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{moreVisible}}" class="more-fields">
      <view class="form-field-stack">
        <form-field label="人数">
          <input class="app-input" value="{{attendanceText}}" data-field="attendanceText" bindblur="updateField" />
        </form-field>
        <form-field label="当前归属场景">
          <view class="field-static">{{linkedRehearsal}}</view>
        </form-field>
        <form-field label="下次提醒">
          <input class="app-input" value="{{reminderValue}}" data-field="reminderValue" bindblur="updateField" />
        </form-field>
      </view>
    </view>
  </form-card>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" bindtap="openInsight">沉淀为方法卡</button>
      <button class="primary-btn" bindtap="saveRecord">保存记录</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{insightVisible}}" title="个人沉淀" bodyMode="fit" bind:close="closeSheet">
    <view class="card insight-card">
      <text class="pill orange">游戏实践</text>
      <view class="section-title insight-title">{{game.title}}的反馈</view>
      <text class="muted">Keep: {{keepValue || '无'}}\nTry: {{tryValue || '无'}}{{reminderValue ? '\n提醒: ' + reminderValue : ''}}</text>
    </view>
    <button class="primary-btn sheet-submit" bindtap="saveMethodCard">保存为方法卡</button>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
