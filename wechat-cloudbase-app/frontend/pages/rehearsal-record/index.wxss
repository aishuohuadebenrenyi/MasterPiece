.subpage-header {
  margin-bottom: 14rpx;
}

.rehearsal {
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
}

.subpage-header .back {
  margin-bottom: 12rpx;
}

.record-form-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.card-head .small-btn {
  width: 128rpx;
  min-width: 128rpx;
  max-width: 128rpx;
  min-height: 56rpx;
}

.game-title {
  font-size: 32rpx;
  color: var(--improv-text);
  font-weight: 900;
}

.option-card {
  padding: 28rpx;
  margin-top: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 92rpx;
  margin: 12rpx 0 8rpx;
  padding: 0 28rpx;
  border-radius: 46rpx;
  background: var(--improv-bg-subtle);
  color: var(--improv-secondary-strong);
  font-size: 28rpx;
  font-weight: 900;
}

.search-bar input {
  flex: 1;
  color: var(--improv-text);
  font-size: 28rpx;
  font-weight: 800;
}

.index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: var(--improv-secondary-soft);
  color: var(--improv-secondary-strong);
  text-align: center;
  line-height: 56rpx;
  font-weight: 900;
}

.rehearsal-game {
  padding: 28rpx;
  margin-top: 24rpx;
}

.plan-empty-card,
.add-empty-card {
  padding: 28rpx;
  margin-top: 24rpx;
}

.plan-empty-card .muted,
.add-empty-card .muted {
  display: block;
  margin-top: 10rpx;
  line-height: 1.6;
}

.plan-empty-btn {
  width: 280rpx;
  max-width: 72%;
  margin-top: 24rpx;
}

.plan-item {
  display: flex;
  flex-direction: row;
  gap: 18rpx;
  align-items: center;
}

.plan-main {
  flex: 1;
  min-width: 0;
}

.plan-item .small-btn {
  flex: 0 0 112rpx;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  min-height: 56rpx;
  padding: 0;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.status-btn {
  flex: 0 0 176rpx;
  width: 176rpx;
  min-width: 176rpx;
  max-width: 176rpx;
  min-height: 58rpx;
  padding: 0;
  background: var(--improv-secondary-soft);
  color: var(--improv-secondary-strong);
}

.status-row .pill {
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 0 22rpx;
}

.quick-feedback {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.form-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 20rpx;
}

.quick-feedback label {
  flex: 1 1 0;
  min-width: 0;
}

.form-actions button {
  flex: 0 1 268rpx;
  min-width: 0;
  max-width: 268rpx;
}

.plan-sheet-summary {
  padding: 28rpx;
  margin-top: 8rpx;
}

.plan-submit {
  width: 320rpx;
  max-width: 72%;
  margin: 24rpx auto 0;
  align-self: center;
}

.inspiration-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.inspiration-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
