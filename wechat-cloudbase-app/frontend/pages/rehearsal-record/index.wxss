.back {
  margin-bottom: 24rpx;
}

.form-card {
  padding: 32rpx;
  margin-top: 24rpx;
}

.section-title,
.game-title {
  color: #24324a;
  font-size: 32rpx;
  font-weight: 900;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta text {
  padding: 10rpx 18rpx;
  background: #f4f6fb;
  color: #667289;
  font-size: 24rpx;
  font-weight: 800;
}

.game-row,
.option-card {
  padding: 28rpx;
  margin-top: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 92rpx;
  margin: 12rpx 0 8rpx;
  padding: 0 28rpx;
  border-radius: 46rpx;
  background: #f6f8fd;
  color: #2f6ff2;
  font-size: 28rpx;
  font-weight: 900;
}

.search-bar input {
  flex: 1;
  color: #24324a;
  font-size: 28rpx;
  font-weight: 800;
}

.index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e8f0ff;
  color: #2f6ff2;
  text-align: center;
  line-height: 56rpx;
  font-weight: 900;
}

.grow {
  flex: 1;
  min-width: 0;
}

.status-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.status-btn {
  background: #e8f0ff;
  color: #2f6ff2;
}

.quick-feedback {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.form-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 28rpx;
}

.quick-feedback label,
.form-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.plan-submit {
  width: 100%;
  margin-top: 24rpx;
}
