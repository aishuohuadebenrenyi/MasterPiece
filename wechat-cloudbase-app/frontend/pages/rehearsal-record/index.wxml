<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page rehearsal {{modalOpen ? 'modal-open' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <subpage-header kicker="排练记录" title="{{title}}" bind:back="back" />

  <form-card title="今晚排练 · {{duration}} 分钟" kicker="本次排练" actionText="编辑" bind:action="openPlan">
    <text class="muted">目标：{{desc}}</text>
    <view class="meta-row"><text class="meta-pill">{{metaText}}</text></view>
  </form-card>

  <form-card title="素材计划与反馈" kicker="素材计划" actionText="加素材" bind:action="openAdd">
    <empty-state-panel wx:if="{{!planMaterials.length}}" customClass="plan-empty-card" title="先加几个这次想练的素材" desc="没有计划时，不需要先把页面填满。先加入 1-3 条素材，排练会更容易开始。" primaryText="加素材" bind:primary="openAdd" />
    <view wx:for="{{planMaterials}}" wx:key="id" class="card rehearsal-material">
      <view class="plan-item">
        <view class="index">{{index + 1}}</view>
        <view class="plan-main">
          <view class="material-title">{{item.title}}</view>
          <text class="muted">{{item.metaText}} · {{item.tagText}}</text>
        </view>
        <button class="small-btn" data-id="{{item.id}}" bindtap="openMaterial">详情</button>
      </view>
      <view class="status-row">
        <button class="small-btn status-btn" data-id="{{item.id}}" bindtap="toggleStatus">{{item.status}}</button>
        <text class="pill orange">Keep / Try</text>
      </view>
      <view class="quick-feedback">
        <form-field label="Keep">
          <input class="app-input" placeholder="有效的瞬间" value="{{item.keepValue}}" data-id="{{item.id}}" data-field="keep" bindblur="updatePlanField" />
        </form-field>
        <form-field label="Try">
          <input class="app-input" placeholder="下次调整" value="{{item.tryValue}}" data-id="{{item.id}}" data-field="try" bindblur="updatePlanField" />
        </form-field>
      </view>
    </view>
  </form-card>

  <view class="section" wx:if="{{linkedInspirations.length > 0}}">
    <view class="section-title">
      <text>速记与灵感 ({{linkedInspirations.length}})</text>
    </view>
    <view class="inspiration-list">
      <view wx:for="{{linkedInspirations}}" wx:key="id" class="card inspiration-card">
        <view class="card-title">{{item.title}}</view>
        <text class="muted">{{item.desc}}</text>
        <view class="meta-row"><text wx:for="{{item.meta}}" wx:key="*this" class="meta-pill">{{item}}</text></view>
      </view>
    </view>
  </view>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" bindtap="pause">暂停排练</button>
      <button class="primary-btn" bindtap="review">结束并复盘</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{addVisible}}" title="添加到排练" closeOnMask="{{false}}" bind:close="closeSheet">
    <search-bar value="{{query}}" placeholder="搜索素材、能力或目标" showClear="{{true}}" bind:blur="searchMaterial" bind:confirm="searchMaterial" bind:clear="clearAddSearch" />
    <empty-state-panel wx:if="{{!filteredMaterials.length}}" customClass="add-empty-card" title="{{addEmptyTitle}}" desc="{{addEmptyDesc}}" primaryText="{{query ? '' : '去发现页添加'}}" secondaryText="{{query ? '清空搜索' : ''}}" bind:primary="goDiscover" bind:secondary="clearAddSearch" />
    <selection-card
      wx:for="{{filteredMaterials}}"
      wx:key="id"
      itemId="{{item.id}}"
      customClass="option-card"
      title="{{item.title}}"
      desc="{{item.desc}}"
      meta="{{item.meta}}"
      actionText="加入"
      bind:tapcard="addMaterial"
      bind:action="addMaterial"
    />
  </bottom-sheet>

  <bottom-sheet visible="{{planVisible}}" title="调整排练计划" closeOnMask="{{false}}" bind:close="closeSheet">
    <view class="card plan-sheet-summary">
      <text class="mini-title">当前排练</text>
      <view class="section-title">{{title}} · {{duration}} 分钟</view>
      <text class="muted">{{desc}}</text>
    </view>
    <empty-state-panel wx:if="{{!planMaterials.length}}" customClass="add-empty-card" title="当前还没有排练计划" desc="先去添加素材，回来后再调整顺序和状态。" primaryText="加素材" bind:primary="openAdd" />
    <selection-card
      wx:for="{{planMaterials}}"
      wx:key="id"
      itemId="{{item.id}}"
      customClass="option-card"
      title="{{index + 1}}. {{item.title}}"
      desc="{{item.status}} · {{item.metaText}} · {{item.tagText}}"
      actionText="切换状态"
      bind:action="toggleStatus"
    />
    <button class="primary-btn plan-submit" bindtap="savePlan">保存计划</button>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
