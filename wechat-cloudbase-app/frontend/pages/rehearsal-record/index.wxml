<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page rehearsal {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <view class="subpage-header safe-right">
    <view class="back" aria-label="返回" bindtap="back">←</view>
    <text class="kicker">排练记录</text>
    <view class="page-title">{{title}}</view>
  </view>

  <view class="card record-form-card">
    <view class="card-head">
      <view>
        <text class="mini-title">本次排练</text>
        <view class="section-title">今晚排练 · {{duration}} 分钟</view>
        <text class="muted">目标：{{desc}}</text>
      </view>
      <button class="small-btn" bindtap="openPlan">编辑</button>
    </view>
    <view class="meta"><text>{{metaText}}</text></view>
  </view>

  <view class="card record-form-card">
    <view class="card-head">
      <view>
        <text class="mini-title">游戏计划</text>
        <view class="section-title">游戏计划与反馈</view>
      </view>
      <button class="small-btn" bindtap="openAdd">加游戏</button>
    </view>
    <view wx:for="{{planGames}}" wx:key="id" class="card rehearsal-game">
      <view class="plan-item">
        <view class="index">{{index + 1}}</view>
        <view class="plan-main">
          <view class="game-title">{{item.title}}</view>
          <text class="muted">{{item.metaText}} · {{item.tagText}}</text>
        </view>
        <button class="small-btn" data-id="{{item.id}}" bindtap="openGame">详情</button>
      </view>
      <view class="status-row">
        <button class="small-btn status-btn" data-id="{{item.id}}" bindtap="toggleStatus">{{item.status}}</button>
        <text class="pill orange">Keep / Try</text>
      </view>
      <view class="quick-feedback">
        <label class="field">Keep<input placeholder="有效的瞬间" value="{{item.keepValue}}" data-id="{{item.id}}" data-field="keep" bindblur="updatePlanField" /></label>
        <label class="field">Try<input placeholder="下次调整" value="{{item.tryValue}}" data-id="{{item.id}}" data-field="try" bindblur="updatePlanField" /></label>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{linkedInspirations.length > 0}}">
    <view class="section-title">
      <text>速记与灵感 ({{linkedInspirations.length}})</text>
    </view>
    <view class="inspiration-list">
      <view wx:for="{{linkedInspirations}}" wx:key="id" class="card inspiration-card">
        <view class="card-title">{{item.title}}</view>
        <text class="muted">{{item.desc}}</text>
        <view class="meta"><text wx:for="{{item.meta}}" wx:key="*this">{{item}}</text></view>
      </view>
    </view>
  </view>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" bindtap="pause">暂停排练</button>
      <button class="primary-btn" bindtap="review">结束并复盘</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{addVisible}}" title="添加到排练" bind:close="closeSheet">
    <view class="search-bar">
      <text>⌕</text>
      <input value="{{query}}" bindblur="searchGame" bindconfirm="searchGame" placeholder="搜索游戏、标签或目标" />
    </view>
    <view wx:for="{{filteredGames}}" wx:key="id" class="card option-card" data-id="{{item.id}}" bindtap="addGame">
      <view class="game-title">{{item.title}}</view>
      <text class="muted">{{item.desc}}</text>
      <view class="meta"><text wx:for="{{item.meta}}" wx:key="*this">{{item}}</text></view>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{planVisible}}" title="调整排练计划" bind:close="closeSheet">
    <view class="card plan-sheet-summary">
      <text class="mini-title">当前排练</text>
      <view class="section-title">{{title}} · {{duration}} 分钟</view>
      <text class="muted">{{desc}}</text>
    </view>
    <view wx:for="{{planGames}}" wx:key="id" class="card option-card">
      <view class="card-head">
        <view>
          <view class="game-title">{{index + 1}}. {{item.title}}</view>
          <text class="muted">{{item.status}} · {{item.metaText}} · {{item.tagText}}</text>
        </view>
        <button class="small-btn" data-id="{{item.id}}" bindtap="toggleStatus">切换状态</button>
      </view>
    </view>
    <button class="primary-btn plan-submit" bindtap="savePlan">保存计划</button>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
