.record {
  padding: var(--content-safe-top) var(--page-side) var(--page-bottom);
}

.record-content {
  width: 100%;
  min-height: calc(100vh - 364rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.record-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  text-align: center;
}

.record-title {
  font-size: 60rpx;
  line-height: 1.08;
  font-weight: 900;
}

.record-intro {
  max-width: 460rpx;
  margin-top: 18rpx;
}

.record-input-card {
  width: 100%;
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--improv-card);
  box-shadow: var(--improv-shadow-card);
  text-align: left;
}

.record-inspiration-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 224rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: var(--improv-bg-field-soft);
  color: var(--improv-text);
  font-size: 30rpx;
  line-height: 1.58;
}

.record-save-btn {
  width: 320rpx;
  max-width: 76%;
  margin: 24rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-actions {
  display: flex;
  width: 100%;
  max-width: 430rpx;
  gap: 18rpx;
  margin-top: 16rpx;
  justify-content: center;
}

.record-action-btn {
  flex: 0 0 auto;
  width: 196rpx;
  min-width: 196rpx;
  max-width: 196rpx;
  min-height: 62rpx;
  padding: 0 18rpx;
}

.record-footnote {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: nowrap;
  column-gap: 0;
  row-gap: 0;
  width: 100%;
  max-width: 100%;
  margin-top: 20rpx;
  padding: 0 6rpx;
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
  white-space: nowrap;
}

.record-stat-link {
  min-height: 0;
  padding: 0;
  color: var(--improv-secondary-strong);
  font-size: 26rpx;
  font-weight: 900;
  line-height: inherit;
}

.record-stat-link-first {
  margin-left: 8rpx;
}

.footnote-sep {
  margin: 0 6rpx;
}

.record-stack {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.record-hub-card,
.recommend-box {
  position: relative;
  width: 100%;
  padding: 32rpx;
  text-align: left;
}

.record-hub-card {
  margin-top: 0;
}

.recommend-box {
  background:
    linear-gradient(135deg, var(--improv-primary-glass), var(--improv-secondary-glass)),
    var(--improv-card);
}

.recommend-box-disabled {
  opacity: 0.98;
}

.recommend-main {
  padding-right: 72rpx;
}

.card-title {
  margin: 10rpx 0 12rpx;
  color: var(--improv-text);
  font-size: 34rpx;
  font-weight: 900;
}

.recommend-close {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  min-height: 44rpx;
  max-width: 44rpx;
  max-height: 44rpx;
  border-radius: 22rpx;
  background: var(--improv-card-translucent);
  color: var(--improv-light);
  font-weight: 900;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 44rpx;
  z-index: 2;
  box-shadow: 0 8rpx 18rpx var(--improv-shadow-dark-color);
}

.rehearsal-card {
  margin-top: 0;
}

.mini-plan {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 20rpx;
}

.mini-plan-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.mini-dot {
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  min-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: var(--improv-secondary-soft);
  color: var(--improv-secondary-strong);
  font-size: 22rpx;
  font-weight: 900;
}

.summary,
.item-card {
  padding: 28rpx;
  margin-top: 28rpx;
}

.sheet-empty-card {
  margin-top: 16rpx;
  text-align: left;
}

.sheet-empty-card .card-title {
  margin-top: 0;
}

.sheet-empty-card .muted {
  display: block;
  margin-top: 10rpx;
  line-height: 1.6;
}

.start-btn {
  width: 320rpx;
  max-width: 72%;
  margin: 24rpx auto 0;
  align-self: center;
}

.start-rehearsal-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  padding-top: 2rpx;
}

.start-rehearsal-section.field {
  margin-top: 0;
}

.start-rehearsal-section.field input {
  min-height: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  margin-top: 0;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.start-rehearsal-section .mini-title {
  margin-bottom: 0;
  font-size: 23rpx;
}

.start-rehearsal-section .field-label-group {
  margin-bottom: var(--improv-form-gap-field-body, 14rpx);
}

.custom-goal-chip {
  max-width: 240rpx;
}

.custom-goal-panel {
  margin-top: var(--improv-form-gap-inline, 16rpx);
}

.start-rehearsal-hint {
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.55;
}

.custom-goal-field {
  margin-top: 0;
  font-size: 24rpx;
}

.custom-goal-field input {
  min-height: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  margin-top: 0;
  padding: 16rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.start-rehearsal-submit {
  width: 280rpx;
  max-width: 64%;
  min-height: 68rpx;
  margin-top: 0;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.disabled-btn {
  opacity: 0.5;
  pointer-events: none;
}

.start-practice-picker {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  width: 100%;
}

.start-practice-search {
  width: 100%;
  min-height: 84rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 26rpx;
  border-radius: 42rpx;
  background: var(--improv-bg-subtle);
  color: var(--improv-secondary-strong);
  font-size: 28rpx;
  font-weight: 900;
}

.start-practice-search-icon {
  flex: 0 0 auto;
}

.start-practice-search input {
  flex: 1;
  min-width: 0;
  color: var(--improv-text);
  font-size: 28rpx;
  font-weight: 800;
}

.start-material-list {
  width: 100%;
  height: 360rpx;
  max-height: 38vh;
  min-height: 260rpx;
  border-radius: 28rpx;
  background: var(--improv-bg-subtle);
  overflow: hidden;
}

.start-practice-option {
  padding: 24rpx;
  margin: 0 0 18rpx;
  border: 2rpx solid transparent;
  background: var(--improv-card-strong);
  box-shadow: 0 8rpx 18rpx var(--improv-shadow-xs-color);
}

.start-practice-option .selection-card-title {
  flex: 1 1 auto;
  min-width: 0;
  margin-top: 0;
  font-size: 30rpx;
  line-height: 1.3;
}

.start-practice-meta {
  margin-top: 16rpx;
}

.start-practice-empty {
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  text-align: center;
}

.small-btn {
  height: 60rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  padding: 0 32rpx;
  border-radius: 30rpx;
  background: var(--improv-primary-wash);
  color: var(--improv-primary);
  font-weight: 600;
  border: none;
  text-align: center;
  white-space: nowrap;
}

bottom-sheet > .mini-title {
  margin-top: 40rpx;
}
