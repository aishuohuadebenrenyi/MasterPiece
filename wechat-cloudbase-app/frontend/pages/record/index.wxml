<view class="page record {{modalOpen ? 'modal-open' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <view class="record-content">
    <view class="record-hero">
      <view class="record-title">记录灵感</view>
      <button class="record-main" bindtap="openVoice">🎤</button>
      <text class="record-intro muted">按一下开始，先把感觉留下来。</text>
      <view class="record-actions">
        <button class="small-btn record-action-btn" bindtap="openStartGame">记录游戏</button>
        <button class="small-btn record-action-btn" bindtap="openStartRehearsal">记录排练</button>
      </view>
      <view wx:if="{{showTodaySummary}}" class="record-footnote">
        <text>今天已记录</text>
        <text class="record-stat-link record-stat-link-first" data-kind="inspirations" bindtap="openToday">{{inspirationCount}} 条灵感</text>
        <text class="footnote-sep">，</text>
        <text class="record-stat-link" data-kind="rehearsals" bindtap="openToday">{{rehearsalCount}} 次练习</text>
      </view>
    </view>

    <view class="record-stack">
      <view wx:if="{{gameCard}}" class="card record-hub-card game-card">
        <view class="row">
          <view>
            <text class="mini-title">{{gameCard.label}}</text>
            <view class="card-title">{{gameCard.title}}</view>
          </view>
          <button class="small-btn" bindtap="resumeGameCard">去查看</button>
        </view>
        <text class="muted">时长：{{gameCard.durationText}}</text>
      </view>

      <view wx:elif="{{rehearsalCard}}" class="card record-hub-card rehearsal-card">
        <view class="row">
          <view>
            <text class="mini-title">{{rehearsalCard.label}}</text>
            <view class="card-title">{{rehearsalCard.title}}</view>
          </view>
          <button class="small-btn" bindtap="resumeRehearsal">继续</button>
        </view>
        <text class="muted">目标：{{rehearsalCard.desc}}</text>
        <view class="mini-plan">
          <view wx:for="{{rehearsalCard.items}}" wx:key="indexLabel" class="mini-plan-item">
            <text class="mini-dot">{{item.indexLabel}}</text>
            <text>{{item.text}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{recommendVisible && recommendTitle}}" class="card recommend-box {{recommendClickable ? '' : 'recommend-box-disabled'}}">
        <button class="recommend-close" catchtap="closeRecommend">×</button>
        <view wx:if="{{recommendClickable}}" class="recommend-main recommend-main-clickable" bindtap="openRecommend">
          <text class="mini-title">今日推荐</text>
          <view class="card-title">{{recommendTitle}}</view>
          <text class="muted">{{recommendDesc}}</text>
        </view>
        <view wx:else class="recommend-main">
          <text class="mini-title">今日推荐</text>
          <view class="card-title">{{recommendTitle}}</view>
          <text class="muted">{{recommendDesc}}</text>
        </view>
      </view>
    </view>
  </view>

  <bottom-sheet visible="{{voiceVisible}}" title="记录灵感" maskVariant="medium" bodyMode="fit" bind:close="closeSheet">
    <text class="muted" wx:if="{{!activeContextName}}">先说下来，整理可以稍后再做。</text>
    <view wx:if="{{activeContextName}}" class="active-rehearsal-tip">
      <text>📍 {{activeContextName}}</text>
    </view>
    <view class="pulse">{{timeText}}</view>
    <view class="voice-actions">
      <button class="small-btn" bindtap="pauseVoice">暂停</button>
      <button class="primary-btn" bindtap="startTimer">{{recordingText}}</button>
      <button class="small-btn" bindtap="finishVoice">完成</button>
    </view>
    <view class="card summary" wx:if="{{!timer && elapsed > 0}}">
      <text class="mini-title">摘要预览</text>
      <text class="muted">{{voiceSummary}}</text>
    </view>
    <view class="save-actions" wx:if="{{!timer && elapsed > 0}}">
      <button class="ghost-btn" bindtap="saveVoiceAsInspiration">存为灵感</button>
      <button class="primary-btn" bindtap="archiveToCurrentContext" wx:if="{{activeContextName}}">归档到当前</button>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{startGameVisible}}" title="快速开始游戏" maskVariant="light" sheetClass="start-game-sheet task-sheet" bodyMode="fit" bind:close="closeSheet">
    <view class="start-game-picker">
      <search-bar customClass="start-game-search" value="{{gameSearchQuery}}" placeholder="搜索游戏、标签或目标" showClear="{{true}}" bind:focus="showStartGameList" bind:blur="onGameSearchInput" bind:confirm="onGameSearchInput" bind:clear="clearGameSearch" />
      <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="start-game-list">
        <selection-card
          wx:for="{{filteredGamesList}}"
          wx:key="id"
          itemId="{{item.id}}"
          customClass="start-game-option"
          title="{{item.title}}"
          desc="{{item.desc}}"
          selected="{{startGameSelectedId === item.id}}"
          selectedText="已选"
          bind:tapcard="selectGameToStart"
        >
          <view slot="extra" class="meta-row start-game-meta" wx:if="{{item.meta.length || item.tags.length}}">
            <text wx:for="{{item.meta}}" wx:key="*this" class="meta-pill">{{item}}</text>
            <text wx:for="{{item.tags}}" wx:key="*this" class="meta-pill">{{item}}</text>
          </view>
        </selection-card>
        <empty-state-panel wx:if="{{filteredGamesList.length === 0}}" customClass="start-game-empty" title="{{startGameEmptyTitle}}" desc="{{startGameEmptyDesc}}" />
      </scroll-view>
    </view>
    <button class="primary-btn start-btn {{!startGameSelectedId ? 'disabled-btn' : ''}}" bindtap="startGameFromRecord" disabled="{{!startGameSelectedId}}">开始游戏</button>
  </bottom-sheet>

  <bottom-sheet visible="{{todayVisible}}" title="{{todayTitle}}" maskVariant="light" bodyMode="fit" bind:close="closeSheet">
    <empty-state-panel wx:if="{{!todayItems.length}}" customClass="sheet-empty-card" title="{{todayEmptyTitle}}" desc="{{todayEmptyDesc}}" />
    <selection-card
      wx:for="{{todayItems}}"
      wx:key="id"
      itemId="{{item.id}}"
      customClass="item-card"
      title="{{item.title}}"
      desc="{{item.desc}}"
      pending="{{item.syncStatus === 'pending'}}"
    />
  </bottom-sheet>

  <bottom-sheet visible="{{startRehearsalVisible}}" title="快速开启排练" maskVariant="light" bodyMode="fit" sheetClass="start-rehearsal-sheet task-sheet" bind:close="closeSheet">
    <view class="start-rehearsal-form">
      <form-field class="start-rehearsal-section" label="团队">
        <input class="app-input" value="{{teamName}}" data-field="teamName" bindblur="updateStartForm" bindconfirm="updateStartForm" />
      </form-field>
      <filter-section label="时长" options="{{durationOptions}}" customClass="start-rehearsal-section" rowClass="start-rehearsal-chips" bind:select="setDuration" />
      <filter-section label="本次目标" options="{{goalOptions}}" customClass="start-rehearsal-section start-goal-section" rowClass="start-rehearsal-goal-row" chipClass="start-rehearsal-goal-chip" bind:select="toggleGoal">
        <button slot="suffix" class="chip compact-filter-chip start-rehearsal-goal-chip custom-goal-chip {{customGoalInput ? 'active' : ''}}" bindtap="toggleCustomGoal">{{customGoalInput ? customGoalInput : '+ 自定义'}}</button>
        <view wx:if="{{customGoalVisible}}" class="custom-goal-panel">
          <form-field label="自定义目标">
            <input class="app-input" value="{{customGoalInput}}" placeholder="例如：默契升温" bindblur="updateCustomGoal" bindconfirm="updateCustomGoal" />
          </form-field>
        </view>
      </filter-section>
      <filter-section label="添加游戏" options="{{sourceOptions}}" customClass="start-rehearsal-section start-rehearsal-section-last" rowClass="start-rehearsal-chips" bind:select="setSource" />
      <text wx:if="{{rehearsalSourceHint}}" class="muted start-rehearsal-hint">{{rehearsalSourceHint}}</text>
      <button class="primary-btn start-btn start-rehearsal-submit {{savedSourceUnavailable ? 'disabled-btn' : ''}}" bindtap="startRehearsal" disabled="{{savedSourceUnavailable}}">开始排练</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</view>
