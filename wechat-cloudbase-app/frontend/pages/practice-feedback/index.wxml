<scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="page subpage-page feedback {{themeClass}}" style="{{layoutStyle}}" wx:if="{{material}}">
  <subpage-header kicker="{{duration > 0 ? '本次练习时长：' + durationText : '素材练习复盘'}}" title="{{material.title}}" bind:back="back" />

  <form-card title="关联方式">
    <view class="feedback-object-summary">
      <view class="feedback-object-title">{{material.title}}</view>
      <text class="muted feedback-object-desc">{{material.desc}}</text>
    </view>
    <view class="meta-row feedback-object-meta"><text wx:for="{{material.meta}}" wx:key="*this" class="meta-pill">{{item}}</text></view>
  </form-card>

  <form-card title="本次反馈">
    <view class="feedback-section context-inline-section">
      <text class="feedback-section-title">归属场景</text>
      <view class="form-chip-row context-chip-row">
        <button wx:for="{{contextOptions}}" wx:key="value" class="chip compact-filter-chip {{item.activeClass}}" data-value="{{item.value}}" bindtap="setContextType">{{item.label}}</button>
      </view>
      <text wx:if="{{contextLoading}}" class="context-load-note">正在加载排练…</text>
      <view wx:if="{{contextLoadFailed}}" class="context-load-error">
        <text>排练加载失败，可单独保存。</text>
        <button class="small-btn context-retry-btn" bindtap="retryHistoricalRehearsals">重试</button>
      </view>
      <view class="feedback-status-card context-status-card">
        <text class="feedback-status-title">{{contextSummaryTitle}}</text>
        <text class="feedback-helper">{{contextSummaryDesc}}</text>
      </view>
      <picker wx:if="{{contextType === 'history'}}" mode="selector" range="{{historicalRehearsals}}" range-key="title" bindchange="selectHistoricalRehearsal">
        <view class="app-input">{{linkedRehearsal || '选择历史排练'}}</view>
      </picker>
    </view>
    <view class="feedback-section effect-inline-section">
      <text class="feedback-section-title">效果反馈</text>
      <view class="form-chip-row effect-chip-row">
        <button wx:for="{{effectOptions}}" wx:key="value" class="chip compact-filter-chip {{item.activeClass}}" data-value="{{item.value}}" bindtap="setEffect">{{item.label}}</button>
      </view>
    </view>
    <view class="form-field-stack feedback-field-stack">
      <form-field label="Keep">
        <textarea class="app-textarea" value="{{keepValue}}" data-field="keepValue" bindblur="updateField" />
      </form-field>
      <form-field label="Try">
        <textarea class="app-textarea" value="{{tryValue}}" data-field="tryValue" bindblur="updateField" />
      </form-field>
      <form-field label="下次提醒">
        <input class="app-input" value="{{reminderValue}}" data-field="reminderValue" bindblur="updateField" bindconfirm="updateField" />
      </form-field>
    </view>
    <view class="more-toggle" bindtap="toggleMore">
      <view>
        <text class="mini-title">更多信息</text>
      </view>
      <text class="more-arrow">{{moreVisible ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{moreVisible}}" class="more-fields">
      <view class="form-field-stack">
        <form-field label="人数">
          <input class="app-input" value="{{attendanceText}}" data-field="attendanceText" bindblur="updateField" />
        </form-field>
      </view>
    </view>
  </form-card>

  <view class="bottom-spacer"></view>

  <root-portal>
    <view class="action-stack">
    <view class="form-actions">
        <button class="ghost-btn" loading="{{savingMode === 'method'}}" disabled="{{!!savingMode}}" bindtap="saveMethodCard">保存并沉淀</button>
        <button class="primary-btn" loading="{{savingMode === 'record'}}" disabled="{{!!savingMode}}" bindtap="saveRecord">保存记录</button>
      </view>
    </view>
  </root-portal>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
