.game-records-scroll {
  width: 100%;
  height: 100vh;
  min-height: 0;
}

.game-records-page {
  width: 100%;
  min-height: 0;
  padding: var(--nav-row-top) var(--page-side) calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.subpage-header {
  margin-bottom: 28rpx;
}

.game-back {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  min-height: 64rpx;
  margin-bottom: 18rpx;
  padding: 0;
  color: var(--improv-text);
  font-size: 36rpx;
  line-height: 1;
  font-weight: 900;
}

.page-title,
.section-title {
  color: var(--improv-text);
  font-weight: 900;
}

.page-title {
  font-size: 56rpx;
  line-height: 1.1;
}

.record-form-card,
.record-item {
  padding: 36rpx;
}

.summary-card {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 34rpx;
  line-height: 1.18;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta text {
  padding: 12rpx 20rpx;
  border-radius: 0;
  background: var(--improv-bg-soft);
  color: var(--improv-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.meta .pending {
  background: var(--improv-primary-tint);
  color: var(--improv-warm);
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.record-item .small-btn {
  flex: 0 0 108rpx;
  width: 108rpx;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 34rpx;
  font-size: 24rpx;
}

.record-item .muted {
  display: block;
  margin-top: 16rpx;
}

.state-card,
.notice-card {
  padding: 28rpx;
  border-radius: 30rpx;
  color: var(--improv-muted);
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 800;
}

.state-card {
  background: var(--improv-card-light);
}

.empty-state {
  padding: 42rpx 36rpx 40rpx;
  border-radius: 40rpx;
  background: var(--improv-card-strong);
  border: 2rpx solid var(--improv-line-soft);
  box-shadow: var(--improv-shadow-xs);
}

.notice-card {
  margin-bottom: 22rpx;
  background: var(--improv-primary-tint);
  color: var(--improv-warm);
}

.empty-state .section-title {
  margin-bottom: 10rpx;
}

.detail-card {
  padding: 28rpx;
  border-radius: 30rpx;
  background: var(--improv-bg-subtle);
}

.detail-title {
  margin-top: 6rpx;
  color: var(--improv-text);
  font-size: 36rpx;
  line-height: 1.18;
  font-weight: 900;
}

.detail-meta {
  margin-top: 22rpx;
}

.detail-section {
  margin-top: 28rpx;
}

.detail-notes {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid var(--improv-line-subtle);
  color: var(--improv-muted);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 800;
}

.readonly-note {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: var(--improv-primary-tint);
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 800;
}