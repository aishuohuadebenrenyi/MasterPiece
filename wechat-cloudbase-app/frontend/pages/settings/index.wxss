@import '../../styles/theme.wxss';

.settings-scroll {
  width: 100%;
  height: 100vh;
  min-height: 0;
  background: linear-gradient(180deg, #fff5ef 0%, #f7f9ff 54%, #eef5ff 100%);
  background: linear-gradient(180deg, var(--improv-bg-top, #fff5ef) 0%, var(--improv-bg-mid, #f7f9ff) 54%, var(--improv-bg-bottom, #eef5ff) 100%);
  color: var(--improv-text);
}

.settings-page {
  width: 100%;
  min-height: 100vh;
  padding: var(--nav-row-top) var(--page-side) calc(60rpx + env(safe-area-inset-bottom));
}

.subpage-header {
  margin-bottom: 30rpx;
}

.settings-group {
  margin-bottom: 40rpx;
}

.settings-group-title {
  display: block;
  margin: 0 0 16rpx;
  color: var(--improv-muted);
  font-size: 26rpx;
  font-weight: 600;
}

.settings-card {
  overflow: hidden;
  background: #ffffff;
  background: var(--improv-card, #ffffff);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.settings-row {
  width: 100%;
  min-height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  padding: 24rpx 32rpx;
  text-align: left;
}

.settings-row-main {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  text-align: left;
}

.settings-row-side {
  flex: 0 0 28rpx;
  width: 28rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.settings-row-title,
.settings-row-desc {
  display: block;
}

.settings-row-title {
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 600;
}

.settings-row-desc {
  margin-top: 6rpx;
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.4;
}

.settings-row-arrow {
  color: var(--improv-light-strong);
  font-size: 36rpx;
  line-height: 1;
}

.settings-account-group {
  margin-top: 72rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.settings-theme-card {
  padding: 32rpx;
}

.settings-panel {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 22rpx;
}

.settings-panel-main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.settings-theme-switch {
  width: 100%;
  max-width: 420rpx;
  margin-top: 4rpx;
}

.settings-theme-switch view {
  min-height: 60rpx;
  font-size: 24rpx;
}

.settings-account-actions {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
}

.settings-account-note {
  display: block;
  color: var(--improv-muted);
  font-size: 22rpx;
  line-height: 1.5;
}

.settings-danger-btn {
  width: 100%;
  min-height: 88rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
}

.feedback-types-scroll {
  width: 100%;
  height: 68rpx;
  white-space: nowrap;
}

.feedback-types-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 2rpx 2rpx 4rpx;
}

.feedback-chip {
  flex: 0 0 auto;
  width: auto !important;
  min-width: 0;
  min-height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
}

.feedback-count {
  align-self: flex-end;
  margin-top: 10rpx;
  color: var(--improv-text-muted);
  font-size: 22rpx;
}

.feedback-submit {
  align-self: center;
  width: 320rpx;
  min-height: 80rpx;
  margin-top: 8rpx;
}
