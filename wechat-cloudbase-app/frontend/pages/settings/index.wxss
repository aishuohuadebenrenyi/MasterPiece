@import '../../styles/theme.wxss';

.settings-scroll {
  width: 100%;
  height: 100vh;
  min-height: 0;
  background: linear-gradient(180deg, #fafaf7 0%, #f7f8f3 54%, #f3f7f5 100%);
  background: linear-gradient(180deg, var(--improv-bg-top, #fafaf7) 0%, var(--improv-bg-mid, #f7f8f3) 54%, var(--improv-bg-bottom, #f3f7f5) 100%);
  color: var(--improv-text);
}

.settings-page {
  width: 100%;
  min-height: 100vh;
  padding: var(--nav-row-top) var(--page-side) calc(60rpx + env(safe-area-inset-bottom));
}

.subpage-header {
  margin-bottom: 30rpx;
}

.settings-group {
  margin-bottom: 40rpx;
}

.settings-group-title {
  display: block;
  margin: 0 0 16rpx;
  color: var(--improv-muted);
  font-size: 26rpx;
  font-weight: 600;
}

.settings-card {
  overflow: hidden;
  background: #ffffff;
  background: var(--improv-card, #ffffff);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.settings-row {
  width: 100%;
  min-height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  padding: 24rpx 32rpx;
  text-align: left;
}

.settings-row-main {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  text-align: left;
}

.settings-row-side {
  flex: 0 0 92rpx;
  width: 92rpx;
  min-width: 92rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  margin-left: auto;
  color: var(--improv-muted);
}

.settings-row-action {
  flex: 0 0 auto;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.settings-row-title,
.settings-row-desc {
  display: block;
}

.settings-row-title {
  color: var(--improv-text);
  font-size: 32rpx;
  font-weight: 600;
}

.settings-row-desc {
  margin-top: 6rpx;
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.4;
}

.settings-row-arrow {
  color: var(--improv-light-strong);
  font-size: 36rpx;
  line-height: 1;
}

.settings-account-group {
  margin-top: 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.settings-theme-card {
  padding: 24rpx 32rpx;
}

.settings-panel {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.settings-panel-main {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.settings-theme-switch {
  position: relative;
  flex: 0 0 232rpx;
  width: 232rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  padding: 4rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background: var(--improv-bg-field-soft);
  border: 2rpx solid var(--improv-line-soft);
}

.settings-theme-thumb {
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  width: 110rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: var(--improv-card-strong);
  box-shadow: var(--improv-shadow-xs);
  transform: translateX(0);
  transition: transform 0.22s ease;
}

.settings-theme-switch.is-vivid .settings-theme-thumb {
  transform: translateX(110rpx);
}

.settings-theme-option {
  position: relative;
  z-index: 1;
  flex: 1 1 0;
  min-width: 0;
  min-height: 52rpx;
  padding: 0;
  background: transparent;
  color: var(--improv-muted);
  font-size: 22rpx;
  font-weight: 700;
  transition: color 0.18s ease;
}

.settings-theme-option.active {
  color: var(--improv-text);
}

.settings-account-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.settings-account-main {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.settings-account-title {
  font-size: 28rpx;
}

.settings-danger-btn {
  flex: 0 0 116rpx;
  width: 116rpx;
  min-width: 116rpx;
  min-height: 60rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
  padding-bottom: 8rpx;
}

.feedback-types-scroll {
  width: 100%;
  height: 68rpx;
  white-space: nowrap;
}

.feedback-types-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 2rpx 2rpx 4rpx;
}

.feedback-chip {
  flex: 0 0 auto;
  width: auto !important;
  min-width: 0;
  min-height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
}

.feedback-count {
  align-self: flex-end;
  margin-top: 10rpx;
  color: var(--improv-text-muted);
  font-size: 22rpx;
}

.feedback-submit {
  width: 320rpx;
  min-height: 80rpx;
  margin: 0;
}

.feedback-actions {
  width: 100%;
  display: flex;
  justify-content: center;
}
