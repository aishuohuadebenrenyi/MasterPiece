<scroll-view scroll-y="{{!modalOpen}}" enable-flex="true" enhanced show-scrollbar="{{false}}" bindscroll="onScroll" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" bindrefresherrefresh="onPullDownRefresh" class="page discover {{modalOpen ? 'modal-open' : ''}} {{filterVisible ? 'filter-open' : ''}} {{showEmptyState ? 'empty-mode' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <view class="discover-content">
    <block wx:if="{{showLoadErrorState}}">
      <view class="empty-state-shell">
        <empty-state-panel
          customClass="discover-hero-empty discover-error-empty"
          tone="error"
          title="同步失败"
          desc="{{loadErrorText}}"
          primaryText="重新同步"
          secondaryText="先添加素材"
          bind:primary="retryLoadMaterials"
          bind:secondary="openAdd"
        />
      </view>
    </block>

    <block wx:elif="{{showEmptyState}}">
      <view class="empty-state-shell">
        <empty-state-panel
          customClass="discover-hero-empty"
          title="添加素材"
          desc="先收几张常用素材，之后练习和排练会更快。"
          primaryText="添加素材"
          bind:primary="openAdd"
        />
      </view>
    </block>

    <block wx:else>
      <view class="view-tools">
        <view class="switch compact-switch">
          <view class="{{allActiveClass}}" data-view="all" bindtap="switchView">全部</view>
          <view class="{{categoryActiveClass}}" data-view="category" bindtap="switchView">分类</view>
        </view>
      </view>

      <search-bar wx:if="{{view === 'all' || isCategoryDetail}}" customClass="search card" value="{{query}}" placeholder="{{searchPlaceholder}}" hint="{{isCategoryDetail ? activeCategory : '角色 / 主理'}}" showClear="{{true}}" bind:blur="search" bind:confirm="search" bind:clear="clearSearchQuery" />

      <view wx:if="{{isCategoryDetail}}" class="category-toolbar">
        <view class="category-back" aria-label="返回分类" bindtap="backToCategoryGrid">←</view>
        <button class="mini-action-btn neutral filter-btn" bindtap="openFilter">筛选</button>
      </view>

      <view wx:else class="section-row result-section-row">
        <text class="section-title">{{view === 'category' ? '素材类别' : discoverTitle}}</text>
        <view class="actions-row">
          <button class="mini-action-btn neutral share-btn" open-type="share">分享</button>
          <button wx:if="{{view === 'all'}}" class="mini-action-btn primary-lite add-btn" bindtap="openAdd">新建</button>
          <button wx:if="{{view === 'all'}}" class="mini-action-btn neutral filter-btn" bindtap="openFilter">筛选</button>
        </view>
      </view>

      <view wx:if="{{loadErrorText}}" class="notice-note-card">{{loadErrorText}}</view>

      <view wx:if="{{view === 'category' && !isCategoryDetail}}" class="category-overview">
        <view class="category-primary-block">
          <view class="category-block-head" wx:if="{{false}}">
            <text class="category-block-kicker">分类导航</text>
            <text class="category-block-desc">先选素材类型，再进入对应类别继续浏览。</text>
          </view>
          <view class="category-grid">
            <view wx:for="{{categoryRows}}" wx:key="id" class="category-row">
              <view wx:for="{{item.items}}" wx:for-item="category" wx:key="type" class="category-card card-surface-nav" data-type="{{category.type}}" bindtap="openCategoryDetail">
                <view class="category-card-accent category-card-accent-{{category.tone}}"></view>
                <view class="category-card-main">
                  <text class="category-card-title">{{category.type}}</text>
                  <text class="category-card-count card-counter-pill">{{category.count}}</text>
                </view>
                <text class="category-card-hint">{{category.hint}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="category-reference-block">
          <view class="reference-block-head">
            <text class="reference-block-title">学习地图与训练路径</text>
          </view>

          <view class="path-card-stack">
            <view wx:for="{{pathEntries}}" wx:key="key" class="path-card" data-key="{{item.key}}" bindtap="openPathSheet" hover-class="none">
              <view class="path-card-head">
                <view class="path-card-content">
                  <view class="path-title-row">
                    <text class="path-card-title">{{item.title}}</text>
                    <text wx:if="{{item.customLabel}}" class="path-custom-label">{{item.customLabel}}</text>
                  </view>
                  <text class="path-card-desc">{{item.desc}}</text>
                  <view class="path-summary-row">
                    <text wx:for="{{item.preview}}" wx:for-item="tag" wx:key="*this" class="path-summary-pill">{{tag}}</text>
                  </view>
                </view>
                <button class="small-btn button-tertiary path-card-toggle" data-key="{{item.key}}" catchtap="openPathSheet">查看</button>
              </view>
            </view>
          </view>
        </view>
      </view>

      <empty-state-panel
        wx:elif="{{showFilterNoMatchState}}"
        customClass="matchless-card"
        tone="notice"
        title="当前条件下没有匹配素材"
        desc="可以放宽筛选条件，或者先从全部素材里继续浏览。"
        secondaryText="清空条件"
        bind:secondary="clearFilters"
      />

      <view wx:else class="material-list">
        <material-card wx:for="{{filteredMaterials}}" wx:key="id" material="{{item}}" saved="{{item.saved}}" bind:open="openMaterial" bind:save="toggleSave" />
      </view>

      <button
        wx:if="{{fabReady}}"
        class="random-fab"
        hover-class="fab-btn-active"
        style="left: {{fabX}}px; top: {{fabY}}px;"
        bindtap="openRandom"
        bindtouchstart="onFabTouchStart"
        catchtouchmove="onFabTouchMove"
        bindtouchend="onFabTouchEnd"
      >
        <text class="icon-text icon-random fab-icon-text">🎲</text>
      </button>
    </block>
  </view>

  <bottom-sheet visible="{{filterVisible}}" title="筛选素材" maskVariant="medium" sheetClass="filter-sheet discover-filter-sheet" bodyMode="fit" bind:close="closeSheet">
    <view class="filter-group-stack">
      <filter-section wx:if="{{!isCategoryDetail}}" customClass="discover-filter-section" label="素材类型" options="{{typeFilters}}" chipClass="discover-filter-chip" bind:select="filterType" />
      <filter-section customClass="discover-filter-section" label="训练能力" options="{{abilityFilters}}" chipClass="discover-filter-chip" bind:select="filterAbility" />
      <filter-section customClass="discover-filter-section" label="使用场景" options="{{sceneFilters}}" chipClass="discover-filter-chip" bind:select="filterScene" />
      <filter-section customClass="discover-filter-section" label="状态" options="{{statusFilters}}" chipClass="discover-filter-chip" bind:select="filterStatus" />
    </view>
    <button class="primary-btn sheet-submit" catchtap="applyFilter">查看结果（{{filteredMaterials.length}}）</button>
  </bottom-sheet>

  <bottom-sheet visible="{{randomVisible}}" title="抽一张素材" maskVariant="light" sheetClass="tab-sheet" bodyMode="fit" bind:close="closeSheet">
    <block wx:if="{{!materials.length}}">
      <empty-state-panel
        customClass="random-state-card"
        kicker="抽卡"
        kickerTone="blue"
        title="还没有可抽的素材"
        desc="先添加几个常用素材，再来随机抽一张。"
        primaryText="添加素材"
        bind:primary="openAdd"
      />
    </block>
    <block wx:elif="{{!currentRandomMaterial}}">
      <empty-state-panel
        customClass="random-state-card"
        kicker="抽卡"
        kickerTone="blue"
        title="当前条件下没有可训练素材"
        desc="路径类素材不进入抽卡训练池，可以放宽条件或从全部素材抽。"
        primaryText="从全部素材抽"
        secondaryText="清空条件"
        bind:primary="useAllMaterialsForRandom"
        bind:secondary="clearFiltersForRandom"
      />
    </block>
    <block wx:else>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}" style="margin-bottom: 8rpx;">
        <view class="chip-row">
          <button class="chip active">{{currentRandomMaterial.type}}</button>
          <button wx:for="{{currentRandomMaterial.abilities}}" wx:key="*this" class="chip active">{{item}}</button>
          <button wx:for="{{currentRandomMaterial.tags}}" wx:key="*this" class="chip active">{{item}}</button>
        </view>
      </scroll-view>
      <view class="recommend card">
        <text class="pill blue">{{randomUseAllMaterials ? '全部素材' : '抽到'}}</text>
        <view class="recommend-title">{{currentRandomMaterial.title}}</view>
        <text class="muted">{{currentRandomMaterial.desc}}</text>
        <view class="random-actions">
          <button class="ghost-btn" catchtap="reroll">再抽一张</button>
          <button class="primary-btn" catchtap="openRandomDetail">查看详情</button>
        </view>
      </view>
    </block>
  </bottom-sheet>

  <bottom-sheet visible="{{pathVisible}}" title="{{pathSheetTitle}}" maskVariant="medium" sheetClass="path-sheet task-sheet" showActions="{{true}}" closeOnMask="{{false}}" bind:close="closeSheet">
    <block wx:if="{{activePath}}">
      <block wx:if="{{!pathEditMode}}">
        <view class="path-sheet-desc-wrap" wx:if="{{activePath.desc}}">
          <text class="path-sheet-desc">{{activePath.desc}}</text>
        </view>
        <view class="path-sheet-steps">
          <view wx:for="{{activePath.steps}}" wx:for-item="stage" wx:key="title" class="path-step">
            <view class="path-step-index">{{index + 1}}</view>
            <view class="path-step-main">
              <view class="path-step-title">{{stage.title}}</view>
              <view wx:if="{{stage.desc}}" class="path-step-desc">{{stage.desc}}</view>
            </view>
          </view>
        </view>
        <view wx:if="{{activePath.tips}}" class="path-note-card">{{activePath.tips}}</view>
        <view class="path-sheet-meta">
          <text class="path-meta-label">相关能力</text>
          <view class="path-sheet-tags">
            <text wx:for="{{activePath.abilities}}" wx:key="*this" class="path-filter-chip">{{item}}</text>
            <text wx:for="{{activePath.scenes}}" wx:key="*this" class="path-summary-pill">{{item}}</text>
          </view>
        </view>
      </block>

      <block wx:else>
        <view class="path-edit-form">
          <form-field label="路径名称">
            <input class="app-input" value="{{pathDraft.title}}" data-field="title" placeholder="例如：我的演员学习地图" bindblur="handlePathDraftFieldChange" bindconfirm="handlePathDraftFieldChange" />
          </form-field>
          <form-field label="简短描述">
            <textarea class="app-textarea" value="{{pathDraft.desc}}" data-field="desc" placeholder="这条路径解决什么训练问题？" bindblur="handlePathDraftFieldChange"></textarea>
          </form-field>
          <form-field label="阶段步骤">
            <textarea class="app-textarea steps-textarea" value="{{pathDraft.steps}}" data-field="steps" placeholder="每行一个阶段，例如：建立关系" bindblur="handlePathDraftFieldChange"></textarea>
          </form-field>
          <form-field label="能力标签">
            <input class="app-input" value="{{pathDraft.abilityText}}" data-field="abilityText" placeholder="用顿号或逗号分隔，例如：自发性，角色塑造" bindblur="handlePathDraftFieldChange" bindconfirm="handlePathDraftFieldChange" />
          </form-field>
          <form-field label="备注">
            <textarea class="app-textarea steps-textarea" value="{{pathDraft.tips}}" data-field="tips" placeholder="记录你带练时需要提醒自己的事" bindblur="handlePathDraftFieldChange"></textarea>
          </form-field>
        </view>
      </block>
    </block>
    <view slot="actions" class="path-sheet-actions">
      <button wx:if="{{activePath && !pathEditMode}}" class="primary-btn path-action-btn" catchtap="editPath">{{activePath.editText}}</button>
      <block wx:else>
        <button wx:if="{{activePath}}" class="ghost-btn path-action-btn" catchtap="cancelPathEdit">取消</button>
        <button wx:if="{{activePath}}" class="primary-btn path-action-btn" catchtap="savePathDraft">{{activePath.saveText}}</button>
      </block>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{addVisible}}" title="添加素材" maskVariant="medium" sheetClass="add-sheet task-sheet" showActions="{{true}}" closeOnMask="{{false}}" bind:close="closeSheet">
    <material-form
      value="{{newMaterial}}"
      typeOptions="{{typeCategoryOptions}}"
      abilityOptions="{{abilityCategoryOptions}}"
      sceneOptions="{{sceneCategoryOptions}}"
      customCategoryVisible="{{customCategoryVisible}}"
      customCategoryInput="{{customCategoryInput}}"
      customCategoryFocus="{{customCategoryFocus}}"
      categorySuggestions="{{categorySuggestions}}"
      showMoreOptions="{{showMoreOptions}}"
      moreOptionsToggleText="{{moreOptionsToggleText}}"
      bind:fieldchange="handleMaterialFormFieldChange"
      bind:selecttype="setNewMaterialType"
      bind:selectability="toggleNewMaterialAbility"
      bind:selectscene="toggleNewMaterialScene"
      bind:togglecustomcategory="toggleCustomCategory"
      bind:customcategoryfocus="handleCustomCategoryFocus"
      bind:customcategoryblur="handleCustomCategoryBlur"
      bind:customcategoryconfirm="confirmCustomCategory"
      bind:selectsuggestion="selectCategorySuggestion"
      bind:togglemore="toggleMoreOptions"
    />
    <view slot="actions" class="add-submit-wrap">
      <button class="primary-btn add-submit-btn" bindtap="addMaterial">加入素材库</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>

<privacy-popup visible="{{privacyVisible}}" bind:agree="onPrivacyAgree" bind:refuse="onPrivacyRefuse" />
