<view class="page discover {{modalOpen ? 'modal-open' : ''}} {{showEmptyState ? 'empty-mode' : ''}}" style="{{layoutStyle}}">
  <block wx:if="{{showEmptyState}}">
    <view class="empty-state-shell">
      <view class="empty-state-card card">
        <view class="empty-state-copy">
          <text class="empty-state-title">添加游戏</text>
          <text class="empty-state-desc">马上开玩</text>
        </view>
        <view class="empty-state-action-wrap">
          <button class="primary-btn empty-state-action" bindtap="openAdd">添加游戏</button>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="view-tools safe-right">
      <view class="switch">
        <button class="{{listActiveClass}}" data-view="list" bindtap="switchView">列表</button>
        <button class="{{cardActiveClass}}" data-view="card" bindtap="switchView">卡片</button>
      </view>
    </view>

    <view class="search card">
      <text>⌕</text>
      <input placeholder="搜索游戏、标签或目标" value="{{query}}" bindblur="search" bindconfirm="search" />
      <text class="hint">试试“破冰”</text>
    </view>

    <scroll-view scroll-x enable-flex="true" enhanced show-scrollbar="{{false}}" class="tag-row discover-tags">
      <view class="chip-track">
        <button wx:for="{{tagChips}}" wx:key="value" class="chip scene-chip {{item.activeClass}}" data-tag="{{item.value}}" bindtap="filterTag">{{item.label}}</button>
      </view>
    </scroll-view>

    <view class="section-row">
      <text class="section-title">全部游戏</text>
      <view class="actions-row">
        <button class="primary-btn add-btn" bindtap="openAdd">+ 添加游戏</button>
        <button class="ghost-btn filter-btn" bindtap="openFilter">筛选</button>
      </view>
    </view>

    <view wx:if="{{isListView}}" class="game-list">
      <game-card wx:for="{{filteredGames}}" wx:key="id" game="{{item}}" saved="{{item.saved}}" bind:open="openGame" bind:save="toggleSave" />
    </view>

    <scroll-view wx:else scroll-x enhanced paging-enabled scroll-with-animation show-scrollbar="{{false}}" class="card-carousel">
      <view class="card-track">
        <view wx:for="{{filteredGames}}" wx:key="id" class="card-page">
          <game-card mode="card" game="{{item}}" saved="{{item.saved}}" bind:open="openGame" bind:save="toggleSave" />
        </view>
      </view>
    </scroll-view>

    <button
      wx:if="{{fabReady}}"
      class="random-fab"
      style="left: {{fabX}}px; top: {{fabY}}px;"
      bindtap="openRandom"
      bindtouchstart="onFabTouchStart"
      catchtouchmove="onFabTouchMove"
      bindtouchend="onFabTouchEnd"
    >🎲</button>
  </block>

  <bottom-sheet visible="{{filterVisible}}" title="筛选游戏" maskVariant="light" sheetClass="filter-sheet" bodyMode="fit" bind:close="closeSheet">
    <view class="filter-section">
      <text class="filter-label">人数</text>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}">
        <view class="chip-row">
          <button wx:for="{{peopleFilters}}" wx:key="value" class="chip filter-chip {{item.activeClass}}" data-value="{{item.value}}" catchtap="filterPeople">{{item.label}}</button>
        </view>
      </scroll-view>
    </view>
    <view class="filter-section">
      <text class="filter-label">时长</text>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}">
        <view class="chip-row">
          <button wx:for="{{durationFilters}}" wx:key="value" class="chip filter-chip {{item.activeClass}}" data-value="{{item.value}}" catchtap="filterDuration">{{item.label}}</button>
        </view>
      </scroll-view>
    </view>
    <view class="filter-section">
      <text class="filter-label">目标</text>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}">
        <view class="chip-row">
          <button wx:for="{{goalFilters}}" wx:key="value" class="chip filter-chip {{item.activeClass}}" data-value="{{item.value}}" catchtap="filterGoal">{{item.label}}</button>
        </view>
      </scroll-view>
    </view>
    <view class="filter-section">
      <text class="filter-label">状态</text>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}">
        <view class="chip-row">
          <button wx:for="{{statusFilters}}" wx:key="value" class="chip filter-chip {{item.activeClass}}" data-status="{{item.value}}" catchtap="filterStatus">{{item.label}}</button>
        </view>
      </scroll-view>
    </view>
    <button class="primary-btn sheet-submit" catchtap="applyFilter">查看结果（{{filteredGames.length}}）</button>
  </bottom-sheet>

  <bottom-sheet visible="{{randomVisible}}" title="条件抽卡" maskVariant="light" sheetClass="tab-sheet" bodyMode="fit" bind:close="closeSheet">
    <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}" style="margin-bottom: 8rpx;">
      <view class="chip-row">
        <button wx:for="{{currentRandomGame.tags}}" wx:key="*this" class="chip active">{{item}}</button>
        <button wx:for="{{currentRandomGame.meta}}" wx:key="*this" class="chip active">{{item}}</button>
      </view>
    </scroll-view>
    <view class="recommend card">
      <text class="pill blue">抽到</text>
      <view class="recommend-title">{{currentRandomGame.title}}</view>
      <text class="muted">{{currentRandomGame.desc}}</text>
      <view class="random-actions">
        <button class="ghost-btn" catchtap="reroll">再抽一张</button>
        <button class="primary-btn" catchtap="openRandomDetail">查看详情</button>
      </view>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{addVisible}}" title="添加游戏" maskVariant="medium" sheetClass="add-sheet task-sheet" showActions="{{true}}" bind:close="closeSheet">
    <view class="field add-sheet-field">
      <text>游戏名称</text>
      <view class="input-voice-row">
        <view class="input-shell">
          <input value="{{newGame.title}}" data-field="title" placeholder="例如：情绪接力" bindblur="updateNewGame" bindconfirm="updateNewGame" />
        </view>
        <button class="voice-circle-btn" data-target="title" bindtap="voiceFill">语音</button>
      </view>
    </view>
    <view class="field add-sheet-field category-field add-sheet-section">
      <text>分类</text>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}" style="margin-top: 14rpx;">
        <view class="chip-row">
          <button wx:for="{{categoryOptions}}" wx:key="value" class="chip category-chip {{item.activeClass}}" data-category="{{item.value}}" catchtap="toggleNewGameCategory">{{item.label}}</button>
          <button class="chip category-chip custom-category-chip {{customCategoryVisible ? 'active' : ''}}" catchtap="toggleCustomCategory">+ 自定义</button>
        </view>
      </scroll-view>
      <view wx:if="{{customCategoryVisible}}" class="custom-category-panel custom-category-block">
        <view class="input-shell custom-category-input">
          <input value="{{customCategoryInput}}" focus="{{customCategoryFocus}}" placeholder="输入或选择已有分类" bindinput="updateCustomCategory" bindfocus="handleCustomCategoryFocus" bindblur="handleCustomCategoryBlur" bindconfirm="confirmCustomCategory" />
        </view>
        <view wx:if="{{categorySuggestions.length}}" class="category-suggestions">
          <button wx:for="{{categorySuggestions}}" wx:key="value" class="category-suggestion" data-category="{{item.value}}" catchtap="selectCategorySuggestion">{{item.label}}</button>
        </view>
        <button class="ghost-btn custom-category-confirm" catchtap="confirmCustomCategory">添加分类</button>
      </view>
    </view>
    <view class="form-grid add-sheet-grid">
      <view class="field compact-field add-sheet-field add-sheet-grid-item">
        <text>适合人数</text>
        <view class="input-shell">
          <input value="{{newGame.people}}" data-field="people" placeholder="4-8 人" bindblur="updateNewGame" bindconfirm="updateNewGame" />
        </view>
      </view>
      <view class="field compact-field add-sheet-field add-sheet-grid-item">
        <text>时长</text>
        <view class="input-shell">
          <input value="{{newGame.duration}}" data-field="duration" placeholder="10 分钟" bindblur="updateNewGame" bindconfirm="updateNewGame" />
        </view>
      </view>
    </view>
    <view class="field add-sheet-field">
      <text>简短描述</text>
      <view class="textarea-voice-row">
        <view class="textarea-shell">
          <textarea value="{{newGame.desc}}" data-field="desc" placeholder="用一句话说清它适合什么时候玩" bindblur="updateNewGame"></textarea>
        </view>
        <button class="voice-circle-btn voice-circle-btn-bottom" data-target="desc" bindtap="voiceFill">语音</button>
      </view>
    </view>
    <button class="steps-toggle" catchtap="toggleMoreOptions">{{moreOptionsToggleText}}</button>
    <view wx:if="{{showMoreOptions}}" class="add-sheet-section">
      <view class="field add-sheet-field steps-field">
        <text>补充玩法步骤</text>
        <view class="textarea-voice-row">
          <view class="textarea-shell">
            <textarea value="{{newGame.steps}}" data-field="steps" placeholder="每行一步，例如：先围成一圈..." bindblur="updateNewGame"></textarea>
          </view>
          <button class="voice-circle-btn voice-circle-btn-bottom" data-target="steps" bindtap="voiceFill">语音</button>
        </view>
      </view>
      <view class="field add-sheet-field steps-field">
        <text>带领提示</text>
        <view class="textarea-voice-row">
          <view class="textarea-shell">
            <textarea value="{{newGame.tips}}" data-field="tips" placeholder="第一次带领时需要注意什么？" bindblur="updateNewGame"></textarea>
          </view>
          <button class="voice-circle-btn voice-circle-btn-bottom" data-target="tips" bindtap="voiceFill">语音</button>
        </view>
      </view>
      <view class="field add-sheet-field steps-field">
        <text>变体玩法</text>
        <view class="textarea-voice-row">
          <view class="textarea-shell">
            <textarea value="{{newGame.variant}}" data-field="variant" placeholder="这个游戏还有什么其他玩法？" bindblur="updateNewGame"></textarea>
          </view>
          <button class="voice-circle-btn voice-circle-btn-bottom" data-target="variant" bindtap="voiceFill">语音</button>
        </view>
      </view>
      <view class="field add-sheet-field steps-field">
        <text>可能翻车点</text>
        <view class="textarea-voice-row">
          <view class="textarea-shell">
            <textarea value="{{newGame.issue}}" data-field="issue" placeholder="大家最容易在哪个环节卡住？" bindblur="updateNewGame"></textarea>
          </view>
          <button class="voice-circle-btn voice-circle-btn-bottom" data-target="issue" bindtap="voiceFill">语音</button>
        </view>
      </view>
    </view>
    <view class="add-sheet-spacer"></view>
    <view slot="actions" class="add-submit-wrap">
      <button class="primary-btn add-submit-btn" bindtap="addGame">加入游戏库</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</view>
