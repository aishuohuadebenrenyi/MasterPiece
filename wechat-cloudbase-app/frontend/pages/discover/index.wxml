<view class="page discover {{modalOpen ? 'modal-open' : ''}} {{showEmptyState ? 'empty-mode' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <block wx:if="{{showLoadErrorState}}">
    <view class="empty-state-shell">
      <empty-state-panel
        customClass="discover-hero-empty discover-error-empty"
        title="同步失败"
        desc="{{loadErrorText}}"
        primaryText="重新同步"
        secondaryText="先添加游戏"
        bind:primary="retryLoadGames"
        bind:secondary="openAdd"
      />
    </view>
  </block>

  <block wx:elif="{{showEmptyState}}">
    <view class="empty-state-shell">
      <empty-state-panel
        customClass="discover-hero-empty"
        title="添加游戏"
        desc="马上开玩"
        primaryText="添加游戏"
        bind:primary="openAdd"
      />
    </view>
  </block>

  <block wx:else>
    <view class="view-tools safe-right">
      <view class="switch">
        <button class="{{listActiveClass}}" data-view="list" bindtap="switchView">列表</button>
        <button class="{{cardActiveClass}}" data-view="card" bindtap="switchView">卡片</button>
      </view>
    </view>

    <search-bar customClass="search card" value="{{query}}" placeholder="搜索游戏、标签或目标" hint="试试“破冰”" showClear="{{true}}" bind:blur="search" bind:confirm="search" bind:clear="clearSearchQuery" />

    <scroll-view scroll-x enable-flex="true" enhanced show-scrollbar="{{false}}" class="tag-row discover-tags">
      <view class="chip-track">
        <button wx:for="{{tagChips}}" wx:key="value" class="chip main-filter-chip scene-chip {{item.activeClass}}" data-tag="{{item.value}}" bindtap="filterTag">{{item.label}}</button>
      </view>
    </scroll-view>

    <view class="section-row">
      <text class="section-title">全部游戏</text>
      <view class="actions-row button-row button-row-equal">
        <button class="primary-btn add-btn" bindtap="openAdd">+ 添加游戏</button>
        <button class="ghost-btn filter-btn" bindtap="openFilter">筛选</button>
      </view>
    </view>

    <view wx:if="{{loadErrorText}}" class="notice-note-card">{{loadErrorText}}</view>

    <empty-state-panel
      wx:if="{{showFilterNoMatchState}}"
      customClass="matchless-card"
      title="当前条件下没有匹配游戏"
      desc="可以放宽筛选条件，或者先从全部游戏里继续浏览。"
      secondaryText="清空条件"
      bind:secondary="clearFilters"
    />

    <view wx:elif="{{isListView}}" class="game-list">
      <game-card wx:for="{{filteredGames}}" wx:key="id" game="{{item}}" saved="{{item.saved}}" bind:open="openGame" bind:save="toggleSave" />
    </view>

    <scroll-view wx:else scroll-x enhanced paging-enabled scroll-with-animation show-scrollbar="{{false}}" class="card-carousel">
      <view class="card-track">
        <view wx:for="{{filteredGames}}" wx:key="id" class="card-page">
          <game-card mode="card" game="{{item}}" saved="{{item.saved}}" bind:open="openGame" bind:save="toggleSave" />
        </view>
      </view>
    </scroll-view>

    <button
      wx:if="{{fabReady}}"
      class="random-fab"
      style="left: {{fabX}}px; top: {{fabY}}px;"
      bindtap="openRandom"
      bindtouchstart="onFabTouchStart"
      catchtouchmove="onFabTouchMove"
      bindtouchend="onFabTouchEnd"
    >🎲</button>
  </block>

  <bottom-sheet visible="{{filterVisible}}" title="筛选游戏" maskVariant="light" sheetClass="filter-sheet" bodyMode="fit" bind:close="closeSheet">
    <view class="filter-group-stack">
      <view class="filter-group">
        <filter-section label="人数" options="{{peopleFilters}}" chipClass="discover-filter-chip" bind:select="filterPeople" />
        <filter-section label="时长" options="{{durationFilters}}" chipClass="discover-filter-chip" bind:select="filterDuration" />
      </view>
      <view class="filter-group">
        <filter-section label="目标" options="{{goalFilters}}" chipClass="discover-filter-chip" bind:select="filterGoal" />
        <filter-section label="状态" options="{{statusFilters}}" chipClass="discover-filter-chip" bind:select="filterStatus" />
      </view>
    </view>
    <button class="primary-btn sheet-submit" catchtap="applyFilter">查看结果（{{filteredGames.length}}）</button>
  </bottom-sheet>

  <bottom-sheet visible="{{randomVisible}}" title="条件抽卡" maskVariant="light" sheetClass="tab-sheet" bodyMode="fit" bind:close="closeSheet">
    <block wx:if="{{!games.length}}">
      <empty-state-panel
        customClass="random-state-card"
        kicker="抽卡"
        kickerTone="blue"
        title="还没有可抽的游戏"
        desc="先添加几个常用游戏，再来条件抽卡。"
        primaryText="添加游戏"
        bind:primary="openAdd"
      />
    </block>
    <block wx:elif="{{!currentRandomGame}}">
      <empty-state-panel
        customClass="random-state-card"
        kicker="抽卡"
        kickerTone="blue"
        title="当前条件下没有匹配游戏"
        desc="放宽条件，或者先从全部游戏里抽一张。"
        primaryText="从全部游戏抽"
        secondaryText="清空条件"
        bind:primary="useAllGamesForRandom"
        bind:secondary="clearFiltersForRandom"
      />
    </block>
    <block wx:else>
      <scroll-view class="chip-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}" style="margin-bottom: 8rpx;">
        <view class="chip-row">
          <button wx:for="{{currentRandomGame.tags}}" wx:key="*this" class="chip active">{{item}}</button>
          <button wx:for="{{currentRandomGame.meta}}" wx:key="*this" class="chip active">{{item}}</button>
        </view>
      </scroll-view>
      <view class="recommend card">
        <text class="pill blue">{{randomUseAllGames ? '全部游戏' : '抽到'}}</text>
        <view class="recommend-title">{{currentRandomGame.title}}</view>
        <text class="muted">{{currentRandomGame.desc}}</text>
        <view class="random-actions">
          <button class="ghost-btn" catchtap="reroll">再抽一张</button>
          <button class="primary-btn" catchtap="openRandomDetail">查看详情</button>
        </view>
      </view>
    </block>
  </bottom-sheet>

  <bottom-sheet visible="{{addVisible}}" title="添加游戏" maskVariant="medium" sheetClass="add-sheet task-sheet" showActions="{{true}}" bind:close="closeSheet">
    <game-form
      value="{{newGame}}"
      categoryOptions="{{categoryOptions}}"
      customCategoryVisible="{{customCategoryVisible}}"
      customCategoryInput="{{customCategoryInput}}"
      customCategoryFocus="{{customCategoryFocus}}"
      categorySuggestions="{{categorySuggestions}}"
      showMoreOptions="{{showMoreOptions}}"
      moreOptionsToggleText="{{moreOptionsToggleText}}"
      bind:fieldchange="handleGameFormFieldChange"
      bind:voice="voiceFill"
      bind:togglecategory="toggleNewGameCategory"
      bind:togglecustomcategory="toggleCustomCategory"
      bind:customcategoryfocus="handleCustomCategoryFocus"
      bind:customcategoryblur="handleCustomCategoryBlur"
      bind:customcategoryconfirm="confirmCustomCategory"
      bind:selectsuggestion="selectCategorySuggestion"
      bind:togglemore="toggleMoreOptions"
    />
    <view class="add-sheet-spacer"></view>
    <view slot="actions" class="add-submit-wrap">
      <button class="primary-btn add-submit-btn" bindtap="addGame">加入游戏库</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</view>
