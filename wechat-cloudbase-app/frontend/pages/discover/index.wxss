.discover {
  display: flex;
  flex-direction: column;
  padding: var(--content-safe-top) 32rpx var(--page-bottom);
}

.discover.empty-mode {
  height: 100vh;
}

.view-tools {
  display: flex;
  justify-content: flex-end;
  min-height: 0;
  margin-bottom: 22rpx;
  padding-right: 182rpx;
}

.switch {
  width: 286rpx;
  display: flex;
  gap: 10rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  background: var(--improv-card-frost, rgba(255, 255, 255, 0.82));
  box-shadow: 0 16rpx 30rpx rgba(50, 68, 120, 0.08);
  box-shadow: 0 16rpx 30rpx var(--improv-shadow-sm-color, rgba(50, 68, 120, 0.08));
}

.switch button {
  flex: 1;
  min-width: 0;
  min-height: 64rpx;
  padding: 0;
  border-radius: 999rpx;
  color: #667289;
  color: var(--improv-muted, #667289);
  font-size: 28rpx;
  font-weight: 900;
}

.switch .active {
  background: #e8f0ff;
  background: var(--improv-secondary-soft, #e8f0ff);
  color: #2f6ff2;
  color: var(--improv-secondary-strong, #2f6ff2);
}

.search {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.search input {
  flex: 1;
  min-width: 0;
  color: var(--improv-text);
  font-size: 28rpx;
  font-weight: 800;
}

.hint {
  color: var(--improv-primary-strong);
  font-size: 26rpx;
  font-weight: 900;
}

.discover-tags {
  width: auto;
  height: 104rpx;
  margin: 0 -32rpx 14rpx;
  white-space: nowrap;
  overflow: hidden;
  position: relative;
  z-index: 2;
}

.chip-track {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  width: auto;
  min-width: auto;
  padding: 12rpx 32rpx;
  white-space: nowrap;
}

.discover-tags .main-filter-chip {
  flex: none;
  width: auto;
  min-width: 0;
  min-height: 66rpx;
  padding: 0 26rpx;
  white-space: nowrap;
}

.section-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 20rpx 0 22rpx;
  color: var(--improv-text);
  position: relative;
  z-index: 1;
}

.section-title {
  flex: 0 0 auto;
  color: var(--improv-text);
  font-size: 30rpx;
  font-weight: 900;
}

.actions-row {
  flex: 1 1 auto;
  min-width: 0;
  max-width: 440rpx;
  justify-content: flex-end;
  gap: 12rpx;
}

.add-btn {
  min-height: 62rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.filter-btn {
  min-height: 62rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(79, 140, 255, 0.14);
  border: 2rpx solid var(--improv-secondary-wash-soft, rgba(79, 140, 255, 0.14));
  box-shadow: 0 12rpx 24rpx rgba(50, 68, 120, 0.06);
  box-shadow: 0 12rpx 24rpx var(--improv-shadow-chip-color, rgba(50, 68, 120, 0.06));
  font-size: 24rpx;
}

.empty-state-shell {
  flex: 1 1 auto;
  width: 100%;
  display: flex;
  min-height: 0;
  padding: 24rpx 0;
}

.empty-state-card {
  flex: 1 1 auto;
  width: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 56rpx 40rpx 40rpx;
  border-radius: 40rpx;
  background:
    linear-gradient(135deg, rgba(79, 140, 255, 0.18), rgba(255, 122, 69, 0.14)),
    rgba(255, 255, 255, 0.96);
  background:
    linear-gradient(135deg, var(--improv-secondary-wash, rgba(79, 140, 255, 0.18)), var(--improv-primary-wash, rgba(255, 122, 69, 0.14))),
    var(--improv-sheet-bg, rgba(255, 255, 255, 0.96));
  box-shadow: 0 28rpx 60rpx rgba(50, 68, 120, 0.1);
  box-shadow: 0 28rpx 60rpx var(--improv-shadow-lg-color, rgba(50, 68, 120, 0.1));
}

.discover-hero-empty {
  justify-content: center;
  align-items: center;
  text-align: center;
}

.discover-hero-empty .section-title {
  font-size: 64rpx;
  line-height: 1.1;
}

.discover-hero-empty .muted {
  max-width: 520rpx;
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.5;
}

.discover-hero-empty .empty-actions {
  justify-content: center;
  padding-top: 24rpx;
}

.discover-error-empty .empty-action-btn {
  min-width: 240rpx;
}

.matchless-card {
  margin-bottom: 24rpx;
}

.matchless-card .muted,
.random-state-card .muted {
  display: block;
  margin-top: 12rpx;
  text-align: center;
}

.game-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-carousel {
  width: 100%;
  height: calc(100vh - 520rpx);
  min-height: 640rpx;
  max-height: 860rpx;
  white-space: nowrap;
  padding: 6rpx 0 28rpx;
  overflow: hidden;
}

.card-track {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  width: auto;
}

.card-page {
  width: calc(100vw - 80rpx);
  height: 100%;
  flex: 0 0 calc(100vw - 80rpx);
}

.random-fab {
  position: fixed;
  z-index: 20;
  width: 116rpx;
  height: 116rpx;
  min-width: 116rpx;
  min-height: 116rpx;
  max-width: 116rpx;
  max-height: 116rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 58rpx;
  background: linear-gradient(135deg, #ff7a45, #ff965e);
  background: linear-gradient(135deg, var(--improv-primary, #ff7a45), var(--improv-primary-light, #ff965e));
  color: #ffffff;
  color: var(--improv-on-brand, #ffffff);
  font-size: 48rpx;
  line-height: 116rpx;
  box-shadow: 0 28rpx 56rpx rgba(255, 91, 46, 0.24);
  box-shadow: 0 28rpx 56rpx var(--improv-shadow-primary-color, rgba(255, 91, 46, 0.24));
}

.sheet-submit {
  width: 320rpx;
  min-width: 320rpx;
  max-width: 320rpx;
  min-height: 76rpx;
  margin: 32rpx auto 0;
  padding: 0;
  display: flex;
  font-size: 28rpx;
}

.filter-group-stack {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--improv-form-gap-section, 48rpx);
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: var(--improv-form-gap-related, 24rpx);
}

.recommend {
  position: relative;
  margin-top: 24rpx;
  padding: 32rpx;
  background:
    linear-gradient(135deg, rgba(255, 150, 106, 0.16), rgba(79, 140, 255, 0.1)),
    rgba(255, 255, 255, 0.94);
  background:
    linear-gradient(135deg, var(--improv-primary-glass, rgba(255, 150, 106, 0.16)), var(--improv-secondary-glass, rgba(79, 140, 255, 0.1))),
    var(--improv-card, rgba(255, 255, 255, 0.94));
}

.recommend-title {
  margin: 20rpx 0 12rpx;
  color: var(--improv-text);
  font-size: 40rpx;
  font-weight: 900;
}

.random-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 28rpx;
}

.random-actions button {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  min-height: 76rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
}

.random-state-card {
  margin-top: 24rpx;
}

.random-state-card .section-title {
  margin-top: 20rpx;
  font-size: 40rpx;
}

.random-state-card .muted {
  display: block;
  margin-top: 12rpx;
  line-height: 1.6;
  text-align: center;
}

.random-state-card .empty-actions {
  padding-top: 28rpx;
}

.random-state-card .empty-action-btn {
  flex: 1 1 0;
  min-width: 0;
}

.add-submit-btn {
  width: 100%;
  min-height: 88rpx;
  margin-top: 0;
  margin-bottom: 0;
  font-size: 32rpx;
}

.add-submit-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 0;
  padding: 0;
}

.add-sheet-spacer {
  height: 28rpx;
}

.random-card-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 720rpx;
  max-height: 85vh;
  margin-top: 40rpx;
  padding-bottom: 240rpx;
}

.random-game-sheet {
  display: flex;
  flex-direction: column;
  height: 85vh;
  padding-bottom: 0;
}
