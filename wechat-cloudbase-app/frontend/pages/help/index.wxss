@import '../../styles/theme.wxss';

.help-scroll {
  width: 100%;
  height: 100vh;
  min-height: 0;
  background: linear-gradient(180deg, #fafaf7 0%, #f7f8f3 54%, #f3f7f5 100%);
  background: linear-gradient(180deg, var(--improv-bg-top, #fafaf7) 0%, var(--improv-bg-mid, #f7f8f3) 54%, var(--improv-bg-bottom, #f3f7f5) 100%);
  color: var(--improv-text);
}

.help-page {
  width: 100%;
  min-height: 100vh;
  padding: var(--nav-row-top) var(--page-side) calc(60rpx + env(safe-area-inset-bottom));
}

.subpage-header {
  margin-bottom: 30rpx;
}

.help-hero {
  padding: 36rpx;
  background: var(--improv-surface-brand-gradient-soft), var(--improv-card);
}

.help-hero-title {
  display: block;
  margin-top: 14rpx;
  color: var(--improv-text);
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 900;
}

.help-steps {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.help-step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  color: var(--improv-text-soft);
  font-size: 26rpx;
  line-height: 1.6;
}

.help-step-index {
  flex: 0 0 42rpx;
  height: 42rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--improv-primary-tint);
  color: var(--improv-primary-warm);
  font-size: 22rpx;
  font-weight: 900;
}

.help-section {
  margin-top: 28rpx;
  padding: 32rpx 34rpx;
  border-radius: 24rpx;
  background: #ffffff;
  background: var(--improv-card, #ffffff);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.help-section-title,
.help-question,
.help-text {
  display: block;
}

.help-section-title {
  margin-bottom: 16rpx;
  color: var(--improv-text);
  font-size: 30rpx;
  font-weight: 900;
}

.help-question {
  margin-top: 22rpx;
  margin-bottom: 8rpx;
  color: var(--improv-text);
  font-size: 26rpx;
  font-weight: 900;
}

.help-text {
  margin-top: 10rpx;
  color: var(--improv-text-soft);
  font-size: 25rpx;
  line-height: 1.75;
}

.help-faq-section {
  margin-bottom: 12rpx;
}
