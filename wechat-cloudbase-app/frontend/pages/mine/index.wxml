<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page mine {{themeClass}} {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <view class="mine-content {{showIntroState ? 'mine-content-intro' : ''}}">
    <block wx:if="{{showIntroState}}">
      <view class="mine-intro-layout">
        <view class="intro-hero-section">
          <view class="card mine-host-card mine-intro-card">
            <view class="profile-card-head">
              <view class="avatar profile-avatar">
                <image wx:if="{{profileAvatar}}" class="avatar-image" src="{{profileAvatar}}" mode="aspectFill"></image>
                <text wx:else>{{profileAvatarText}}</text>
              </view>
              <view class="profile-card-main">
            <view class="profile-name">{{profileName}}</view>
            <view class="role-line">
              <text wx:for="{{profileTags}}" wx:key="*this" class="role-pill">{{item}}</text>
            </view>
          </view>
          <view class="profile-edit-btn" catchtap="openEditProfile">编辑</view>
        </view>
        <text class="muted">练习复盘、灵感和排练复盘，都会慢慢收进这里。</text>
          </view>
        </view>

        <view class="intro-stats-section">
          <view class="card mine-stats-card mine-stats-empty-card">
            <view><text>{{totalRecords}}</text><text>累计记录</text></view>
            <view><text>{{playedCount}}</text><text>练过素材</text></view>
            <view><text>{{methodCount}}</text><text>方法卡</text></view>
          </view>
        </view>

        <view class="intro-action-section">
          <view class="mine-card-list intro-fill-list">
            <view class="card mine-entry-card mine-guide-card intro-fill-card">
              <view class="intro-card-top">
                <text class="kicker intro-kicker">这里会出现什么</text>
              </view>
              <view class="intro-card-center">
                <view class="mine-entry-title intro-title">你的方法卡、灵感和排练记录</view>
                <text class="muted intro-body">每次现场记录，都会慢慢沉淀到这里。</text>
              </view>
              <view class="tags intro-tags"><text>方法卡</text><text>灵感回看</text><text>排练记录</text></view>
            </view>
            <view class="intro-actions intro-actions-outside">
              <button class="ghost-btn intro-link-btn" bindtap="goDiscover">去发现</button>
              <button class="primary-btn intro-primary-btn" bindtap="goRecord">去记录</button>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="card mine-host-card">
        <view class="profile-card-head">
          <view class="avatar profile-avatar">
            <image wx:if="{{profileAvatar}}" class="avatar-image" src="{{profileAvatar}}" mode="aspectFill"></image>
            <text wx:else>{{profileAvatarText}}</text>
          </view>
          <view class="profile-card-main">
            <view class="profile-name">{{profileName}}</view>
            <view class="role-line">
              <text wx:for="{{profileTags}}" wx:key="*this" class="role-pill">{{item}}</text>
            </view>
          </view>
          <view class="profile-edit-btn" catchtap="openEditProfile">编辑</view>
        </view>
        <text class="muted">把热身、关系和灵感收集成一套顺手可用的排练工具，让每次现场都能更快进入状态。</text>
      </view>

      <view wx:if="{{showStatsCard}}" class="card mine-stats-card">
        <view><text>{{totalRecords}}</text><text>累计记录</text></view>
        <view><text>{{playedCount}}</text><text>练过素材</text></view>
        <view><text>{{methodCount}}</text><text>方法卡</text></view>
      </view>

      <view class="mine-card-list">
        <view wx:if="{{showPendingCard}}" class="card mine-entry-card mine-pending-card" data-kind="pending" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">待整理</text>
            <view class="mine-entry-title">{{pendingCount}} 条可沉淀记录</view>
            <text class="muted">把灵感、素材练习和排练复盘整理成方法卡。</text>
          </view>
          <view class="mine-entry-action">整理</view>
          <view class="tags"><text>灵感</text><text>素材练习</text><text>排练复盘</text></view>
        </view>

        <view wx:if="{{showSedimentsCard}}" class="card mine-entry-card" data-kind="sediments" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">个人沉淀</text>
            <view class="mine-entry-title">{{sediments.length}} 张方法卡</view>
            <text class="muted">带领提醒、素材变体、复盘方法。</text>
          </view>
          <view class="mine-entry-action">查看</view>
          <view class="tags"><text>带领提醒</text><text>素材改造</text><text>排练复盘</text></view>
        </view>

        <view wx:if="{{showInspirationsCard}}" class="card mine-entry-card" data-kind="inspirations" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">灵感记录</text>
            <view class="mine-entry-title">{{inspirations.length}} 条灵感</view>
            <text class="muted">还没完全整理，但值得回看。</text>
          </view>
          <view class="mine-entry-action">查看</view>
        </view>

        <view wx:if="{{showGameRecordsCard}}" class="card mine-entry-card" bindtap="openGameRecords">
          <view class="mine-entry-main">
            <text class="kicker">练习记录</text>
            <view class="mine-entry-title">{{gameRecordsCount}} 次素材练习</view>
            <text class="muted">看看在练习里的 Keep & Try。</text>
          </view>
          <view class="mine-entry-action">查看</view>
        </view>

        <view wx:if="{{showRehearsalCard}}" class="card mine-entry-card" bindtap="openTeamRecords">
          <view class="mine-entry-main">
            <text class="kicker">排练记录</text>
            <view class="mine-entry-title">{{rehearsalCount}} 次排练</view>
            <text class="muted">最近更新于今天。</text>
          </view>
          <view class="mine-entry-action">查看</view>
        </view>

        <view wx:if="{{showLiteGuideCard}}" class="card mine-entry-card mine-guide-card mine-lite-guide-card">
          <view class="mine-entry-main no-action">
            <text class="kicker">继续积累</text>
            <view class="mine-entry-title">这里只保留已经发生的沉淀</view>
            <text class="muted">还没有更多资产时，不需要把所有入口都摆出来。去记录一次，内容会慢慢长出来。</text>
          </view>
          <view class="intro-actions mine-lite-guide-actions">
            <button class="ghost-btn intro-link-btn" bindtap="goDiscover">去发现</button>
            <button class="primary-btn intro-primary-btn" bindtap="goRecord">去记录</button>
          </view>
        </view>
      </view>
    </block>
  </view>

  <bottom-sheet visible="{{listVisible}}" title="{{listTitle}}" sheetClass="mine-list-sheet" bind:close="closeSheet">
    <view class="list-stack">
      <scroll-view wx:if="{{currentKind === 'sediments' && methodFilterOptions.length > 1}}" class="mine-filter-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}">
        <view class="mine-filter-row">
          <button wx:for="{{methodFilterOptions}}" wx:key="value" class="chip compact-filter-chip mine-filter-chip {{item.activeClass}}" data-filter="{{item.value}}" catchtap="filterMethodCards">{{item.label}}</button>
        </view>
      </scroll-view>
      <empty-state-panel wx:if="{{!listItems.length}}" customClass="empty-list" title="暂无记录" desc="{{currentKind === 'sediments' ? '还没沉淀方法卡，去整理一条吧。' : (currentKind === 'pending' ? '当前没有待整理记录。' : '还没有灵感记录，随时记下闪念。')}}" />
      <record-card wx:for="{{listItems}}" wx:key="title" itemId="{{item.id}}" badgeText="{{item.type}}" badgeTone="{{item.type === '素材练习' ? 'orange' : (item.type === '排练复盘' ? 'mint' : 'blue')}}" pending="{{item.syncStatus === 'pending'}}" title="{{item.title}}" desc="{{item.desc}}" meta="{{item.filteredMeta}}" bind:tapcard="openDetail" />
    </view>
  </bottom-sheet>

  <floating-card visible="{{detailVisible}}" title="{{detailTitle}}" count="{{detailCount}}" bind:close="closeDetail" bind:prev="prevDetail" bind:next="nextDetail">
    <asset-detail-panel wx:if="{{detailItem}}" badgeText="{{detailItem.type}}" badgeTone="{{detailItem.type === '素材练习' ? 'orange' : (detailItem.type === '排练复盘' ? 'mint' : 'blue')}}" pending="{{detailItem.syncStatus === 'pending'}}" title="{{detailItem.title}}" desc="{{detailItem.desc}}" meta="{{detailItem.filteredMeta}}" canSediment="{{detailCanSediment}}" loading="{{sedimentSaving}}" bind:discard="discardCurrentDetail" bind:sediment="sedimentCurrentDetail" />
  </floating-card>

  <bottom-sheet visible="{{profileEditVisible}}" title="编辑个人卡片" bodyMode="fit" sheetClass="profile-edit-sheet-shell" bind:close="closeSheet">
    <view class="profile-edit-sheet">
      <view class="profile-edit-avatar-container" bindtap="chooseProfileAvatar">
        <view class="avatar profile-editor-avatar">
          <image wx:if="{{profileDraftAvatar}}" class="avatar-image" src="{{profileDraftAvatar}}" mode="aspectFill"></image>
          <text wx:else>{{profileDraftAvatarText}}</text>
        </view>
        <text class="profile-avatar-tip">点击更换头像</text>
      </view>

      <form-field label="名字">
        <input class="app-input" type="nickname" value="{{profileDraftName}}" maxlength="12" placeholder="输入你的名字" bindblur="updateProfileName" bindconfirm="updateProfileName" />
      </form-field>

      <form-field label="剧团">
        <input class="app-input" type="text" value="{{profileDraftTroupeName}}" maxlength="12" placeholder="输入剧团名字（选填）" bindblur="updateProfileTroupeName" bindconfirm="updateProfileTroupeName" />
      </form-field>

      <form-field class="profile-tags-field" label="个人标签" desc="如果没有设置剧团名字，默认显示「即兴主理人」。">
        <view class="role-line profile-tag-line info-primary">
          <text wx:for="{{profileDraftTags}}" wx:key="*this" class="role-pill">{{item}}</text>
        </view>
      </form-field>

      <form-field class="profile-preference-field" label="偏好设置" desc="点击切换主题，即时生效并保存在本机">
        <view class="profile-tag-line info-primary">
          <view class="role-pill" catchtap="toggleTheme" style="padding: 10rpx 32rpx; min-height: 64rpx; background: var(--improv-card); color: var(--improv-text); border: 2rpx solid var(--improv-line-soft);">当前主题：{{themeClass === 'theme-vivid' ? '沉浸模式' : '默认模式'}}</view>
        </view>
      </form-field>

      <button class="primary-btn profile-save-btn" loading="{{profileSaving}}" bindtap="saveProfile">保存</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
