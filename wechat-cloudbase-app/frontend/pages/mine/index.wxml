<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page mine {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <view class="mine-content {{showIntroState ? 'mine-content-intro' : ''}}">
    <block wx:if="{{showIntroState}}">
      <view class="mine-intro-layout">
        <view class="intro-hero-section">
          <view class="card mine-host-card mine-intro-card">
            <view class="profile-card-head">
              <view class="avatar profile-avatar">
                <image wx:if="{{profileAvatar}}" class="avatar-image" src="{{profileAvatar}}" mode="aspectFill"></image>
                <text wx:else>{{profileAvatarText}}</text>
              </view>
              <view class="profile-card-main">
            <view class="profile-name">{{profileName}}</view>
            <view class="role-line">
              <text wx:for="{{profileTags}}" wx:key="*this" class="role-pill">{{item}}</text>
            </view>
          </view>
          <view class="profile-edit-btn" catchtap="openEditProfile">编辑</view>
        </view>
        <text class="muted">游戏反馈、灵感和排练复盘，都会慢慢收进这里。</text>
          </view>
        </view>

        <view class="intro-stats-section">
          <view class="card mine-stats-card mine-stats-empty-card">
            <view><text>{{totalRecords}}</text><text>累计记录</text></view>
            <view><text>{{playedCount}}</text><text>玩过游戏</text></view>
            <view><text>{{methodCount}}</text><text>方法卡</text></view>
          </view>
        </view>

        <view class="intro-action-section">
          <view class="mine-card-list intro-fill-list">
            <view class="card mine-entry-card mine-guide-card intro-fill-card">
              <view class="intro-card-top">
                <text class="kicker intro-kicker">这里会出现什么</text>
              </view>
              <view class="intro-card-center">
                <view class="mine-entry-title intro-title">你的方法卡、灵感和排练记录</view>
                <text class="muted intro-body">每次现场记录，都会慢慢沉淀到这里。</text>
              </view>
              <view class="tags intro-tags"><text>方法卡</text><text>灵感回看</text><text>排练记录</text></view>
            </view>
            <view class="intro-actions intro-actions-outside">
              <button class="ghost-btn intro-link-btn" bindtap="goDiscover">去发现</button>
              <button class="primary-btn intro-primary-btn" bindtap="goRecord">去记录</button>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="card mine-host-card">
        <view class="profile-card-head">
          <view class="avatar profile-avatar">
            <image wx:if="{{profileAvatar}}" class="avatar-image" src="{{profileAvatar}}" mode="aspectFill"></image>
            <text wx:else>{{profileAvatarText}}</text>
          </view>
          <view class="profile-card-main">
            <view class="profile-name">{{profileName}}</view>
            <view class="role-line">
              <text wx:for="{{profileTags}}" wx:key="*this" class="role-pill">{{item}}</text>
            </view>
          </view>
          <view class="profile-edit-btn" catchtap="openEditProfile">编辑</view>
        </view>
        <text class="muted">把热身、关系和灵感收集成一套顺手可用的排练工具，让每次现场都能更快进入状态。</text>
      </view>

      <view class="card mine-stats-card">
        <view><text>{{totalRecords}}</text><text>累计记录</text></view>
        <view><text>{{playedCount}}</text><text>玩过游戏</text></view>
        <view><text>{{methodCount}}</text><text>方法卡</text></view>
      </view>

      <view class="mine-card-list">
        <view class="card mine-entry-card" data-kind="sediments" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">个人沉淀</text>
            <view class="mine-entry-title">{{sediments.length}} 张方法卡</view>
            <text wx:if="{{sediments.length > 0}}" class="muted">带领提醒、游戏变体、复盘方法。</text>
            <text wx:else class="muted">还没沉淀方法卡，去整理一条吧。</text>
          </view>
          <view class="mine-entry-action">查看</view>
          <view class="tags"><text>带领提醒</text><text>游戏改造</text><text>排练复盘</text></view>
        </view>

        <view class="card mine-entry-card" data-kind="inspirations" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">灵感记录</text>
            <view class="mine-entry-title">{{inspirations.length}} 条灵感</view>
            <text wx:if="{{inspirations.length > 0}}" class="muted">还没完全整理，但值得回看。</text>
            <text wx:else class="muted">还没有灵感记录，随时记下闪念。</text>
          </view>
          <view class="mine-entry-action">查看</view>
        </view>

        <view class="card mine-entry-card" bindtap="openGameRecords">
          <view class="mine-entry-main">
            <text class="kicker">游戏记录</text>
            <view class="mine-entry-title">{{gameRecordsCount}} 次游戏实践</view>
            <text wx:if="{{gameRecordsCount > 0}}" class="muted">看看在游戏里的 Keep & Try。</text>
            <text wx:else class="muted">还没有游戏记录，去玩一次吧。</text>
          </view>
          <view class="mine-entry-action">查看</view>
        </view>

        <view class="card mine-entry-card" bindtap="openTeamRecords">
          <view class="mine-entry-main">
            <text class="kicker">排练记录</text>
            <view class="mine-entry-title">{{rehearsalCount}} 次排练</view>
            <text wx:if="{{rehearsalCount > 0}}" class="muted">最近更新于今天。</text>
            <text wx:else class="muted">还没有排练过，去开启一次吧。</text>
          </view>
          <view class="mine-entry-action">查看</view>
        </view>
      </view>
    </block>
  </view>

  <bottom-sheet visible="{{listVisible}}" title="{{listTitle}}" sheetClass="mine-list-sheet" bind:close="closeSheet">
    <view class="list-stack">
      <view wx:if="{{!listItems.length}}" class="empty-list">
        <view class="mine-entry-title">暂无记录</view>
        <text wx:if="{{currentKind === 'sediments'}}" class="muted">还没沉淀方法卡，去整理一条吧。</text>
        <text wx:else class="muted">还没有灵感记录，随时记下闪念。</text>
      </view>
      <view wx:for="{{listItems}}" wx:key="title" class="card list-item" data-index="{{index}}" bindtap="openDetail">
        <view class="list-item-head">
          <text class="pill {{item.type === '游戏实践' ? 'orange' : (item.type === '排练复盘' ? 'mint' : 'blue')}}">{{item.type}}</text>
          <text wx:if="{{item.syncStatus === 'pending'}}" class="sync-pill">待同步</text>
        </view>
        <view class="mine-entry-title">{{item.title}}</view>
        <text class="muted">{{item.desc}}</text>
        <view wx:if="{{item.meta && item.meta.length}}" class="tags list-tags">
          <block wx:for="{{item.meta}}" wx:key="*this" wx:for-item="metaItem">
            <text wx:if="{{metaItem !== item.type}}">{{metaItem}}</text>
          </block>
        </view>
      </view>
    </view>
  </bottom-sheet>

  <floating-card visible="{{detailVisible}}" title="{{detailTitle}}" count="{{detailCount}}" bind:close="closeDetail" bind:prev="prevDetail" bind:next="nextDetail">
    <view wx:if="{{detailItem}}" class="detail-card">
      <view class="detail-panel">
        <view class="detail-content-wrapper">
          <view class="list-item-head">
            <text class="pill {{detailItem.type === '游戏实践' ? 'orange' : (detailItem.type === '排练复盘' ? 'mint' : 'blue')}}">{{detailItem.type}}</text>
            <text wx:if="{{detailItem.syncStatus === 'pending'}}" class="sync-pill">待同步</text>
          </view>
          <view class="detail-title">{{detailItem.title}}</view>
          <text class="muted detail-desc">{{detailItem.desc}}</text>
          <view class="tags detail-tags">
            <block wx:for="{{detailItem.meta}}" wx:key="*this" wx:for-item="metaItem">
              <text wx:if="{{metaItem !== detailItem.type}}" class="pill-meta">{{metaItem}}</text>
            </block>
          </view>
        </view>
      </view>
    </view>
  </floating-card>

  <bottom-sheet visible="{{profileEditVisible}}" title="编辑个人卡片" bodyMode="fit" sheetClass="profile-edit-sheet-shell" bind:close="closeSheet">
    <view class="profile-edit-sheet">
      <view class="profile-edit-avatar-container" bindtap="chooseProfileAvatar">
        <view class="avatar profile-editor-avatar">
          <image wx:if="{{profileDraftAvatar}}" class="avatar-image" src="{{profileDraftAvatar}}" mode="aspectFill"></image>
          <text wx:else>{{profileDraftAvatarText}}</text>
        </view>
        <text class="profile-avatar-tip">点击更换头像</text>
      </view>

      <label class="field profile-name-field">
        <text>名字</text>
        <view class="input-shell">
          <input type="nickname" value="{{profileDraftName}}" maxlength="12" placeholder="输入你的名字" bindblur="updateProfileName" bindconfirm="updateProfileName" />
        </view>
      </label>

      <label class="field profile-name-field">
        <text>剧团</text>
        <view class="input-shell">
          <input type="text" value="{{profileDraftTroupeName}}" maxlength="12" placeholder="输入剧团名字（选填）" bindblur="updateProfileTroupeName" bindconfirm="updateProfileTroupeName" />
        </view>
      </label>

      <view class="profile-tag-field">
        <text class="mini-title">个人标签</text>
        <view class="role-line profile-tag-line">
          <text wx:for="{{profileDraftTags}}" wx:key="*this" class="role-pill">{{item}}</text>
        </view>
        <text class="muted">如果没有设置剧团名字，默认显示「即兴主理人」。</text>
      </view>

      <button class="primary-btn profile-save-btn" loading="{{profileSaving}}" bindtap="saveProfile">保存</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
