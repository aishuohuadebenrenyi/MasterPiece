<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" bindscroll="onScroll" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" bindrefresherrefresh="onPullDownRefresh" class="page mine {{themeClass}} {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <button class="settings-entry-btn" aria-label="设置" bindtap="goSettings">设置</button>
  <view class="mine-content {{showIntroState ? 'mine-content-intro' : ''}}">
    <empty-state-panel wx:if="{{loadErrorText}}" tone="error" title="数据未完全加载" desc="{{loadErrorText}}" />
    <block wx:if="{{showIntroState}}">
      <view class="mine-intro-layout">
        <view class="intro-hero-section">
          <view class="card mine-host-card mine-intro-card">
            <view class="profile-card-head">
              <view class="avatar profile-avatar">
                <image wx:if="{{profileAvatar}}" class="avatar-image" src="{{profileAvatar}}" mode="aspectFill"></image>
                <text wx:else class="avatar-fallback-text">{{profileAvatarText}}</text>
              </view>
              <view class="profile-card-main">
            <view class="profile-name">{{profileName}}</view>
            <view class="role-line">
              <text wx:for="{{profileTags}}" wx:key="*this" class="role-pill">{{item}}</text>
            </view>
          </view>
          <button class="small-btn profile-edit-btn" catchtap="openEditProfile">编辑</button>
        </view>
        <text class="muted">灵感、练习和排练记录都在这里。</text>
          </view>
        </view>

        <view class="intro-stats-section">
          <view class="card mine-stats-card mine-stats-empty-card">
            <view><text>{{totalRecords}}</text><text>累计记录</text></view>
            <view><text>{{playedCount}}</text><text>练过素材</text></view>
            <view><text>{{methodCount}}</text><text>方法卡</text></view>
          </view>
        </view>

        <view class="intro-action-section">
          <view class="mine-card-list intro-fill-list">
            <view class="card mine-entry-card mine-guide-card intro-fill-card">
              <view class="intro-card-center">
                <view class="mine-entry-title intro-title">你的记录与方法卡</view>
              </view>
              <view class="tags intro-tags"><text>方法卡</text><text>灵感回看</text><text>排练记录</text></view>
            </view>
            <view class="intro-actions intro-actions-outside">
              <button class="ghost-btn intro-link-btn" bindtap="goDiscover">去发现</button>
              <button class="primary-btn intro-primary-btn" bindtap="goRecord">去记录</button>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="card mine-host-card">
        <view class="profile-card-head">
          <view class="avatar profile-avatar">
            <image wx:if="{{profileAvatar}}" class="avatar-image" src="{{profileAvatar}}" mode="aspectFill"></image>
            <text wx:else class="avatar-fallback-text">{{profileAvatarText}}</text>
          </view>
          <view class="profile-card-main">
            <view class="profile-name">{{profileName}}</view>
            <view class="role-line">
              <text wx:for="{{profileTags}}" wx:key="*this" class="role-pill">{{item}}</text>
            </view>
          </view>
          <button class="small-btn profile-edit-btn" catchtap="openEditProfile">编辑</button>
        </view>
      </view>

      <view wx:if="{{showStatsCard}}" class="card mine-stats-card">
        <view><text>{{totalRecords}}</text><text>累计记录</text></view>
        <view><text>{{playedCount}}</text><text>练过素材</text></view>
        <view><text>{{methodCount}}</text><text>方法卡</text></view>
      </view>

      <view class="mine-card-list">
        <view wx:if="{{showPendingCard}}" class="card mine-entry-card mine-pending-card" data-kind="pending" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">待整理</text>
            <view class="mine-entry-title">{{pendingCount}} 条可沉淀记录</view>
          </view>
          <view class="small-btn mine-entry-action" data-kind="pending" catchtap="openList">整理</view>
          <view class="tags"><text>灵感</text><text>素材练习</text><text>排练复盘</text></view>
        </view>

        <view wx:if="{{showSedimentsCard}}" class="card mine-entry-card" data-kind="sediments" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">个人沉淀</text>
            <view class="mine-entry-title">{{sediments.length}} 张方法卡</view>
          </view>
          <view class="small-btn mine-entry-action" data-kind="sediments" catchtap="openList">查看</view>
          <view class="tags"><text>带领提醒</text><text>素材改造</text><text>排练复盘</text></view>
        </view>

        <view wx:if="{{showInspirationsCard}}" class="card mine-entry-card" data-kind="inspirations" bindtap="openList">
          <view class="mine-entry-main">
            <text class="kicker">灵感记录</text>
            <view class="mine-entry-title">{{inspirations.length}} 条灵感</view>
          </view>
          <view class="small-btn mine-entry-action" data-kind="inspirations" catchtap="openList">查看</view>
        </view>

        <view wx:if="{{showPracticeRecordsCard}}" class="card mine-entry-card" bindtap="openPracticeRecords">
          <view class="mine-entry-main">
            <text class="kicker">练习记录</text>
            <view class="mine-entry-title">{{practiceRecordsCount}} 次素材练习</view>
          </view>
          <view class="small-btn mine-entry-action" catchtap="openPracticeRecords">查看</view>
        </view>

        <view wx:if="{{showRehearsalCard}}" class="card mine-entry-card" bindtap="openTeamRecords">
          <view class="mine-entry-main">
            <text class="kicker">排练记录</text>
            <view class="mine-entry-title">{{rehearsalCount}} 次排练</view>
          </view>
          <view class="small-btn mine-entry-action" catchtap="openTeamRecords">查看</view>
        </view>
      </view>
    </block>
  </view>

  <bottom-sheet visible="{{listVisible}}" title="{{listTitle}}" sheetClass="mine-list-sheet" bodyMode="fit" bind:close="closeSheet">
    <view class="list-stack">
      <scroll-view wx:if="{{currentKind === 'sediments' && methodFilterOptions.length > 1}}" class="mine-filter-scroll" scroll-x="true" enable-flex="true" enhanced show-scrollbar="{{false}}">
        <view class="mine-filter-row">
          <button wx:for="{{methodFilterOptions}}" wx:key="value" class="chip compact-filter-chip mine-filter-chip {{item.activeClass}}" data-filter="{{item.value}}" catchtap="filterMethodCards">{{item.label}}</button>
        </view>
      </scroll-view>
      <view wx:if="{{currentKind === 'inspirations'}}" class="mine-inspiration-filter-row">
          <button wx:for="{{inspirationFilterOptions}}" wx:key="value" class="chip compact-filter-chip mine-filter-chip {{item.activeClass}}" data-filter="{{item.value}}" catchtap="filterInspirations">{{item.label}}</button>
      </view>
      <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="mine-list-scroll">
        <empty-state-panel wx:if="{{!listItems.length}}" customClass="empty-list" title="暂无记录" desc="{{currentKind === 'sediments' ? '还没沉淀方法卡，去整理一条吧。' : (currentKind === 'pending' ? '当前没有待整理记录。' : '还没有灵感记录，随时记下闪念。')}}" />
        <view wx:for="{{listItems}}" wx:key="id" class="mine-list-item-wrap">
          <record-card customClass="mine-list-record-card" itemId="{{item.id}}" layoutKind="{{item.cardView.layoutKind}}" title="{{item.cardView.title}}" bodyText="{{item.cardView.bodyText}}" metaPills="{{item.cardView.metaPills}}" pending="{{item.cardView.pending}}" badgeText="{{item.cardView.badgeText}}" badgeTone="{{item.cardView.badgeTone}}" primaryActionText="{{(currentKind === 'sediments' || currentKind === 'inspirations' || (currentKind === 'pending' && item.sourceType === 'inspiration')) ? '编辑' : ''}}" bind:tapcard="openDetail" bind:action="onEditCard" />
        </view>
      </scroll-view>
    </view>
  </bottom-sheet>

  <floating-card visible="{{detailVisible}}" title="{{detailTitle}}" count="{{detailCount}}" bind:close="closeDetail" bind:prev="prevDetail" bind:next="nextDetail">
    <asset-detail-panel wx:if="{{detailItem}}" badgeText="{{detailItem.type}}" badgeTone="{{detailItem.type === '素材练习' ? 'orange' : (detailItem.type === '排练复盘' ? 'mint' : 'blue')}}" pending="{{detailItem.syncStatus === 'pending'}}" title="{{detailItem.title}}" desc="{{detailItem.desc}}" meta="{{detailItem.filteredMeta}}" canSediment="{{detailCanSediment}}" canMarkIntent="{{detailCanSediment && detailItem.sourceType === 'inspiration'}}" selectedIntent="{{detailSelectedIntent}}" loading="{{sedimentSaving}}" bind:discard="discardCurrentDetail" bind:sediment="sedimentCurrentDetail" bind:markintent="markCurrentDetailIntent" />
  </floating-card>

  <bottom-sheet visible="{{profileEditVisible}}" title="编辑个人卡片" bodyMode="fit" sheetClass="profile-edit-sheet-shell" showActions="{{true}}" closeOnMask="{{false}}" bind:close="closeSheet">
    <view class="profile-edit-sheet">
      <view class="profile-edit-avatar-container" bindtap="chooseProfileAvatar">
        <view class="avatar profile-editor-avatar">
          <image wx:if="{{profileDraftAvatar}}" class="avatar-image" src="{{profileDraftAvatar}}" mode="aspectFill"></image>
          <text wx:else class="avatar-fallback-text">{{profileDraftAvatarText}}</text>
        </view>
        <text class="profile-avatar-tip">点击更换头像</text>
      </view>

      <form-field label="名字">
        <input class="app-input" type="nickname" value="{{profileDraftName}}" maxlength="12" placeholder="输入你的名字" bindblur="updateProfileName" bindconfirm="updateProfileName" />
      </form-field>

      <form-field label="剧团（选填）">
        <input class="app-input" type="text" value="{{profileDraftTroupeName}}" maxlength="12" placeholder="剧团名称" bindblur="updateProfileTroupeName" bindconfirm="updateProfileTroupeName" />
      </form-field>

      <form-field class="profile-tags-field" label="个人标签" desc="未填写剧团时显示「即兴主理人」">
        <view class="role-line profile-tag-line info-primary">
          <text wx:for="{{profileDraftTags}}" wx:key="*this" class="role-pill">{{item}}</text>
        </view>
      </form-field>

    </view>
    <view slot="actions" class="profile-action-bar">
      <button class="primary-btn profile-save-btn" loading="{{profileSaving}}" bindtap="saveProfile">保存</button>
    </view>
  </bottom-sheet>

  <bottom-sheet visible="{{showMethodCardEditSheet}}" title="编辑方法卡" bodyMode="fit" showActions="{{true}}" closeOnMask="{{false}}" bind:close="closeMethodCardEdit">
    <view class="edit-form">
      <view class="edit-form-field">
        <text class="edit-form-label">标题</text>
        <input class="edit-form-input" value="{{methodCardDraftTitle}}" bindblur="onMethodCardDraftTitleInput" bindconfirm="onMethodCardDraftTitleInput" placeholder="方法卡标题" />
      </view>
      <view class="edit-form-field">
        <text class="edit-form-label">内容</text>
        <textarea class="edit-form-textarea" value="{{methodCardDraftContent}}" bindblur="onMethodCardDraftContentInput" placeholder="方法卡内容" />
      </view>
    </view>
    <view slot="actions" class="method-edit-actions">
      <button class="primary-btn edit-form-submit" bindtap="saveMethodCardEdit">保存</button>
    </view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>

<privacy-popup visible="{{privacyVisible}}" bind:agree="onPrivacyAgree" bind:refuse="onPrivacyRefuse" />
