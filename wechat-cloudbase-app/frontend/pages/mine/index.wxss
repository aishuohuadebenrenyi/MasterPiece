.mine {
  width: 100%;
  padding: 132rpx 40rpx 270rpx;
}

.host {
  width: 100%;
  padding: 46rpx 36rpx 38rpx;
  margin-bottom: 30rpx;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.88)),
    linear-gradient(135deg, rgba(255, 122, 69, 0.18), rgba(79, 140, 255, 0.16));
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  border-radius: 62rpx;
  background: linear-gradient(145deg, #4f8cff, #ff7a45);
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 124rpx;
  text-align: center;
}

.grow {
  flex: 1 1 0;
  min-width: 0;
  width: 0;
}

.host .row {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 28rpx;
}

.host .muted {
  display: block;
  width: 100%;
  margin-top: 28rpx;
  line-height: 1.72;
}

.host-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
  margin-top: 26rpx;
}

.host-meta text {
  color: #667289;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-name,
.entry-title,
.detail-title {
  color: #24324a;
  font-size: 38rpx;
  font-weight: 900;
}

.role-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.role-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #2f6ff2;
  font-size: 24rpx;
  font-weight: 900;
}

.role-text {
  color: #667289;
  font-size: 26rpx;
  font-weight: 800;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tags text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #2f6ff2;
  font-size: 24rpx;
  font-weight: 800;
}

.stats {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 34rpx 18rpx;
  margin-top: 0;
  margin-bottom: 32rpx;
  text-align: center;
}

.stats text:first-child {
  display: block;
  color: #24324a;
  font-size: 46rpx;
  font-weight: 900;
}

.stats text:last-child {
  color: #667289;
  font-size: 24rpx;
}

.entry-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 0;
}

.entry,
.list-item {
  width: 100%;
  min-width: 100%;
  display: block;
  padding: 36rpx 32rpx 34rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: left;
}

.entry .row,
.list-item .row {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.entry .row > view {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.link {
  flex: 0 0 auto;
  min-width: 72rpx;
  padding-top: 8rpx;
  color: #2f6ff2;
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
  line-height: 1.25;
}

.detail-card {
  min-height: 0;
  padding-top: 4rpx;
}

.detail-title {
  margin: 18rpx 0 16rpx;
  font-size: 42rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-item {
  border: 0;
  box-shadow: none;
}

.list-tags {
  margin-top: 18rpx;
}

.detail-panel {
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.9);
}

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
}

.detail-count {
  color: #96a1b4;
  font-size: 24rpx;
  font-weight: 900;
}
