.subpage-header {
  margin-bottom: 14rpx;
}

.subpage-page {
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
}

.subpage-header .back {
  margin-bottom: 12rpx;
}

.page-title,
.section-title {
  color: var(--improv-text);
  font-weight: 900;
}

.page-title {
  font-size: 56rpx;
  line-height: 1.1;
}

.record-form-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
}

.form-actions,
.save-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.form-actions button,
.save-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.save-actions {
  width: 84%;
  margin: 24rpx auto 0;
}

.insight-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.insight-title {
  margin: 14rpx 0 10rpx;
}

.sheet-submit {
  width: 100%;
  margin-top: 24rpx;
}
