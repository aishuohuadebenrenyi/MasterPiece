.back {
  margin-bottom: 24rpx;
}

.form-card {
  padding: 32rpx;
  margin-top: 24rpx;
}

.section-title {
  color: #24324a;
  font-size: 32rpx;
  font-weight: 900;
}

.form-actions,
.center-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 28rpx;
}

.form-actions button,
.center-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.center-actions {
  width: 78%;
  margin-left: auto;
  margin-right: auto;
}

.insight-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.insight-title {
  margin: 14rpx 0 10rpx;
}

.sheet-submit {
  width: 100%;
  margin-top: 24rpx;
}
