<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="page subpage-page {{modalOpen ? 'modal-open' : ''}} {{themeClass}}" style="{{layoutStyle}}">
  <subpage-header kicker="排练复盘" title="结束并复盘" bind:back="back" />

  <form-card title="{{reviewTitle}}" kicker="整体复盘">
    <view class="form-field-stack">
      <form-field label="整体 Keep">
        <textarea class="app-textarea" value="{{keepValue}}" data-field="keepValue" bindblur="updateField" />
      </form-field>
      <form-field label="整体 Try">
        <textarea class="app-textarea" value="{{tryValue}}" data-field="tryValue" bindblur="updateField" />
      </form-field>
      <form-field label="下次提醒">
        <input class="app-input" value="{{reminderValue}}" data-field="reminderValue" bindblur="updateField" bindconfirm="updateField" />
      </form-field>
    </view>
  </form-card>

  <form-card title="这次想留下什么" kicker="沉淀方向">
    <view class="choice-section">
      <view class="form-chip-row">
        <button class="chip compact-filter-chip {{selectedDirections.indexOf('带领提醒') >= 0 ? 'active' : ''}}" data-value="带领提醒" bindtap="toggleDirection">带领提醒</button>
        <button class="chip compact-filter-chip {{selectedDirections.indexOf('游戏调整') >= 0 ? 'active' : ''}}" data-value="游戏调整" bindtap="toggleDirection">游戏调整</button>
        <button class="chip compact-filter-chip {{selectedDirections.indexOf('下次计划') >= 0 ? 'active' : ''}}" data-value="下次计划" bindtap="toggleDirection">下次计划</button>
      </view>
    </view>
  </form-card>

  <root-portal wx:if="{{!modalOpen}}">
    <view class="form-actions">
      <button class="ghost-btn" bindtap="createMethodCard">沉淀为方法卡</button>
      <button class="primary-btn" bindtap="save">保存复盘</button>
    </view>
  </root-portal>

  <bottom-sheet visible="{{insightVisible}}" title="个人沉淀" bodyMode="fit" bind:close="closeSheet">
    <view class="card insight-card">
      <text class="pill orange">带领提醒</text>
      <view class="section-title insight-title">{{methodTitle}}</view>
      <text class="muted">{{reminderValue}}</text>
    </view>
    <button class="primary-btn sheet-submit" bindtap="saveMethodCard">保存为方法卡</button>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
