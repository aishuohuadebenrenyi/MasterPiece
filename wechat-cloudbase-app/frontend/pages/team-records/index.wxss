.team-records-scroll {
  width: 100%;
  height: 100vh;
  min-height: 0;
}

.team-records-page {
  width: 100%;
  min-height: 0;
  padding: var(--nav-row-top) var(--page-side) calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.subpage-header {
  margin-bottom: 28rpx;
}

.record-form-card,
.record-item {
  padding: var(--improv-card-padding-md, 40rpx);
}

.summary-card {
  margin-bottom: 30rpx;
}

.record-list {
  width: 100%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.record-item-wrap {
  width: 100%;
  min-width: 0;
}

.record-item .muted {
  display: block;
  margin-top: 16rpx;
}

.empty-actions {
  justify-content: center;
  margin-top: 24rpx;
}

.empty-action-btn {
  flex: 0 1 240rpx;
  min-width: 0;
  max-width: 240rpx;
}

.detail-card {
  padding: 28rpx;
  border-radius: 30rpx;
  background: var(--improv-bg-subtle);
}

.detail-title {
  margin-top: 6rpx;
  color: var(--improv-text);
  font-size: 36rpx;
  line-height: 1.18;
  font-weight: 900;
}

.detail-meta {
  margin-top: 22rpx;
}

.detail-section {
  margin-top: 28rpx;
}

.detail-plan {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.detail-game {
  padding: 24rpx;
  border: 2rpx solid var(--improv-line-soft);
  border-radius: 28rpx;
  background: var(--improv-card-strong);
}

.detail-game-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.step-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--improv-secondary-soft);
  color: var(--improv-secondary-alt);
  font-size: 24rpx;
  font-weight: 900;
}

.detail-game-title {
  color: var(--improv-text);
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.detail-notes {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid var(--improv-line-subtle);
  color: var(--improv-muted);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 800;
}

.readonly-note {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: var(--improv-primary-tint);
  color: var(--improv-muted);
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 800;
}
