.back {
  margin-bottom: 24rpx;
}

.summary,
.record {
  padding: 32rpx;
  margin-top: 24rpx;
}

.section-title {
  color: #24324a;
  font-size: 32rpx;
  font-weight: 900;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta text {
  padding: 10rpx 18rpx;
  background: #f4f6fb;
  color: #667289;
  font-size: 24rpx;
  font-weight: 800;
}

.record-list {
  display: grid;
  gap: 24rpx;
}
