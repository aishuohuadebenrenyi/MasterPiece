<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="team-records-scroll {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <view class="team-records-page">
    <subpage-header title="排练记录" bind:back="back" />

    <form-card wx:if="{{showSummaryCard}}" title="最近排练" kicker="排练概览">
      <view class="card-head">
        <text class="muted">按时间回看排练记录、游戏反馈和下次提醒。</text>
        <text class="pill blue">{{records.length}} 条</text>
      </view>
    </form-card>

    <view wx:if="{{errorText}}" class="notice-note-card">{{errorText}}</view>

    <view wx:if="{{loading}}" class="state-note-card">正在同步排练记录...</view>
    <empty-state-panel wx:elif="{{!records.length}}" title="还没有排练记录" desc="这里会回看排练目标、游戏计划和复盘结果。先开启一次排练，内容才值得留下来。" primaryText="去记录" secondaryText="去发现" bind:primary="goRecord" bind:secondary="goDiscover" />

    <view wx:else class="record-list">
      <record-card wx:for="{{records}}" wx:key="id" itemId="{{item.id}}" miniTitle="{{item.dateLabel}} · {{item.duration}} 分钟" title="{{item.displayTitle}}" desc="{{item.displayDesc}}" meta="{{item.displayMeta}}" pending="{{item.syncStatus === 'pending'}}" actionText="查看" bind:action="openRecord" />
    </view>
  </view>

  <bottom-sheet visible="{{detailVisible}}" title="排练详情" sheetClass="record-detail-sheet" bind:close="closeSheet">
    <record-detail-panel wx:if="{{selectedRecord}}" title="{{selectedRecord.displayTitle}}" desc="{{selectedRecord.displayDesc}}" meta="{{selectedDetailMeta}}" pending="{{selectedRecord.syncStatus === 'pending'}}" sectionTitle="排练计划" plan="{{selectedPlan}}" planEmptyText="这次排练没有保存具体游戏计划。" readonlyNote="这是历史记录的只读回看。需要再次排练时，从记录页或游戏详情重新创建。" />
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}} {{themeClass}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
