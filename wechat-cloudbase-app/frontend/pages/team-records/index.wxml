<scroll-view scroll-y="{{!modalOpen}}" enhanced show-scrollbar="{{false}}" class="team-records-scroll {{modalOpen ? 'modal-open' : ''}}" style="{{layoutStyle}}">
  <view class="team-records-page">
    <view class="subpage-header safe-right">
      <view class="team-back" aria-label="返回" bindtap="back">←</view>
      <view class="page-title">排练记录</view>
    </view>

    <view class="card record-form-card summary-card">
      <view class="card-head">
        <view>
          <view class="section-title">最近排练</view>
          <text class="muted">按时间回看排练记录、游戏反馈和下次提醒。</text>
        </view>
        <text class="pill blue">{{records.length}} 条</text>
      </view>
    </view>

    <view wx:if="{{errorText}}" class="notice-card">{{errorText}}</view>

    <view wx:if="{{loading}}" class="state-card">正在同步排练记录...</view>
    <view wx:elif="{{!records.length}}" class="state-card empty-state">
      <view class="section-title">暂无记录</view>
      <text class="muted">还没有排练过，去开启一次吧。</text>
    </view>

    <view wx:else class="record-list">
      <view wx:for="{{records}}" wx:key="id" class="card record-item">
        <view class="card-head">
          <view>
            <text class="mini-title">{{item.dateLabel}} · {{item.duration}} 分钟</text>
            <view class="section-title">{{item.displayTitle}}</view>
          </view>
          <button class="small-btn" data-id="{{item.id}}" bindtap="openRecord">查看</button>
        </view>
        <text class="muted">{{item.displayDesc}}</text>
        <view class="meta"><text wx:for="{{item.displayMeta}}" wx:key="*this">{{item}}</text><text wx:if="{{item.syncStatus === 'pending'}}" class="pending">待同步</text></view>
      </view>
    </view>
  </view>

  <bottom-sheet visible="{{detailVisible}}" title="排练详情" sheetClass="record-detail-sheet" bind:close="closeSheet">
    <view wx:if="{{selectedRecord}}" class="detail-card">
      <view class="detail-title">{{selectedRecord.displayTitle}}</view>
      <text class="muted">{{selectedRecord.displayDesc}}</text>
      <view class="meta detail-meta">
        <text>{{selectedRecord.duration}} 分钟</text>
        <text>{{selectedRecord.statusLabel}}</text>
        <text>{{selectedPlan.length}} 个游戏</text>
        <text wx:if="{{selectedRecord.syncStatus === 'pending'}}" class="pending">待同步</text>
      </view>
    </view>

    <view class="detail-section">
      <view class="section-title">排练计划</view>
      <view wx:if="{{selectedPlan.length}}" class="detail-plan">
        <view wx:for="{{selectedPlan}}" wx:key="gameId" class="detail-game">
          <view class="detail-game-head">
            <text class="step-index">{{index + 1}}</text>
            <view>
              <view class="detail-game-title">{{item.title}}</view>
              <text class="muted">{{item.status}}</text>
            </view>
          </view>
          <view wx:if="{{item.keep || item.try}}" class="detail-notes">
            <text wx:if="{{item.keep}}">Keep：{{item.keep}}</text>
            <text wx:if="{{item.try}}">Try：{{item.try}}</text>
          </view>
        </view>
      </view>
      <text wx:else class="muted">这次排练没有保存具体游戏计划。</text>
    </view>

    <view class="readonly-note">这是历史记录的只读回看。需要再次排练时，从记录页或游戏详情重新创建。</view>
  </bottom-sheet>

  <root-portal wx:if="{{appToastVisible}}">
    <view class="app-toast app-toast-{{appToastTone}}"><text>{{appToastTitle}}</text></view>
  </root-portal>
</scroll-view>
