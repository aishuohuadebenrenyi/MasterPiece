@import '../../styles/theme.wxss';

.privacy-content {
  display: flex;
  flex-direction: column;
}

.privacy-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--improv-text);
  margin-bottom: 8rpx;
}

.privacy-updated {
  font-size: 24rpx;
  color: var(--improv-text-muted);
  margin-bottom: 32rpx;
}

.privacy-section-title {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--improv-text);
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}

.privacy-text {
  font-size: 26rpx;
  color: var(--improv-text-soft);
  line-height: 1.7;
  margin-bottom: 8rpx;
}
